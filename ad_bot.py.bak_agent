async def fb_get_active_campaigns():
    """Получает список активных кампаний из FB"""
    url = f"{FB_BASE_URL}/{FB_AD_ACCOUNT_ID}/campaigns"
    params = {
        "access_token": FB_ACCESS_TOKEN,
        "fields": "name,status,objective,daily_budget,lifetime_budget",
        "filtering": json.dumps([{"field": "effective_status", "operator": "IN", "value": ["ACTIVE", "PAUSED"]}]),
        "limit": 50,
    }
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(url, params=params, timeout=aiohttp.ClientTimeout(total=15)) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    return {"ok": True, "data": data.get("data", [])}
                else:
                    error = await resp.text()
                    return {"ok": False, "error": f"HTTP {resp.status}"}
    except Exception as e:
        return {"ok": False, "error": str(e)}


async def fb_get_campaign_insights(campaign_id, date_preset="last_7d"):
    """Получает статистику конкретной кампании"""
    url = f"{FB_BASE_URL}/{campaign_id}/insights"
    params = {
        "access_token": FB_ACCESS_TOKEN,
        "fields": "spend,impressions,clicks,cpc,ctr,cpm,actions,cost_per_action_type,frequency",
        "date_preset": date_preset,
    }
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(url, params=params, timeout=aiohttp.ClientTimeout(total=15)) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    return {"ok": True, "data": data.get("data", [])}
                else:
                    return {"ok": False, "error": f"HTTP {resp.status}"}
    except Exception as e:
        return {"ok": False, "error": str(e)}


def save_plan_campaigns(user_id, plan_name, campaigns):
    """Сохраняет привязку кампаний к плану"""
    data = load_data()
    uid = str(user_id)
    if uid in data and "plans" in data[uid] and plan_name in data[uid]["plans"]:
        data[uid]["plans"][plan_name]["linked_campaigns"] = campaigns
        save_data(data)
        return True
    return False


def get_plan_campaigns(user_id, plan_name):
    """Получает привязанные кампании плана"""
    plans = get_plans(user_id)
    if plan_name in plans:
        return plans[plan_name].get("linked_campaigns", [])
    return []

@dp.message(UnitEcon.confirm_rates)
async def unit_confirm_rates(message: types.Message, state: FSMContext):
    data = await state.get_data()

    if data.get("rate_step") == "waiting_usd":
        v = pn(message.text)
        if not v or v <= 0:
            await message.answer("❌ Число. Например: <code>3.2</code>", parse_mode="HTML")
            return
        await state.update_data(usd_rate=v, rate_step=None)
        await ask_purchase(message)
        await state.set_state(UnitEcon.purchase_price_rub)
        return

    if data.get("rate_step") == "waiting_rub":
        v = pn(message.text)
        if not v or v <= 0:
            await message.answer("❌ Число. Например: <code>0.037</code>", parse_mode="HTML")
            return
        await state.update_data(rub_rate=v, rate_step="waiting_usd")
        await message.answer(
            "Теперь курс $ к BYN\n\nНапример: <code>3.2</code>",
            parse_mode="HTML"
        )
        return

    yn = pyn(message.text)
    if yn is None:
        await message.answer("Нажми ✅ Да или ❌ Нет")
        return
    if yn:
        await ask_purchase(message)
        await state.set_state(UnitEcon.purchase_price_rub)
    else:
        await state.update_data(rate_step="waiting_rub")
        await message.answer(
            "Введи курс ₽ к BYN\n\nНапример: <code>0.037</code>",
            parse_mode="HTML", reply_markup=cancel_kb()
        )


