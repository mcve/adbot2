# ЦИКЛ АВТОМАТИЧЕСКИХ ОПОВЕЩЕНИЙ
# ══════════════════════════════════════

async def check_campaign_alerts(uid, plan_name, plan, campaigns):
    """Проверяет кампании одного плана и возвращает список алертов.
    Светофор:
      🔴 Мёртвый старт — CPC/CTR плохие, лидов нет
      🟡 Тест идёт — метрики ок, лидов пока нет
      🛑 СТОП — потрачено много, лидов 0
      🟢 Успех — CPL сильно ниже плана
      🔄 Выгорание — частота высокая
      🧊 Медленный открут
    """
    alerts = []

    max_cpl_20 = plan.get("max_cpl_20", 0) or plan.get("max_cpl", 0) or 0
    max_cpl_0 = plan.get("max_cpl_0", 0) or plan.get("max_cpl", 0) or 0

    for c in campaigns:
        camp_name = c["name"][:30]
        source = c["source"]
        camp_id = c["id"]

        spend = 0
        impressions = 0
        clicks = 0
        leads = 0
        cpl = 0
        ctr = 0
        cpc = 0
        freq = 0

        try:
            if source == "fb":
                result = await fb_get_campaign_insights(camp_id, date_preset="today")
                if result["ok"] and result["data"]:
                    row = result["data"][0]
                    spend = float(row.get("spend", 0))
                    impressions = int(row.get("impressions", 0))
                    clicks = int(row.get("clicks", 0))
                    ctr = float(row.get("ctr", 0))
                    cpc = float(row.get("cpc", 0))
                    freq = float(row.get("frequency", 0))
                    leads = fb_extract_leads(row.get("actions"))
                    cpl = (spend / leads) if leads > 0 else 0

            elif source == "tt":
                result = await tt_get_campaign_insights(camp_id, "today")
                if result and result.get("ok") and result.get("data"):
                    m = result["data"]
                    spend = float(m.get("spend", 0) or 0)
                    impressions = int(float(m.get("impressions", 0) or 0))
                    clicks = int(float(m.get("clicks", 0) or 0))
                    ctr = (clicks / impressions * 100) if impressions > 0 else 0
                    cpc = (spend / clicks) if clicks > 0 else 0
                    leads = int(float(m.get("conversion", 0) or 0))
                    cpl = float(m.get("cost_per_conversion", 0) or 0)
                    if cpl == 0 and leads > 0:
                        cpl = spend / leads

        except Exception as e:
            logging.error(f"Alert check error {camp_name}: {e}")
            continue

        if spend == 0 and impressions == 0:
            continue

        emoji = c.get("source_emoji", "📊")

        # ══════════════════════════════
        # НОРМЫ ПО ПЛАТФОРМЕ
        # ══════════════════════════════
        if source == "tt":
            stop_threshold = 4.0
            bad_cpc = 0.15
            bad_ctr = 1.0
        else:  # fb
            stop_threshold = 6.0
            bad_cpc = 0.50
            bad_ctr = 0.8

        # ══════════════════════════════
        # УРОВЕНЬ КАМПАНИИ
        # ══════════════════════════════

        if leads > 0:
            # 🟢 Успех — CPL сильно ниже плана
            if max_cpl_20 > 0 and cpl <= max_cpl_20 * 0.7 and leads >= 3:
                alerts.append(
                    f"🟢 {emoji} <b>{camp_name}</b>\n"
                    f"   CPL ${cpl:.2f} при плане ${max_cpl_20:.2f} — огонь!\n"
                    f"   Делай дубли, не трогай оригинал!"
                )
            # 🔴 Убыток — CPL выше безубытка
            elif max_cpl_0 > 0 and cpl > max_cpl_0:
                alerts.append(
                    f"🔴 {emoji} <b>{camp_name}</b>\n"
                    f"   CPL ${cpl:.2f} > безуб. ${max_cpl_0:.2f} — УБЫТОК!\n"
                    f"   Выключай или дублируй с новым крео"
                )
            # 🟡 Рент падает — CPL выше плана
            elif max_cpl_20 > 0 and cpl > max_cpl_20:
                alerts.append(
                    f"🟡 {emoji} <b>{camp_name}</b>\n"
                    f"   CPL ${cpl:.2f} > план ${max_cpl_20:.2f} — рент. падает\n"
                    f"   Наблюдай 24ч, не упадёт — дублируй"
                )
        else:
            # 0 лидов — светофор по расходу (elif чтобы не дублировать)

            # 🛑 Точка стопа (приоритет)
            if spend >= stop_threshold:
                alerts.append(
                    f"🛑 {emoji} <b>{camp_name}</b>\n"
                    f"   ${spend:.2f} потрачено — 0 лидов! СТОП!\n"
                    f"   Воронка сломана. Выключай."
                )
            # 🔴 Мёртвый старт
            elif spend >= 1.5 and (cpc > bad_cpc or (impressions > 500 and ctr < bad_ctr)):
                alerts.append(
                    f"🔴 {emoji} <b>{camp_name}</b>\n"
                    f"   ${spend:.2f} | CPC ${cpc:.2f} | CTR {ctr:.1f}% — мёртвый старт\n"
                    f"   Вырубай! Дорогой клик — лид не будет дешёвым"
                )
            # 🟡 Тест идёт
            elif spend >= 2.0:
                alerts.append(
                    f"🟡 {emoji} <b>{camp_name}</b>\n"
                    f"   ${spend:.2f} | CPC ${cpc:.2f} | CTR {ctr:.1f}% — тест идёт\n"
                    f"   Не трогай, алгоритму нужно время"
                )

        # 🔄 Выгорание
        if freq > 3.0:
            alerts.append(
                f"🔄 {emoji} <b>{camp_name}</b>\n"
                f"   Частота {freq:.1f} — выгорание!\n"
                f"   Выключай адсет. Дублируй на широкую или смени крео"
            )

        # 🧊 Медленный открут
        if impressions > 0 and impressions < 200 and spend < 0.5 and clicks < 5:
            alerts.append(
                f"🧊 {emoji} <b>{camp_name}</b>\n"
                f"   Медленный открут: {impressions} показов, ${spend:.2f}\n"
                f"   Подними ставку +10% или перезапусти с новым крео"
            )

        # ══════════════════════════════
        # УРОВЕНЬ СВЯЗОК (adgroups/adsets)
        # ══════════════════════════════
        try:
            if source == "tt" and spend > 0:
                adgroups = await tt_get_adgroup_insights(camp_id, "today")

                # Нормы для TT adgroups
                ag_stop = 4.0
                ag_bad_cpc = 0.15
                ag_bad_ctr = 1.0

                for ag in adgroups:
                    ag_name = ag["name"][:25]
                    ag_spend = ag["spend"]
                    ag_leads = ag["leads"]
                    ag_cpl = ag["cpl"]
                    ag_clicks = ag["clicks"]
                    ag_ctr = ag["ctr"]
                    ag_cpc = ag.get("cpc", 0)
                    ag_imp = ag["impressions"]

                    if ag_spend == 0 and ag_imp == 0:
                        continue

                    if ag_leads > 0:
                        # 🟢 Огонь!
                        if max_cpl_20 > 0 and ag_cpl <= max_cpl_20 * 0.7 and ag_leads >= 2:
                            alerts.append(
                                f"🟢 {emoji} ├ <b>{ag_name}</b>\n"
                                f"      CPL ${ag_cpl:.2f} — огонь! Делай дубли!"
                            )
                        # 🔴 Убыток
                        elif max_cpl_0 > 0 and ag_cpl > max_cpl_0:
                            alerts.append(
                                f"🔴 {emoji} ├ <b>{ag_name}</b>\n"
                                f"      CPL ${ag_cpl:.2f} > безуб. ${max_cpl_0:.2f}\n"
                                f"      Выключай, дублируй!"
                            )
                        # 🟡 Рент падает
                        elif max_cpl_20 > 0 and ag_cpl > max_cpl_20:
                            alerts.append(
                                f"🟡 {emoji} ├ <b>{ag_name}</b>\n"
                                f"      CPL ${ag_cpl:.2f} > план ${max_cpl_20:.2f}\n"
                                f"      Наблюдай 24ч"
                            )
                    else:
                        # 0 лидов — светофор (elif!)

                        # 🛑 Стоп
                        if ag_spend >= ag_stop:
                            alerts.append(
                                f"🛑 {emoji} ├ <b>{ag_name}</b>\n"
                                f"      ${ag_spend:.2f} без лидов — СТОП!"
                            )
                        # 🔴 Мёртвый старт
                        elif ag_spend >= 2.0 and (ag_cpc > ag_bad_cpc or (ag_imp > 500 and ag_ctr < ag_bad_ctr)):
                            alerts.append(
                                f"🔴 {emoji} ├ <b>{ag_name}</b>\n"
                                f"      ${ag_spend:.2f} | CPC ${ag_cpc:.2f} | CTR {ag_ctr:.1f}%\n"
                                f"      Мёртвый старт — вырубай!"
                            )
                        # 🟡 Тест идёт
                        elif ag_spend >= 2.0:
                            alerts.append(
                                f"🟡 {emoji} ├ <b>{ag_name}</b>\n"
                                f"      ${ag_spend:.2f} | CPC ${ag_cpc:.2f} | CTR {ag_ctr:.1f}%\n"
                                f"      Тест идёт, не трогай"
                            )

                        # Клики без лидов (дополнительно к основному)
                        if ag_clicks > 30:
                            if leads > 0:
                                alerts.append(
                                    f"⚠️ {emoji} ├ <b>{ag_name}</b>\n"
                                    f"      {ag_clicks} кликов, 0 лидов. Аудитория не та!"
                                )
                            else:
                                alerts.append(
                                    f"⚠️ {emoji} ├ <b>{ag_name}</b>\n"
                                    f"      {ag_clicks} кликов, 0 лидов. Проверь лендинг!"
                                )

                    # CTR дно (независимо от лидов)
                    if ag_imp > 1000 and ag_ctr < 0.8:
                        alerts.append(
                            f"⚠️ {emoji} ├ <b>{ag_name}</b>\n"
                            f"      CTR {ag_ctr:.2f}% — смени креатив!"
                        )

                    # 🧊 Медленный открут связки
                    if ag_imp > 0 and ag_imp < 200 and ag_spend < 0.5 and ag_clicks < 5:
                        alerts.append(
                            f"🧊 {emoji} ├ <b>{ag_name}</b>\n"
                            f"      Медленный открут: {ag_imp} показов\n"
                            f"      Подними ставку +10%"
                        )

            elif source == "fb" and spend > 0:
                adsets = await fb_get_adset_insights(camp_id, date_preset="today")

                # Нормы для FB adsets
                as_stop = 6.0
                as_bad_cpc = 0.50
                as_bad_ctr = 0.8

                if adsets and adsets.get("ok"):
                    for row in adsets.get("data", []):
                        as_name = row.get("adset_name", "?")[:25]
                        as_spend = float(row.get("spend", 0))
                        as_clicks = int(row.get("clicks", 0))
                        as_imp = int(row.get("impressions", 0))
                        as_ctr = float(row.get("ctr", 0))
                        as_cpc = float(row.get("cpc", 0))
                        as_freq = float(row.get("frequency", 0))
                        as_leads = fb_extract_leads(row.get("actions"))
                        as_cpl = (as_spend / as_leads) if as_leads > 0 else 0

                        if as_spend == 0 and as_imp == 0:
                            continue

                        if as_leads > 0:
                            # 🟢 Огонь!
                            if max_cpl_20 > 0 and as_cpl <= max_cpl_20 * 0.7 and as_leads >= 2:
                                alerts.append(
                                    f"🟢 {emoji} ├ <b>{as_name}</b>\n"
                                    f"      CPL ${as_cpl:.2f} — огонь! Делай дубли!"
                                )
                            # 🔴 Убыток
                            elif max_cpl_0 > 0 and as_cpl > max_cpl_0:
                                alerts.append(
                                    f"🔴 {emoji} ├ <b>{as_name}</b>\n"
                                    f"      CPL ${as_cpl:.2f} > безуб. ${max_cpl_0:.2f}\n"
                                    f"      Выключай, дублируй!"
                                )
                            # 🟡 Рент падает
                            elif max_cpl_20 > 0 and as_cpl > max_cpl_20:
                                alerts.append(
                                    f"🟡 {emoji} ├ <b>{as_name}</b>\n"
                                    f"      CPL ${as_cpl:.2f} > план ${max_cpl_20:.2f}\n"
                                    f"      Наблюдай 24ч"
                                )
                        else:
                            # 0 лидов — светофор (elif!)

                            # 🛑 Стоп
                            if as_spend >= as_stop:
                                alerts.append(
                                    f"🛑 {emoji} ├ <b>{as_name}</b>\n"
                                    f"      ${as_spend:.2f} без лидов — СТОП!"
                                )
                            # 🔴 Мёртвый старт
                            elif as_spend >= 1.5 and (as_cpc > as_bad_cpc or (as_imp > 500 and as_ctr < as_bad_ctr)):
                                alerts.append(
                                    f"🔴 {emoji} ├ <b>{as_name}</b>\n"
                                    f"      ${as_spend:.2f} | CPC ${as_cpc:.2f} | CTR {as_ctr:.1f}%\n"
                                    f"      Мёртвый старт — вырубай!"
                                )
                            # 🟡 Тест идёт
                            elif as_spend >= 2.0:
                                alerts.append(
                                    f"🟡 {emoji} ├ <b>{as_name}</b>\n"
                                    f"      ${as_spend:.2f} | CPC ${as_cpc:.2f} | CTR {as_ctr:.1f}%\n"
                                    f"      Тест идёт, не трогай"
                                )

                            # Клики без лидов
                            if as_clicks > 30:
                                if leads > 0:
                                    alerts.append(
                                        f"⚠️ {emoji} ├ <b>{as_name}</b>\n"
                                        f"      {as_clicks} кликов, 0 лидов. Смени аудиторию!"
                                    )
                                else:
                                    alerts.append(
                                        f"⚠️ {emoji} ├ <b>{as_name}</b>\n"
                                        f"      {as_clicks} кликов, 0 лидов. Проверь лендинг!"
                                    )

                        # CTR дно
                        if as_imp > 1000 and as_ctr < 0.8:
                            alerts.append(
                                f"⚠️ {emoji} ├ <b>{as_name}</b>\n"
                                f"      CTR {as_ctr:.2f}% — смени креатив!"
                            )

                        # 🔄 Выгорание FB adset
                        if as_freq > 3.0:
                            alerts.append(
                                f"🔄 {emoji} ├ <b>{as_name}</b>\n"
                                f"      Частота {as_freq:.1f} — выгорание!\n"
                                f"      Дублируй на широкую"
                            )

                        # 🧊 Медленный открут
                        if as_imp > 0 and as_imp < 200 and as_spend < 0.5 and as_clicks < 5:
                            alerts.append(
                                f"🧊 {emoji} ├ <b>{as_name}</b>\n"
                                f"      Медленный открут: {as_imp} показов\n"
                                f"      Подними ставку +10%"
                            )

        except Exception as e:
            logging.error(f"Adgroup alert error {camp_name}: {e}")

    return alerts


# ═══════════════════════════════════════════════════════
# КЕШ СТАТУСОВ СВЯЗОК (для отслеживания правил TT)
# ═══════════════════════════════════════════════════════
adgroup_status_cache = {}


# ═══════════════════════════════════════════════════════
# ХЕЛПЕР: собрать данные по всем кампаниям юзера
# ═══════════════════════════════════════════════════════
async def collect_user_ad_data(uid):
    """Собирает все данные по рекламе юзера. Возвращает dict."""
    plans = get_plans(int(uid))
    if not plans:
        return None

    total_spend = 0.0
    total_leads = 0
    campaigns_data = []
    all_verdicts = []
    disabled_ags = []

    for plan_name, plan in plans.items():
        campaigns = plan.get("linked_campaigns", [])
        if not campaigns:
            continue

        max_cpl_20 = plan.get("max_cpl_20", 0) or plan.get("max_cpl", 0) or 0
        max_cpl_0 = plan.get("max_cpl_0", 0) or plan.get("max_cpl", 0) or 0

        for c in campaigns:
            try:
                source = c.get("source", "tt")
                camp_id = c["id"]
                camp_name = c["name"][:35]

                spend = 0
                leads = 0
                clicks = 0
                imp = 0
                adgroups = []

                if source == "tt":
                    adgroups = await tt_get_adgroup_insights(camp_id, "today")
                    if adgroups:
                        spend = sum(ag["spend"] for ag in adgroups)
                        leads = sum(ag["leads"] for ag in adgroups)
                        clicks = sum(ag["clicks"] for ag in adgroups)
                        imp = sum(ag["impressions"] for ag in adgroups)
                    else:
                        m = await tt_get_campaign_insights(camp_id, "today")
                        if m:
                            spend = float(m.get("spend", 0) or 0)
                            imp = int(float(m.get("impressions", 0) or 0))
                            clicks = int(float(m.get("clicks", 0) or 0))
                            leads = int(float(m.get("conversion", 0) or 0))

                elif source == "fb":
                    result = await fb_get_campaign_insights(camp_id, date_preset="today")
                    if result["ok"] and result["data"]:
                        row = result["data"][0]
                        spend = float(row.get("spend", 0))
                        imp = int(row.get("impressions", 0))
                        clicks = int(row.get("clicks", 0))
                        leads = fb_extract_leads(row.get("actions"))

                total_spend += spend
                total_leads += leads

                ctr = (clicks / imp * 100) if imp > 0 else 0
                cpc = (spend / clicks) if clicks > 0 else 0
                cpl = (spend / leads) if leads > 0 else 0

                camp_data = {
                    "name": camp_name,
                    "source": source,
                    "spend": spend,
                    "leads": leads,
                    "cpl": cpl,
                    "clicks": clicks,
                    "imp": imp,
                    "ctr": ctr,
                    "cpc": cpc,
                    "plan_name": plan_name,
                    "max_cpl_20": max_cpl_20,
                    "max_cpl_0": max_cpl_0,
                    "plan_info": plan,
                    "adgroups": adgroups,
                }
                campaigns_data.append(camp_data)

                # Вердикты по связкам (TT)
                if source == "tt" and adgroups:
                    for ag in adgroups:
                        ag_name = ag["name"][:25]
                        ag_spend = ag["spend"]
                        ag_leads = ag["leads"]
                        ag_cpl = ag["cpl"]
                        ag_clicks = ag["clicks"]
                        ag_ctr = ag["ctr"]
                        ag_cpc = ag.get("cpc", 0)
                        ag_imp = ag["impressions"]
                        ag_budget = ag.get("budget", 0)
                        is_active = ag.get("is_active", True)

                        if not is_active:
                            reason = ""
                            if ag_spend > 0 and ag_leads == 0:
                                reason = f"${ag_spend:.2f} без лидов"
                            elif ag_leads > 0 and max_cpl_0 > 0 and ag_cpl > max_cpl_0:
                                reason = f"CPL ${ag_cpl:.2f} > безуб ${max_cpl_0:.2f}"
                            elif ag_cpc > 0.25:
                                reason = f"CPC ${ag_cpc:.2f}"
                            else:
                                reason = "выключена"
                            disabled_ags.append({
                                "camp": camp_name,
                                "name": ag_name,
                                "reason": reason,
                                "spend": ag_spend,
                                "id": ag["id"]
                            })
                            continue

                        if ag_spend == 0 and ag_imp == 0:
                            continue

                        # Автовердикт
                        verdict, emoji_v, action = "", "", ""
                        budget_str = f"${ag_budget:.2f}" if ag_budget > 0 else "?"
                        stop_threshold = max_cpl_0 if max_cpl_0 > 0 else 5.0

                        if ag_leads > 0 and max_cpl_20 > 0:
                            if ag_cpl <= max_cpl_20 * 0.7 and ag_leads >= 2:
                                emoji_v, verdict = "🟢", "ОГОНЬ"
                                if ag_budget > 0:
                                    action = f"Масштабируй! Бюджет {budget_str} → ${ag_budget * 1.3:.2f}"
                                else:
                                    action = "Масштабируй! +30% бюджет"
                            elif ag_cpl <= max_cpl_20:
                                emoji_v, verdict = "🟢", "ПЕРСПЕКТИВНАЯ"
                                if ag_budget > 0:
                                    action = f"Поднять бюджет {budget_str} → ${ag_budget * 1.2:.2f}"
                                else:
                                    action = "Поднять бюджет +20%"
                            elif ag_cpl <= max_cpl_0:
                                emoji_v, verdict = "⚠️", "РЕНТ ПАДАЕТ"
                                action = "Наблюдать 24ч"
                            else:
                                emoji_v, verdict = "🔴", "УБЫТОК"
                                action = f"Выключить! CPL ${ag_cpl:.2f} > безуб ${max_cpl_0:.2f}"
                        elif ag_leads > 0:
                            if ag_cpl <= 2.5:
                                emoji_v, verdict = "🟢", "ПЕРСПЕКТИВНАЯ"
                                action = "+20% бюджет"
                            else:
                                emoji_v, verdict = "⚠️", "CPL ВЫСОКИЙ"
                                action = "Привяжи план"
                        else:
                            if ag_spend >= stop_threshold:
                                emoji_v, verdict = "🛑", "СТОП"
                                action = f"Выключить! ${ag_spend:.2f} без лидов"
                            elif ag_spend >= 2.0 and (ag_cpc > 0.25 or (ag_imp > 500 and ag_ctr < 1.0)):
                                emoji_v, verdict = "🔴", "МЁРТВАЯ"
                                action = "Выключить!"
                            elif ag_spend >= 2.0:
                                emoji_v, verdict = "🟡", "НАБИРАЕТ"
                                action = f"Ждать ещё ${stop_threshold - ag_spend:.2f}"
                            else:
                                emoji_v, verdict = "🟡", "ТЕСТ"
                                action = f"Ждать ещё ~${2.0 - ag_spend:.2f}"

                        all_verdicts.append({
                            "camp": camp_name,
                            "name": ag_name,
                            "spend": ag_spend,
                            "budget": ag_budget,
                            "imp": ag_imp,
                            "clicks": ag_clicks,
                            "ctr": ag_ctr,
                            "cpc": ag_cpc,
                            "leads": ag_leads,
                            "cpl": ag_cpl,
                            "verdict": verdict,
                            "emoji": emoji_v,
                            "action": action,
                            "plan_cpl_20": max_cpl_20,
                            "plan_cpl_0": max_cpl_0,
                            "id": ag["id"],
                        })

            except Exception as e:
                logging.error(f"Collect data error {c.get('name', '?')}: {e}")

    return {
        "total_spend": total_spend,
        "total_leads": total_leads,
        "campaigns": campaigns_data,
        "verdicts": all_verdicts,
        "disabled": disabled_ags,
        "plans": plans,
    }


# ═══════════════════════════════════════════════════════
# ТИП 1: ПОЛНЫЙ ОТЧЁТ (дашборд + AI)
# ═══════════════════════════════════════════════════════
async def send_full_report(uid):
    """Полный дашборд + AI рекомендации"""
    data = await collect_user_ad_data(uid)
    if not data or data["total_spend"] == 0:
        return

    now = datetime.now()
    ts = data["total_spend"]
    tl = data["total_leads"]
    tc = (ts / tl) if tl > 0 else 0

    # ═══ ШАПКА ═══
    header = f"📊 <b>ПОЛНЫЙ ОТЧЁТ</b> | {now.strftime('%H:%M')}\n"
    header += f"━━━━━━━━━━━━━━━━━━━━\n"
    header += f"💵 Расход: <b>${ts:.2f}</b>\n"
    header += f"📝 Лидов: <b>{tl}</b>\n"
    if tl > 0:
        header += f"💰 CPL: <b>${tc:.2f}</b>\n"
    header += f"━━━━━━━━━━━━━━━━━━━━\n"

    for cd in data["campaigns"]:
        if cd["spend"] == 0 and cd["imp"] == 0:
            continue
        icon = "🎵" if cd["source"] == "tt" else "📘"
        header += f"\n{icon} <b>{cd['name']}</b>\n"
        header += f"   💵 ${cd['spend']:.2f} | 📝 {cd['leads']} лид"
        if cd["leads"] > 0:
            header += f" | CPL ${cd['cpl']:.2f}"
            if cd["max_cpl_20"] > 0:
                if cd["cpl"] <= cd["max_cpl_20"]:
                    d = ((cd["max_cpl_20"] - cd["cpl"]) / cd["max_cpl_20"]) * 100
                    header += f" ✅ -{d:.0f}%"
                elif cd["cpl"] <= cd["max_cpl_0"]:
                    header += f" ⚠️ выше плана"
                else:
                    header += f" 🔴 УБЫТОК"
        else:
            header += " | ⏳"
        header += "\n"
    header += f"━━━━━━━━━━━━━━━━━━━━"

    try:
        await bot.send_message(int(uid), header, parse_mode="HTML")
    except Exception as e:
        logging.error(f"Report header send error: {e}")
        return

    # ═══ ДАШБОРД СВЯЗОК ═══
    if data["verdicts"] or data["disabled"]:
        dash = "┌─ СВЯЗКИ ────────────────────┐\n"
        for v in data["verdicts"]:
            budget_str = f"${v['budget']:.0f}" if v["budget"] > 0 else "?"
            dash += f"│ {v['emoji']} <b>{v['name']}</b> — {v['verdict']}\n"
            dash += f"│   ${v['spend']:.2f} (бюдж {budget_str})"
            if v["leads"] > 0:
                dash += f" | {v['leads']}лид CPL ${v['cpl']:.2f}"
            dash += f"\n│   CTR {v['ctr']:.1f}% CPC ${v['cpc']:.2f}\n"
            dash += f"│   → {v['action']}\n"

        for d in data["disabled"]:
            dash += f"│ ⛔ {d['name']} — {d['reason']}\n"

        dash += f"└──────────────────────────────┘"

        if len(dash) > 4000:
            parts = smart_split(dash, 4000)
            for p in parts:
                try:
                    await bot.send_message(int(uid), p, parse_mode="HTML")
                except Exception:
                    await bot.send_message(int(uid), p)
        else:
            try:
                await bot.send_message(int(uid), dash, parse_mode="HTML")
            except Exception:
                await bot.send_message(int(uid), dash)

    # ═══ AI РЕКОМЕНДАЦИИ ═══
    ai_data = f"Расход: ${ts:.2f}, лидов: {tl}\n\n"
    for v in data["verdicts"]:
        ai_data += (
            f"Связка: {v['name']} ({v['camp']})\n"
            f"  ${v['spend']:.2f} | бюджет ${v['budget']:.2f} | "
            f"{v['imp']} показов | {v['clicks']} кликов | "
            f"CTR {v['ctr']:.2f}% | CPC ${v['cpc']:.2f} | "
            f"лиды {v['leads']}"
        )
        if v["leads"] > 0:
            ai_data += f" | CPL ${v['cpl']:.2f}"
        ai_data += (
            f"\n  ВЕРДИКТ: {v['verdict']} | ДЕЙСТВИЕ: {v['action']}\n"
            f"  План CPL: ${v['plan_cpl_20']:.2f} | Безуб: ${v['plan_cpl_0']:.2f}\n\n"
        )

    if data["disabled"]:
        ai_data += "ВЫКЛЮЧЕНЫ:\n"
        for d in data["disabled"]:
            ai_data += f"  ⛔ {d['name']}: {d['reason']}\n"

    prompt = (
        "Пользователю УЖЕ показан дашборд с цифрами и вердиктами.\n"
        "НЕ повторяй цифры! НЕ спорь с вердиктами!\n\n"
        "ПРАВИЛА:\n"
        "1. БЮДЖЕТ ≠ РАСХОД\n"
        "2. Если система сказала УБЫТОК/СТОП — подтверди\n"
        "3. Добавь инсайты: паттерны, тренды, стратегию\n"
        "4. Только русский язык\n\n"
        "ФОРМАТ:\n"
        "━━━ 🧠 МНЕНИЕ ━━━\n[2-3 предл: общая картина]\n\n"
        "━━━ 💡 ИНСАЙТЫ ━━━\n[паттерны CTR/CPC, аномалии, крео]\n\n"
        "━━━ 🎯 СТРАТЕГИЯ ━━━\n[масштабирование, крео, апсейлы]\n\n"
        "Коротко, как друг-таргетолог."
    )

    try:
        ai_resp = await ai_ask(prompt, ai_data)
        import html as html_module
        safe = html_module.escape(ai_resp)
        if len(safe) > 4000:
            for p in smart_split(safe, 4000):
                try:
                    await bot.send_message(int(uid), p, parse_mode="HTML")
                except Exception:
                    await bot.send_message(int(uid), p)
        else:
            try:
                await bot.send_message(int(uid), safe, parse_mode="HTML")
            except Exception:
                await bot.send_message(int(uid), ai_resp)
    except Exception as e:
        logging.error(f"Report AI error: {e}")


# ═══════════════════════════════════════════════════════
# ТИП 2: ТРИГГЕР ПРАВИЛ — связка выключилась
# ═══════════════════════════════════════════════════════
async def check_rule_triggers(uid):
    """Проверяет не выключились ли связки по правилам TT"""
    global adgroup_status_cache

    data = await collect_user_ad_data(uid)
    if not data:
        return

    # Если кеш пуст — первая проверка, заполняем без алертов
    first_run = len(adgroup_status_cache) == 0

    alerts = []

    for d in data["disabled"]:
        ag_id = d.get("id", "")
        prev = adgroup_status_cache.get(ag_id)

        if prev is True and not first_run:
            alerts.append(
                f"🛑 <b>Правило TT сработало!</b>\n"
                f"📦 {d['camp']}\n"
                f"🔗 {d['name']}\n"
                f"💵 {d['reason']}"
            )

        adgroup_status_cache[ag_id] = False

    for v in data["verdicts"]:
        adgroup_status_cache[v.get("id", "")] = True

    if alerts:
        header = "🔔 <b>АВТОАЛЕРТ МЕТРИК</b>\n" + "─" * 25
        try:
            await bot.send_message(int(uid), header, parse_mode="HTML")
        except Exception:
            pass

    if alerts:
        header = "🔔 <b>АВТОАЛЕРТ МЕТРИК</b>\n" + "─" * 25
        try:
            await bot.send_message(int(uid), header, parse_mode="HTML")
        except Exception:
            pass

    if alerts:
        header = "⚠️ <b>Алерты метрик</b>\n" + "━" * 24
        try:
            await bot.send_message(int(uid), header, parse_mode="HTML")
        except Exception:
            pass
        for alert in alerts:
            try:
                await bot.send_message(int(uid), alert, parse_mode="HTML")
            except Exception as e:
                logging.error(f"Metric alert send error: {e}")

    return len(alerts)


# ═══════════════════════════════════════════════════════
# ТИП 3: АЛЕРТЫ МЕТРИК — плохие показатели
# ═══════════════════════════════════════════════════════
_sent_metric_alerts = {}


async def check_metric_alerts(uid):
    """Проверяет активные связки на плохие метрики"""
    global _sent_metric_alerts

    data = await collect_user_ad_data(uid)
    if not data:
        return

    now = datetime.now()
    alerts = []

    for v in data["verdicts"]:
        # Дедупликация: не слать один алерт чаще чем раз в 2 часа
        alert_key = f"{uid}_{v.get('id', '')}_{v['verdict']}"
        last_sent = _sent_metric_alerts.get(alert_key)
        if last_sent and (now - last_sent).total_seconds() < 7200:
            continue

        sent = False

        if v["verdict"] == "СТОП":
            alerts.append(
                f"🛑 <b>СТОП! Выключай!</b>\n"
                f"📦 {v['camp']} → {v['name']}\n"
                f"💵 ${v['spend']:.2f} без лидов (порог ${v['plan_cpl_0']:.2f})"
            )
            sent = True

        elif v["verdict"] == "УБЫТОК":
            alerts.append(
                f"🔴 <b>УБЫТОК!</b>\n"
                f"📦 {v['camp']} → {v['name']}\n"
                f"💰 CPL ${v['cpl']:.2f} > безуб ${v['plan_cpl_0']:.2f}\n"
                f"→ Выключай, дублируй"
            )
            sent = True

        elif v["verdict"] == "МЁРТВАЯ":
            alerts.append(
                f"🔴 <b>Мёртвая связка!</b>\n"
                f"📦 {v['camp']} → {v['name']}\n"
                f"💵 ${v['spend']:.2f} | CPC ${v['cpc']:.2f} | CTR {v['ctr']:.1f}%\n"
                f"→ Выключай"
            )
            sent = True

        elif v["verdict"] == "ОГОНЬ":
            alerts.append(
                f"🟢 <b>ОГОНЬ! Масштабируй!</b>\n"
                f"📦 {v['camp']} → {v['name']}\n"
                f"💰 CPL ${v['cpl']:.2f} (план ${v['plan_cpl_20']:.2f})\n"
                f"→ {v['action']}"
            )
            sent = True

        # CTR дно
        if v["imp"] > 1000 and v["ctr"] < 0.8:
            ctr_key = f"{uid}_{v.get('id', '')}_CTR_LOW"
            ctr_last = _sent_metric_alerts.get(ctr_key)
            if not ctr_last or (now - ctr_last).total_seconds() >= 7200:
                alerts.append(
                    f"⚠️ <b>CTR дно!</b>\n"
                    f"📦 {v['camp']} → {v['name']}\n"
                    f"👁 {v['imp']} показов, CTR {v['ctr']:.2f}%\n"
                    f"→ Смени креатив"
                )
                _sent_metric_alerts[ctr_key] = now

        if sent:
            _sent_metric_alerts[alert_key] = now

    # 3-дневные проблемы
    plans = data.get("plans", {})
    for plan_name, plan in plans.items():
        for c in plan.get("linked_campaigns", []):
            try:
                camp_name = c["name"][:30]
                max_cpl_0 = plan.get("max_cpl_0", 0) or plan.get("max_cpl", 0) or 0

                # Дедупликация 3-дневных
                day3_key = f"{uid}_{c['id']}_3day"
                day3_last = _sent_metric_alerts.get(day3_key)
                if day3_last and (now - day3_last).total_seconds() < 14400:
                    continue

                if c.get("source") == "tt":
                    today = datetime.now().date()
                    start_3d = (today - timedelta(days=2)).isoformat()
                    end_3d = today.isoformat()

                    url = "https://business-api.tiktok.com/open_api/v1.3/report/integrated/get/"
                    headers_tt = {"Access-Token": tt_token_data["access_token"]}
                    base_p = {
                        "advertiser_id": TT_ADVERTISER_ID,
                        "service_type": "AUCTION",
                        "report_type": "BASIC",
                        "data_level": "AUCTION_CAMPAIGN",
                        "dimensions": json.dumps(["campaign_id"]),
                        "start_date": start_3d,
                        "end_date": end_3d,
                        "filtering": json.dumps([{
                            "field_name": "campaign_ids",
                            "filter_type": "IN",
                            "filter_value": json.dumps([str(c["id"])])
                        }]),
                        "page": 1,
                        "page_size": 10,
                    }

                    spend_3d = 0
                    leads_3d = 0

                    async with aiohttp.ClientSession() as session:
                        p1 = {**base_p, "metrics": json.dumps(["spend", "clicks"])}
                        async with session.get(url, headers=headers_tt, params=p1) as resp:
                            r1 = await resp.json()
                        if r1.get("code") == 0:
                            dl = r1.get("data", {}).get("list", [])
                            if dl:
                                spend_3d = float(dl[0].get("metrics", {}).get("spend", 0) or 0)

                        p2 = {**base_p, "metrics": json.dumps(["real_time_conversion"])}
                        async with session.get(url, headers=headers_tt, params=p2) as resp:
                            r2 = await resp.json()
                        if r2.get("code") == 0:
                            dl2 = r2.get("data", {}).get("list", [])
                            if dl2:
                                leads_3d = int(float(
                                    dl2[0].get("metrics", {}).get("real_time_conversion", 0) or 0
                                ))

                    if spend_3d >= 15 and leads_3d == 0:
                        alerts.append(
                            f"🚨 <b>КРИТИЧНО! 3 дня без лидов</b>\n"
                            f"📦 {camp_name}\n"
                            f"💵 ${spend_3d:.0f} потрачено\n"
                            f"→ Меняй крео/лендинг/товар"
                        )
                        _sent_metric_alerts[day3_key] = now
                    elif spend_3d > 5 and leads_3d > 0 and max_cpl_0 > 0:
                        cpl_3d = spend_3d / leads_3d
                        if cpl_3d > max_cpl_0:
                            alerts.append(
                                f"⚠️ <b>Убыток за 3 дня</b>\n"
                                f"📦 {camp_name}\n"
                                f"💰 CPL ${cpl_3d:.2f} > безуб ${max_cpl_0:.2f}"
                            )
                            _sent_metric_alerts[day3_key] = now

                elif c.get("source") == "fb":
                    result_3d = await fb_get_campaign_insights(c["id"], date_preset="last_3d")
                    if result_3d["ok"] and result_3d["data"]:
                        row3 = result_3d["data"][0]
                        spend_3d = float(row3.get("spend", 0))
                        leads_3d = fb_extract_leads(row3.get("actions"))
                        if spend_3d >= 15 and leads_3d == 0:
                            alerts.append(
                                f"🚨 <b>3 дня без лидов (FB)</b>\n"
                                f"📦 {camp_name} | ${spend_3d:.0f}"
                            )
                            _sent_metric_alerts[day3_key] = now
                        elif spend_3d > 5 and leads_3d > 0 and max_cpl_0 > 0:
                            cpl_3d = spend_3d / leads_3d
                            if cpl_3d > max_cpl_0:
                                alerts.append(
                                    f"⚠️ <b>Убыток за 3 дня (FB)</b>\n"
                                    f"📦 {camp_name}\n"
                                    f"💰 CPL ${cpl_3d:.2f} > безуб ${max_cpl_0:.2f}"
                                )
                                _sent_metric_alerts[day3_key] = now

            except Exception as e:
                logging.error(f"3day check error: {e}")

    if alerts:
        header = "⚠️ <b>Алерты метрик</b>\n" + "━" * 24
        try:
            await bot.send_message(int(uid), header, parse_mode="HTML")
        except Exception:
            pass
        for alert in alerts:
            try:
                await bot.send_message(int(uid), alert, parse_mode="HTML")
            except Exception as e:
                logging.error(f"Metric alert send error: {e}")

    return len(alerts)

@dp.message(ReportSchedule.waiting_times)
async def process_report_settings(message: types.Message, state: FSMContext):
    uid = message.from_user.id
    text = message.text.strip()

    reminders = get_reminders()
    rdata = reminders.get(str(uid), {})

    # ═══ НАЗАД / ГЛАВНОЕ МЕНЮ ═══
    if text == "🔙 Назад" or text == "🔙 Главное меню":
        await state.clear()
        await notifications_menu(message, state)
        return

    # ═══ ВЫКЛЮЧИТЬ ВСЁ ═══
    if text == "🚫 Выключить всё":
        rdata["reports_enabled"] = False
        rdata["triggers_enabled"] = False
        rdata["alerts_enabled"] = False
        rdata["enabled"] = False
        save_reminder(uid, rdata)
        await state.clear()
        await message.answer(
            "🚫 Все уведомления выключены.\n"
            "Включить: ⏰ Уведомления",
            reply_markup=main_kb()
        )
        return

    # ═══ ВКЛЮЧИТЬ ВСЁ ═══
    if text == "✅ Включить всё":
        rdata["reports_enabled"] = True
        rdata["triggers_enabled"] = True
        rdata["alerts_enabled"] = True
        rdata["enabled"] = True
        if not rdata.get("report_times"):
            rdata["report_times"] = ["09:00", "21:00"]
        save_reminder(uid, rdata)
        times_str = ", ".join(rdata["report_times"])
        await state.clear()
        await message.answer(
            f"✅ Все уведомления включены!\n\n"
            f"📊 Отчёты: {times_str}\n"
            f"🛑 Триггеры: каждые 15 мин\n"
            f"⚠️ Алерты: каждые 30 мин",
            reply_markup=main_kb()
        )
        return

    # ═══ ТОГГЛ ТРИГГЕРОВ ═══
    if text.startswith("🛑 Триггеры правил"):
        current = rdata.get("triggers_enabled", True)
        rdata["triggers_enabled"] = not current
        rdata["enabled"] = True
        save_reminder(uid, rdata)
        new_state = "✅ ВКЛ" if not current else "❌ ВЫКЛ"
        await message.answer(
            f"🛑 Триггеры правил TT: <b>{new_state}</b>",
            parse_mode="HTML"
        )
        await notifications_menu(message, state)
        return

    # ═══ ТОГГЛ АЛЕРТОВ ═══
    if text.startswith("⚠️ Алерты метрик"):
        current = rdata.get("alerts_enabled", True)
        rdata["alerts_enabled"] = not current
        rdata["enabled"] = True
        save_reminder(uid, rdata)
        new_state = "✅ ВКЛ" if not current else "❌ ВЫКЛ"
        await message.answer(
            f"⚠️ Алерты метрик: <b>{new_state}</b>",
            parse_mode="HTML"
        )
        await notifications_menu(message, state)
        return

    # ═══ ТОГГЛ ОТЧЁТОВ ═══
    if text.startswith("📊 Полные отчёты"):
        current = rdata.get("reports_enabled", True)
        rdata["reports_enabled"] = not current
        rdata["enabled"] = True
        save_reminder(uid, rdata)
        new_state = "✅ ВКЛ" if not current else "❌ ВЫКЛ"
        await message.answer(
            f"📊 Полные отчёты: <b>{new_state}</b>",
            parse_mode="HTML"
        )
        await notifications_menu(message, state)
        return

    # ═══ НАСТРОИТЬ ВРЕМЯ ═══
    if text == "📊 Настроить время отчётов":
        current_times = rdata.get("report_times", [])
        current_str = ", ".join(current_times) if current_times else "не настроено"
        await message.answer(
            f"⏰ <b>Время отчётов</b>\n\n"
            f"Сейчас: <b>{current_str}</b>\n\n"
            f"Отправь время через запятую:\n"
            f"<code>09:00, 15:00, 21:00</code>\n\n"
            f"Или выбери:",
            parse_mode="HTML",
            reply_markup=ReplyKeyboardMarkup(keyboard=[
                [KeyboardButton(text="🌅 09:00, 21:00")],
                [KeyboardButton(text="📊 09:00, 13:00, 18:00, 21:00")],
                [KeyboardButton(text="🔥 Каждые 3 часа (09-21)")],
                [KeyboardButton(text="🔙 Назад")]
            ], resize_keyboard=True)
        )
        return

    # ═══ ПАРСИМ ВРЕМЯ ═══
    times = []

    if text == "🌅 09:00, 21:00":
        times = ["09:00", "21:00"]
    elif text == "📊 09:00, 13:00, 18:00, 21:00":
        times = ["09:00", "13:00", "18:00", "21:00"]
    elif text == "🔥 Каждые 3 часа (09-21)":
        times = ["09:00", "12:00", "15:00", "18:00", "21:00"]
    else:
        raw = text.replace(";", ",").split(",")
        for t in raw:
            t = t.strip().replace(".", ":")
            if len(t) == 4 and t.isdigit():
                t = t[:2] + ":" + t[2:]
            if ":" not in t:
                continue
            parts = t.split(":")
            try:
                h = int(parts[0])
                m = int(parts[1])
                if 0 <= h <= 23 and 0 <= m <= 59:
                    times.append(f"{h:02d}:{m:02d}")
            except ValueError:
                continue

        if not times:
            await message.answer(
                "❌ Не удалось распознать время.\n"
                "Формат: <code>09:00, 15:00, 21:00</code>",
                parse_mode="HTML"
            )
            return

    times = sorted(set(times))

    rdata["report_times"] = times
    rdata["reports_enabled"] = True
    rdata["enabled"] = True
    save_reminder(uid, rdata)

    times_str = ", ".join(times)
    triggers_on = rdata.get("triggers_enabled", True)
    alerts_on = rdata.get("alerts_enabled", True)

    await state.clear()
    await message.answer(
        f"✅ <b>Сохранено!</b>\n\n"
        f"📊 Отчёты: <b>{times_str}</b>\n"
        f"🛑 Триггеры правил: <b>{'вкл' if triggers_on else 'выкл'}</b>\n"
        f"⚠️ Алерты метрик: <b>{'вкл' if alerts_on else 'выкл'}</b>\n\n"
        f"🕐 Время — Минск (UTC+3)",
        parse_mode="HTML",
        reply_markup=main_kb()
    )

# ═══════════════════════════════════════════════════════
# ГЛАВНЫЙ ДИСПЕТЧЕР
# ═══════════════════════════════════════════════════════
async def alert_loop():
    """Диспетчер: отчёты по расписанию, триггеры, алерты"""
    last_trigger_check = {}
    last_metric_check = {}
    sent_reports_today = {}
    # Задержка после старта — не слать алерты сразу
    startup_time = datetime.now()

    while True:
        await asyncio.sleep(60)
        try:
            reminders = get_reminders()
            now = datetime.now()
            today_str = now.strftime("%Y-%m-%d")

            for uid, rdata in reminders.items():
                if not rdata.get("enabled", True):
                    continue

                try:
                    # ═══ ТРИГГЕР ПРАВИЛ — каждые 15 мин ═══
                    if rdata.get("triggers_enabled", True):
                        lt = last_trigger_check.get(uid)
                        if not lt or (now - lt).total_seconds() >= 900:
                            await check_rule_triggers(uid)
                            last_trigger_check[uid] = now

                    # ═══ АЛЕРТЫ МЕТРИК — каждые 30 мин ═══
                    if rdata.get("alerts_enabled", True):
                        if (now - startup_time).total_seconds() >= 300:
                            lm = last_metric_check.get(uid)
                            if not lm or (now - lm).total_seconds() >= 1800:
                                await check_metric_alerts(uid)
                                last_metric_check[uid] = now

                    # ═══ ПОЛНЫЙ ОТЧЁТ — по расписанию ═══
                    if rdata.get("reports_enabled", True):
                        report_times = rdata.get("report_times", [])

                        if report_times:
                            cache_key = f"{uid}_{today_str}"
                            if cache_key not in sent_reports_today:
                                sent_reports_today[cache_key] = set()
                                old_keys = [k for k in sent_reports_today
                                            if not k.endswith(today_str)]
                                for ok in old_keys:
                                    del sent_reports_today[ok]

                            for rt in report_times:
                                if rt in sent_reports_today[cache_key]:
                                    continue

                                try:
                                    rh, rm = map(int, rt.split(":"))
                                    scheduled = now.replace(
                                        hour=rh, minute=rm,
                                        second=0, microsecond=0
                                    )
                                    diff = (now - scheduled).total_seconds()
                                    if 0 <= diff <= 120:
                                        await send_full_report(uid)
                                        sent_reports_today[cache_key].add(rt)
                                except Exception as e:
                                    logging.error(f"Report time error {rt}: {e}")

                except Exception as e:
                    logging.error(f"Alert dispatch error {uid}: {e}")

        except Exception as e:
            logging.error(f"Alert main loop error: {e}")
