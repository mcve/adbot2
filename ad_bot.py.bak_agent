@dp.message(UnlinkCampaign.choose_plan)
async def unlink_choose_plan(message: types.Message, state: FSMContext):
    text = message.text.strip()
    if not text.startswith("🔓 "):
        await message.answer("❌ Выбери план из списка:")
        return

    name = text[2:].strip()
    if "(" in name:
        name = name[:name.rfind("(")].strip()

    plans = get_plans(message.from_user.id)
    if name not in plans:
        await message.answer("❌ План не найден:")
        return

    campaigns = plans[name].get("linked_campaigns", [])
    if not campaigns:
        await message.answer("❌ Нет привязанных кампаний.", reply_markup=main_kb())
        await state.clear()
        return

    await state.update_data(unlink_plan_name=name)

    buttons = []
    for i, c in enumerate(campaigns):
        short = c["name"][:35] + "..." if len(c["name"]) > 35 else c["name"]
        buttons.append([KeyboardButton(text=f"🗑 {i+1}. {c['source_emoji']} {short}")])
    buttons.append([KeyboardButton(text="🗑🗑 Отвязать ВСЕ")])
    buttons.append([KeyboardButton(text="❌ Отмена")])
    kb = ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True)

    text_msg = f"🔓 <b>План: {name}</b>\n\nКакую кампанию отвязать?\n"
    for i, c in enumerate(campaigns):
        text_msg += f"\n{i+1}. {c['source_emoji']} {c['name']}"

    await message.answer(text_msg, parse_mode="HTML", reply_markup=kb)
    await state.set_state(UnlinkCampaign.choose_campaign)


@dp.message(UnlinkCampaign.choose_campaign)
async def unlink_choose_campaign(message: types.Message, state: FSMContext):
    text = message.text.strip()
    d = await state.get_data()
    plan_name = d["unlink_plan_name"]
    plans = get_plans(message.from_user.id)
    campaigns = plans[plan_name].get("linked_campaigns", [])

    if "отвязать все" in text.lower() or "🗑🗑" in text:
        save_plan_campaigns(message.from_user.id, plan_name, [])
        await message.answer(
            f"✅ Все кампании отвязаны от «{plan_name}»!",
            reply_markup=main_kb()
        )
        await state.clear()
        return

    import re
    match = re.search(r'(\d+)\.', text)
    if not match:
        await message.answer("❌ Выбери кампанию из списка:")
        return

    idx = int(match.group(1)) - 1
    if idx < 0 or idx >= len(campaigns):
        await message.answer("❌ Неверный номер:")
        return

    removed = campaigns.pop(idx)
    save_plan_campaigns(message.from_user.id, plan_name, campaigns)

    await message.answer(
        f"✅ Отвязана: {removed['source_emoji']} {removed['name']}\n"
        f"📎 Осталось кампаний: {len(campaigns)}",
        reply_markup=main_kb()
    )
    await state.clear()

async def tt_get_account_timezone():
    """Получает часовой пояс аккаунта TikTok"""
    url = "https://business-api.tiktok.com/open_api/v1.3/advertiser/info/"
    headers = {"Access-Token": tt_token_data["access_token"]}
    params = {
        "advertiser_ids": json.dumps([TT_ADVERTISER_ID]),
        "fields": json.dumps(["timezone"]),
    }
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(url, headers=headers, params=params) as resp:
                res = await resp.json()
                if res.get("code") == 0:
                    data_list = res.get("data", {}).get("list", [])
                    if data_list:
                        tz = data_list[0].get("timezone", "")
                        logging.info(f"TT account timezone: {tz}")
                        return tz
    except Exception as e:
        logging.error(f"TT timezone error: {e}")
    return None


async def tt_get_adgroup_insights(campaign_id, preset="today"):
    """Статистика по группам объявлений TikTok кампании"""
    from datetime import timezone, timedelta as td
    minsk_tz = timezone(td(hours=3))
    today = datetime.now(minsk_tz).date()
    if preset in ["today", "Сегодня"]:
        start_date = end_date = today.isoformat()
    elif preset in ["yesterday", "Вчера"]:
        start_date = end_date = (today - timedelta(days=1)).isoformat()
    elif preset in ["last_7d", "7 дней"]:
        start_date = (today - timedelta(days=6)).isoformat()
        end_date = today.isoformat()
    elif preset in ["last_30d", "30 дней"]:
        start_date = (today - timedelta(days=29)).isoformat()
        end_date = today.isoformat()
    else:
        start_date = end_date = today.isoformat()

    url = "https://business-api.tiktok.com/open_api/v1.3/report/integrated/get/"
    headers = {"Access-Token": tt_token_data["access_token"]}

    base_params = {
        "advertiser_id": TT_ADVERTISER_ID,
        "service_type": "AUCTION",
        "report_type": "BASIC",
        "data_level": "AUCTION_ADGROUP",
        "dimensions": json.dumps(["adgroup_id"]),
        "start_date": start_date,
        "end_date": end_date,
        "filtering": json.dumps([{
            "field_name": "campaign_ids",
            "filter_type": "IN",
            "filter_value": json.dumps([str(campaign_id)])
        }]),
        "page": 1,
        "page_size": 100,
    }

    try:
        async with aiohttp.ClientSession() as session:
            # Базовые метрики
            params1 = {**base_params, "metrics": json.dumps([
                "spend", "impressions", "clicks", "cpc", "ctr", "cpm"
            ])}
            async with session.get(url, headers=headers, params=params1) as resp:
                res1 = await resp.json()
            base_data = {}
            if res1.get("code") == 0:
                for item in res1.get("data", {}).get("list", []):
                    ag_id = item["dimensions"]["adgroup_id"]
                    base_data[ag_id] = item["metrics"]

            # Конверсии
            params2 = {**base_params, "metrics": json.dumps([
                "real_time_conversion", "real_time_cost_per_conversion"
            ])}
            async with session.get(url, headers=headers, params=params2) as resp:
                res2 = await resp.json()
            conv_data = {}
            if res2.get("code") == 0:
                for item in res2.get("data", {}).get("list", []):
                    ag_id = item["dimensions"]["adgroup_id"]
                    conv_data[ag_id] = item["metrics"]

            # Названия и статусы adgroup
            url_ag = "https://business-api.tiktok.com/open_api/v1.3/adgroup/get/"
            ag_ids = list(base_data.keys())
            names = {}
            statuses = {}
            if ag_ids:
                params_ag = {
                    "advertiser_id": TT_ADVERTISER_ID,
                    "filtering": json.dumps({
                        "campaign_ids": [str(campaign_id)],
                        "adgroup_ids": [str(x) for x in ag_ids]
                    }),
                    "page": 1,
                    "page_size": 100,
                    "fields": json.dumps(["adgroup_id", "adgroup_name", "operation_status", "secondary_status", "budget"]),
                }
                async with session.get(url_ag, headers=headers, params=params_ag) as resp:
                    res_ag = await resp.json()
                budgets = {}
                if res_ag.get("code") == 0:
                    for ag in res_ag.get("data", {}).get("list", []):
                        ag_id_str = str(ag["adgroup_id"])
                        names[ag_id_str] = ag["adgroup_name"]
                        statuses[ag_id_str] = ag.get("operation_status", "ENABLE")
                        # budget в TikTok в микро-юнитах (нет, в обычных долларах)
                        budgets[ag_id_str] = float(ag.get("budget", 0) or 0)
            # Собираем
            adgroups = []
            for ag_id, metrics in base_data.items():
                conv = conv_data.get(ag_id, {})
                spend = float(metrics.get("spend", 0) or 0)
                leads = int(float(conv.get("real_time_conversion", 0) or 0))
                cpl = float(conv.get("real_time_cost_per_conversion", 0) or 0)
                if cpl == 0 and leads > 0:
                    cpl = spend / leads

                op_status = statuses.get(ag_id, "ENABLE")
                is_active = op_status in ["ENABLE", "ADGROUP_STATUS_ENABLE"]

                adgroups.append({
                    "id": ag_id,
                    "name": names.get(ag_id, f"AG {ag_id[-6:]}"),
                    "spend": spend,
                    "impressions": int(float(metrics.get("impressions", 0) or 0)),
                    "clicks": int(float(metrics.get("clicks", 0) or 0)),
                    "ctr": float(metrics.get("ctr", 0) or 0),
                    "cpc": float(metrics.get("cpc", 0) or 0),
                    "leads": leads,
                    "cpl": cpl,
                    "is_active": is_active,
                    "status": "АКТИВНА" if is_active else "ВЫКЛЮЧЕНА",
                    "budget": budgets.get(ag_id, 0),
                })

            # Сортируем по расходу
            adgroups.sort(key=lambda x: x["spend"], reverse=True)
            return adgroups

    except Exception as e:
        logging.error(f"TT adgroup insights error: {e}")
        return []

async def fb_get_adset_insights(campaign_id, date_preset="today"):
    """Статистика по adsets (группам) кампании Facebook"""
    url = f"{FB_BASE_URL}/{campaign_id}/insights"
    params = {
        "access_token": FB_ACCESS_TOKEN,
        "fields": "adset_name,spend,impressions,clicks,cpc,ctr,cpm,actions,frequency",
        "date_preset": date_preset,
        "level": "adset",
        "limit": 50,
    }
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(url, params=params, timeout=aiohttp.ClientTimeout(total=15)) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    return {"ok": True, "data": data.get("data", [])}
                else:
                    return {"ok": False, "error": f"HTTP {resp.status}"}
    except Exception as e:
        logging.error(f"FB adset insights error: {e}")
        return {"ok": False, "error": str(e)}

# ══════════════════════════════════════
# ДАШБОРД ПО ПЛАНУ
# ══════════════════════════════════════

@dp.message(F.text == "📊 Дашборд по плану")
async def dashboard_start(message: types.Message, state: FSMContext):
    await state.clear()
    plans = get_plans(message.from_user.id)

    # Только планы с привязанными кампаниями
    linked_plans = {k: v for k, v in plans.items() if v.get("linked_campaigns")}

    if not linked_plans:
        await message.answer(
            "❌ Нет планов с привязанными кампаниями.\n\n"
            "1. Создай план → «📊 Юнит-экономика»\n"
            "2. Привяжи кампании → «🔗 Привязать кампании»",
            reply_markup=main_kb()
        )
        return

    buttons = []
    for name, p in linked_plans.items():
        count = len(p.get("linked_campaigns", []))
        buttons.append([KeyboardButton(text=f"📊 {name} ({count} камп.)")])
    buttons.append([KeyboardButton(text="❌ Отмена")])
    kb = ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True)

    await message.answer(
        "📊 <b>Дашборд — выбери план:</b>",
        parse_mode="HTML",
        reply_markup=kb
    )
    await state.set_state(PlanDashboard.choose_plan)


@dp.message(PlanDashboard.choose_plan)
async def dashboard_choose_plan(message: types.Message, state: FSMContext):
    text = message.text.strip()
    if not text.startswith("📊 "):
        await message.answer("❌ Выбери план из списка:")
        return

    name = text[2:].strip()
    if "(" in name:
        name = name[:name.rfind("(")].strip()

    plans = get_plans(message.from_user.id)
    if name not in plans:
        await message.answer("❌ План не найден:")
        return

    await state.update_data(dashboard_plan=name)

    kb = ReplyKeyboardMarkup(keyboard=[
        [KeyboardButton(text="📊 Сегодня"), KeyboardButton(text="📊 Вчера")],
        [KeyboardButton(text="📊 7 дней"), KeyboardButton(text="📊 30 дней")],
        [KeyboardButton(text="❌ Отмена")]
    ], resize_keyboard=True)

    await message.answer(
        f"📊 <b>План: {name}</b>\n\nВыбери период:",
        parse_mode="HTML",
        reply_markup=kb
    )
    await state.set_state(PlanDashboard.choose_period)


@dp.message(PlanDashboard.choose_period)
async def dashboard_period(message: types.Message, state: FSMContext):
    text = message.text.strip()

    presets = {
        "📊 Сегодня": "today",
        "📊 Вчера": "yesterday",
        "📊 7 дней": "last_7d",
        "📊 30 дней": "last_30d",
    }

    preset = presets.get(text)
    if not preset:
        await message.answer("❌ Выбери период кнопкой:")
        return

    d = await state.get_data()
    plan_name = d["dashboard_plan"]
    plans = get_plans(message.from_user.id)
    plan = plans.get(plan_name, {})
    campaigns = plan.get("linked_campaigns", [])

    if not campaigns:
        await message.answer("❌ Нет привязанных кампаний.", reply_markup=main_kb())
        await state.clear()
        return

    await message.answer("⏳ Загружаю данные по всем кампаниям...")

    max_cpl_20 = plan.get("max_cpl_20", 0) or plan.get("max_cpl", 0) or plan.get("max_cpl_usd", 0) or 0
    max_cpl_0 = plan.get("max_cpl_0", 0) or plan.get("max_cpl", 0) or plan.get("max_cpl_usd", 0) or 0
    max_cpl = max_cpl_20  # основной план = рент 20%
    profit_per = plan.get("profit_per_buyout", 0)
    profitability = plan.get("profitability", 0)

    total_spend = 0
    total_impressions = 0
    total_clicks = 0
    total_leads = 0
    campaign_reports = []

    for c in campaigns:
        if c["source"] == "fb":
            result = await fb_get_campaign_insights(c["id"], date_preset=preset)
            if result["ok"] and result["data"]:
                row = result["data"][0]
                spend = float(row.get("spend", 0))
                impressions = int(row.get("impressions", 0))
                clicks = int(row.get("clicks", 0))
                ctr = float(row.get("ctr", 0))
                cpc = float(row.get("cpc", 0))
                leads = fb_extract_leads(row.get("actions"))
                cpl = (spend / leads) if leads > 0 else 0

                total_spend += spend
                total_impressions += impressions
                total_clicks += clicks
                total_leads += leads

                if leads == 0:
                    cpl_status = "⏳"
                elif max_cpl_20 > 0 and cpl <= max_cpl_20:
                    cpl_status = "🟢"   # рент 20%+
                elif max_cpl_0 > 0 and cpl <= max_cpl_0:
                    cpl_status = "🟡"   # между планом и безубытком
                else:
                    cpl_status = "🔴"   # убыток

                short_name = c["name"][:30] + "..." if len(c["name"]) > 30 else c["name"]
                campaign_reports.append({
                    "id": c["id"],           # ДОБАВЬ
                    "source": c["source"],   # ДОБАВЬ
                    "name": short_name, "emoji": c["source_emoji"],
                    "spend": spend, "clicks": clicks, "leads": leads,
                    "cpl": cpl, "ctr": ctr, "cpc": cpc, "status": cpl_status,
                })
            else:
                short_name = c["name"][:30] + "..." if len(c["name"]) > 30 else c["name"]
                campaign_reports.append({
                    "id": c["id"],           # ДОБАВЬ
                    "source": c["source"],   # ДОБАВЬ
                    "name": short_name, "emoji": c["source_emoji"],
                    "spend": 0, "clicks": 0, "leads": 0,
                    "cpl": 0, "ctr": 0, "cpc": 0, "status": "⏸",
                })

        elif c["source"] == "tt":
            # TikTok: загружаем данные по кампании
            result = await tt_get_campaign_insights(c["id"], preset)
            if result and result.get("ok") and result.get("data"):
                m = result["data"]
                spend = float(m.get("spend", 0) or 0)
                impressions = int(float(m.get("impressions", 0) or 0))
                clicks = int(float(m.get("clicks", 0) or 0))
                ctr = (clicks / impressions * 100) if impressions > 0 else 0
                cpc = (spend / clicks) if clicks > 0 else 0
                leads = int(float(m.get("conversion", 0) or 0))
                cpl = float(m.get("cost_per_conversion", 0) or 0)
                if cpl == 0 and leads > 0:
                    cpl = spend / leads

                total_spend += spend
                total_impressions += impressions
                total_clicks += clicks
                total_leads += leads

                if leads == 0:
                    cpl_status = "⏳"
                elif max_cpl_20 > 0 and cpl <= max_cpl_20:
                    cpl_status = "🟢"   # рент 20%+
                elif max_cpl_0 > 0 and cpl <= max_cpl_0:
                    cpl_status = "🟡"   # между планом и безубытком
                else:
                    cpl_status = "🔴"   # убыток
                    
                short_name = c["name"][:30] + "..." if len(c["name"]) > 30 else c["name"]
                campaign_reports.append({
                    "id": c["id"],           # ДОБАВЬ
                    "source": c["source"],   # ДОБАВЬ
                    "name": short_name, "emoji": c["source_emoji"],
                    "spend": spend, "clicks": clicks, "leads": leads,
                    "cpl": cpl, "ctr": ctr, "cpc": cpc, "status": cpl_status,
                })
            else:
                short_name = c["name"][:30] + "..." if len(c["name"]) > 30 else c["name"]
                campaign_reports.append({
                    "id": c["id"],           # ДОБАВЬ
                    "source": c["source"],   # ДОБАВЬ
                    "name": short_name, "emoji": c["source_emoji"],
                    "spend": 0, "clicks": 0, "leads": 0,
                    "cpl": 0, "ctr": 0, "cpc": 0, "status": "⏸",
                })
    # Общие метрики
    avg_cpl = (total_spend / total_leads) if total_leads > 0 else 0
    avg_ctr = (total_clicks / total_impressions * 100) if total_impressions > 0 else 0
    avg_cpc = (total_spend / total_clicks) if total_clicks > 0 else 0

    # Светофор общий
    if total_leads == 0:
        overall = "⏳"
    elif max_cpl_20 > 0 and avg_cpl <= max_cpl_20:
        overall = "🟢"
    elif max_cpl_0 > 0 and avg_cpl <= max_cpl_0:
        overall = "🟡"
    else:
        overall = "🔴"

    # Прогноз прибыли
    if total_leads > 0 and plan.get("approve_pct", 0) > 0:
        approve = plan["approve_pct"] / 100
        estimated_orders = total_leads * approve
        estimated_profit = estimated_orders * profit_per
    else:
        estimated_orders = 0
        estimated_profit = 0

    period_names = {
        "today": "Сегодня",
        "yesterday": "Вчера",
        "last_7d": "7 дней",
        "last_30d": "30 дней",
    }

    report = f"""📊 <b>ДАШБОРД: {plan_name}</b>
📅 {period_names.get(preset, preset)}

━━━ 🎯 ПЛАН ━━━
🎯 План CPL: <b>${max_cpl_20:.2f}</b> (рент. 20%)
⚠️ Безубыток: <b>${max_cpl_0:.2f}</b>
📈 Рентабельность: <b>{profitability:.1f}%</b>
💵 Прибыль/выкуп: <b>{profit_per:.2f} BYN</b>

━━━ 📊 ИТОГО ━━━
💵 Потрачено: <b>${total_spend:.2f}</b>
👁 Показы: <b>{total_impressions:,}</b>
🖱 Клики: <b>{total_clicks:,}</b>
📝 Лиды: <b>{total_leads}</b>
{overall} Средний CPL: <b>${avg_cpl:.2f}</b> (план ${max_cpl_20:.2f} | безуб. ${max_cpl_0:.2f})

━━━ 💰 ПРОГНОЗ ━━━
✅ Заказов (прогноз): ~{estimated_orders:.0f}
💰 Прибыль (прогноз): ~{estimated_profit:.2f} BYN

━━━ 📋 КАМПАНИИ И СВЯЗКИ ━━━"""

    # Собираем adgroup данные для каждой кампании
    all_adgroup_alerts = []

    for c in campaign_reports:
        report += f"""
{c['status']} {c['emoji']} <b>{c['name']}</b>
   💵 ${c['spend']:.2f} | 🖱 {c['clicks']} | 📝 {c['leads']}"""
        if c['leads'] > 0:
            report += f" | CPL ${c['cpl']:.2f}"
        report += "\n"

        # Загружаем adgroups для этой кампании
        camp_id = c.get("id")
        source = c.get("source")

        if camp_id and source == "tt" and c['spend'] > 0:
            adgroups = await tt_get_adgroup_insights(camp_id, preset)
            if adgroups:
                for ag in adgroups:
                    ag_name = ag["name"][:25] + "..." if len(ag["name"]) > 25 else ag["name"]

                    if ag["leads"] == 0 and ag["spend"] == 0:
                        continue  # пропускаем пустые

                    if ag["leads"] == 0:
                        ag_st = "⏳"
                    elif max_cpl_20 > 0 and ag["cpl"] <= max_cpl_20:
                        ag_st = "🟢"
                    elif max_cpl_0 > 0 and ag["cpl"] <= max_cpl_0:
                        ag_st = "🟡"
                    else:
                        ag_st = "🔴"

                    ag_line = f"   {ag_st} ├ {ag_name}: ${ag['spend']:.2f} | 👁{ag['impressions']:,} | 🖱{ag['clicks']} | 📝{ag['leads']}"
                    if ag["leads"] > 0:
                        ag_line += f" | CPL ${ag['cpl']:.2f}"
                    report += ag_line + "\n"

                    # Собираем алерты по adgroup
                    if ag["leads"] >= 2 and max_cpl_20 > 0 and ag["cpl"] <= max_cpl_20 * 0.7:
                        all_adgroup_alerts.append(
                            f"🟢 «{ag_name}» — CPL ${ag['cpl']:.2f} — огонь! Делай дубли!"
                        )
                    elif ag["leads"] > 0 and max_cpl_0 > 0 and ag["cpl"] > max_cpl_0:
                        all_adgroup_alerts.append(
                            f"🔴 «{ag_name}» — CPL ${ag['cpl']:.2f} > безуб. ${max_cpl_0:.2f}. УБЫТОК!"
                        )
                    elif ag["leads"] > 0 and max_cpl_20 > 0 and ag["cpl"] > max_cpl_20:
                        all_adgroup_alerts.append(
                            f"🟡 «{ag_name}» — CPL ${ag['cpl']:.2f} > план ${max_cpl_20:.2f}. Низкая рент."
                        )                   
                    if ag["leads"] == 0 and ag["spend"] > 0:
                        ag_stop_d = 4.0 if c.get("source") == "tt" else 6.0
                        ag_bad_cpc_d = 0.15 if c.get("source") == "tt" else 0.50
                        ag_bad_ctr_d = 1.0 if c.get("source") == "tt" else 0.8

                        if ag["spend"] >= ag_stop_d:
                            all_adgroup_alerts.append(
                                f"🛑 «{ag_name}» — ${ag['spend']:.2f} без лидов — СТОП!"
                            )
                        elif ag["spend"] >= 1.5 and (ag.get("cpc", 0) > ag_bad_cpc_d or (ag["impressions"] > 500 and ag["ctr"] < ag_bad_ctr_d)):
                            all_adgroup_alerts.append(
                                f"🔴 «{ag_name}» — ${ag['spend']:.2f} | CPC ${ag.get('cpc',0):.2f} | CTR {ag['ctr']:.1f}% — мёртвый старт!"
                            )
                        elif ag["spend"] >= 2.0:
                            all_adgroup_alerts.append(
                                f"🟡 «{ag_name}» — ${ag['spend']:.2f} тест идёт, не трогай"
                            )

                        if ag["clicks"] > 30:
                            if c['leads'] > 0:
                                all_adgroup_alerts.append(
                                    f"⚠️ «{ag_name}» — {ag['clicks']} кликов, 0 лидов. Смени аудиторию!"
                                )
                            else:
                                all_adgroup_alerts.append(
                                    f"⚠️ «{ag_name}» — {ag['clicks']} кликов, 0 лидов. Проверь лендинг!"
                                )
                    if ag["impressions"] > 1000 and ag["ctr"] < 0.8:
                        all_adgroup_alerts.append(
                            f"⚠️ «{ag_name}» — CTR {ag['ctr']:.2f}%. Смени креатив!"
                        )

        elif camp_id and source == "fb" and c['spend'] > 0:
            # FB adsets
            adsets = await fb_get_adset_insights(camp_id, date_preset=preset)
            if adsets and adsets.get("ok") and adsets.get("data"):
                for row in adsets["data"]:
                    as_name = row.get("adset_name", "Без названия")[:25]
                    as_spend = float(row.get("spend", 0))
                    as_imp = int(row.get("impressions", 0))
                    as_clicks = int(row.get("clicks", 0))
                    as_ctr = float(row.get("ctr", 0))
                    as_leads = fb_extract_leads(row.get("actions"))
                    as_cpl = (as_spend / as_leads) if as_leads > 0 else 0

                    if as_spend == 0 and as_imp == 0:
                        continue

                    if as_leads == 0:
                        as_st = "⏳"
                    elif max_cpl_20 > 0 and as_cpl <= max_cpl_20:
                        as_st = "🟢"
                    elif max_cpl_0 > 0 and as_cpl <= max_cpl_0:
                        as_st = "🟡"
                    else:
                        as_st = "🔴"

                    as_line = f"   {as_st} ├ {as_name}: ${as_spend:.2f} | 👁{as_imp:,} | 🖱{as_clicks} | 📝{as_leads}"
                    if as_leads > 0:
                        as_line += f" | CPL ${as_cpl:.2f}"
                    report += as_line + "\n"

                    # Алерты по adset
                    if as_leads > 0 and max_cpl_0 > 0 and as_cpl > max_cpl_0:
                        all_adgroup_alerts.append(
                            f"🔴 «{as_name}» — CPL ${as_cpl:.2f} > безуб. ${max_cpl_0:.2f}. УБЫТОК!"
                        )
                    elif as_leads > 0 and max_cpl_20 > 0 and as_cpl > max_cpl_20:
                        all_adgroup_alerts.append(
                            f"🟡 «{as_name}» — CPL ${as_cpl:.2f} > план ${max_cpl_20:.2f}. Низкая рент."
                        )
                    if as_leads == 0 and as_spend > max_cpl_0 * 2 and max_cpl_0 > 0:
                        all_adgroup_alerts.append(
                            f"🚨 «{as_name}» — ${as_spend:.2f} без лидов! Останови!"
                        )
                    if as_leads == 0 and as_clicks > 30 and as_spend > 0:
                        all_adgroup_alerts.append(
                            f"⚠️ «{as_name}» — {as_clicks} кликов, 0 лидов. Лендинг?"
                        )

    # Рекомендации по кампаниям
    tips = []
    for c in campaign_reports:
        if c["status"] == "🔴" and c["leads"] > 0:
            tips.append(f"🔴 «{c['name']}» — CPL ${c['cpl']:.2f} > безуб. ${max_cpl_0:.2f}. УБЫТОК!")
        if c["spend"] > 0 and c["leads"] == 0 and c["clicks"] > 20:
            tips.append(f"⚠️ «{c['name']}» — {c['clicks']} кликов, 0 лидов. Лендинг!")

    # Добавляем алерты по связкам
    if all_adgroup_alerts:
        tips.extend(all_adgroup_alerts)

    if tips:
        report += "\n━━━ ⚠️ ВНИМАНИЕ ━━━\n"
        # Убираем дубли
        seen = set()
        for tip in tips:
            if tip not in seen:
                seen.add(tip)
                report += f"{tip}\n"

    # Сохраняем данные для кнопки "Связки"
    await state.update_data(
        dashboard_plan=plan_name,
        dashboard_preset=preset,
        dashboard_campaigns=campaigns,
        dashboard_max_cpl_20=max_cpl_20,
        dashboard_max_cpl_0=max_cpl_0,
    )

    # Inline кнопки под дашбордом
    inline_kb = InlineKeyboardMarkup(inline_keyboard=[
        [
            InlineKeyboardButton(text="📊 Связки (adgroups)", callback_data="dash_adgroups"),
        ],
        [
            InlineKeyboardButton(text="📊 Сегодня", callback_data="dash_today"),
            InlineKeyboardButton(text="📊 Вчера", callback_data="dash_yesterday"),
        ],
        [
            InlineKeyboardButton(text="📊 7 дней", callback_data="dash_last_7d"),
            InlineKeyboardButton(text="📊 30 дней", callback_data="dash_last_30d"),
        ],
    ])

    await message.answer(report, parse_mode="HTML", reply_markup=inline_kb)
    # НЕ очищаем state — нужен для кнопок

@dp.callback_query(F.data == "dash_adgroups")
async def dash_adgroups_handler(callback: types.CallbackQuery, state: FSMContext):
    d = await state.get_data()
    campaigns = d.get("dashboard_campaigns", [])
    preset = d.get("dashboard_preset", "today")
    max_cpl_20 = d.get("dashboard_max_cpl_20", 0)
    max_cpl_0 = d.get("dashboard_max_cpl_0", 0)
    plan_name = d.get("dashboard_plan", "")

    await callback.answer("⏳ Загружаю связки...")

    period_names = {
        "today": "Сегодня", "yesterday": "Вчера",
        "last_7d": "7 дней", "last_30d": "30 дней",
    }

    report = f"""📊 <b>СВЯЗКИ (ADGROUPS): {plan_name}</b>
📅 {period_names.get(preset, preset)}
🎯 План: ${max_cpl_20:.2f} | Безуб: ${max_cpl_0:.2f}
"""

    has_data = False

    for c in campaigns:
        if c["source"] == "tt":
            adgroups = await tt_get_adgroup_insights(c["id"], preset)
            if adgroups:
                has_data = True
                camp_name = c["name"][:25] + "..." if len(c["name"]) > 25 else c["name"]
                report += f"\n━━━ 🎵 {camp_name} ━━━\n"

                for ag in adgroups:
                    name = ag["name"][:22] + "..." if len(ag["name"]) > 22 else ag["name"]

                    if ag["leads"] == 0:
                        st = "⏳"
                    elif max_cpl_20 > 0 and ag["cpl"] <= max_cpl_20:
                        st = "🟢"
                    elif max_cpl_0 > 0 and ag["cpl"] <= max_cpl_0:
                        st = "🟡"
                    else:
                        st = "🔴"

                    report += f"""
{st} <b>{name}</b>
   💵 ${ag['spend']:.2f} | 🖱 {ag['clicks']} | CTR {ag['ctr']:.1f}%
   CPC ${ag['cpc']:.2f} | 📝 {ag['leads']} лид."""
                    if ag["leads"] > 0:
                        report += f" | CPL ${ag['cpl']:.2f}"
                    report += "\n"

        elif c["source"] == "fb":
            # TODO: FB adsets если нужно
            pass

    if not has_data:
        report += "\n❌ Нет данных по связкам"

    # Кнопка назад
    back_kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="◀️ Назад к дашборду", callback_data=f"dash_{preset}")],
    ])

    # Telegram лимит 4096 символов
    if len(report) > 4000:
        parts = [report[i:i+4000] for i in range(0, len(report), 4000)]
        for i, part in enumerate(parts):
            if i == len(parts) - 1:
                await callback.message.answer(part, parse_mode="HTML", reply_markup=back_kb)
            else:
                await callback.message.answer(part, parse_mode="HTML")
    else:
        await callback.message.answer(report, parse_mode="HTML", reply_markup=back_kb)


@dp.callback_query(F.data.startswith("dash_"))
async def dash_period_switch(callback: types.CallbackQuery, state: FSMContext):
    preset = callback.data.replace("dash_", "")
    if preset == "adgroups":
        return  # обработан выше

    d = await state.get_data()
    plan_name = d.get("dashboard_plan")
    if not plan_name:
        await callback.answer("❌ Данные устарели, открой дашборд заново")
        return

    # Эмулируем выбор периода
    preset_map = {
        "today": "📊 Сегодня",
        "yesterday": "📊 Вчера",
        "last_7d": "📊 7 дней",
        "last_30d": "📊 30 дней",
    }

    fake_text = preset_map.get(preset)
    if not fake_text:
        await callback.answer("❌ Неизвестный период")
        return

    await callback.answer(f"⏳ {fake_text}...")

    # Создаём фейковое сообщение и вызываем dashboard_period
    callback.message.text = fake_text
    await dashboard_period(callback.message, state)

