@dp.message(ProductCheck.ah_notes)
async def ah_notes_h(message: types.Message, state: FSMContext):
    text = message.text.strip()
    notes = "" if ("пропустить" in text.lower() or "пропуск" in text) else text
    d = await state.get_data()
    name = d["check_product_name"]
    days, creo, buyers = d.get("ah_days", 0), d.get("ah_creatives", 0), d.get("ah_buyers", 0)

    score, details = 0, []
    # Дни
    if days >= 14:
        score += 1; details.append(f"✅ {int(days)} дней — стабильно")
    elif days >= 10:
        score += 0.7; details.append(f"🟡 {int(days)} дней — норма")
    elif days >= 5:
        score += 0.3; details.append(f"🟡 {int(days)} дней — мало")
    else:
        details.append(f"❌ {int(days)} дней — слишком мало")
    # Крео
    if creo >= 7:
        score += 1; details.append(f"✅ {creo} крео — активно")
    elif creo >= 5:
        score += 0.7; details.append(f"🟡 {creo} крео — нормально")
    elif creo >= 3:
        score += 0.3; details.append(f"🟡 {creo} крео — мало")
    else:
        details.append(f"❌ {creo} крео — почти нет")
    # Байеры
    if buyers >= 3:
        score += 1; details.append(f"✅ {buyers} байеров — массово льют")
    elif buyers >= 2:
        score += 0.5; details.append(f"🟡 {buyers} байера")
    else:
        score += 0.2; details.append(f"🟡 {buyers} байер")

    pct = score / 3 * 100
    if pct >= 70: ve, vt = "🟢", "ПОДТВЕРЖДЁН"
    elif pct >= 45: ve, vt = "🟡", "СОМНЕНИЯ"
    else: ve, vt = "🔴", "НЕ ПРОШЁЛ"

    adheart_data = {
        "days": days, "creatives": creo, "buyers": buyers,
        "geo": d.get("ah_geo", ""), "formats": d.get("ah_formats", ""),
        "notes": notes, "score": round(pct, 1), "verdict": vt,
        "verdict_emoji": ve, "details": details,
        "date": datetime.now().strftime("%d.%m.%Y %H:%M"),
    }
    update_product_field(message.from_user.id, name, "adheart", adheart_data)

    report = f"""{ve} <b>ADHEART: {name}</b>

📅 Дней: <b>{int(days)}</b> | 🎨 Крео: <b>{creo}</b> | 👤 Байеров: <b>{buyers}</b>
🌍 ГЕО: {d.get('ah_geo','—')} | 🎬 {d.get('ah_formats','—')}

━━━ ОЦЕНКА ({pct:.0f}%) ━━━
"""
    for det in details:
        report += f"{det}\n"
    if notes:
        report += f"\n📝 {notes}"
    report += f"\n{ve} <b>{vt}</b>"

    await message.answer(report, parse_mode="HTML")
    p = get_products(message.from_user.id).get(name, {})
    await show_criteria_menu(message, state, name, p)


