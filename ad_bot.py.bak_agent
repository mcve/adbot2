# 🗑 УДАЛЕНИЕ ТОВАРА
# ══════════════════════════════════════

@dp.message(F.text == "🗑 Удалить товар")
async def del_product_start(message: types.Message, state: FSMContext):
    await state.clear()
    products = get_products(message.from_user.id)
    if not products:
        await message.answer("📦 Нет товаров.", reply_markup=main_kb())
        return

    buttons = []
    for name in products:
        buttons.append([KeyboardButton(text=f"🗑 {name}")])
    buttons.append([KeyboardButton(text="🗑🗑 Удалить ВСЕ товары")])
    buttons.append([KeyboardButton(text="❌ Отмена")])

    await message.answer("🗑 <b>Удалить товар:</b>", parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True))
    await state.set_state(DeleteProduct.choose)


@dp.message(DeleteProduct.choose)
async def del_product_confirm(message: types.Message, state: FSMContext):
    text = message.text.strip()

    if "удалить все" in text.lower() or "🗑🗑" in text:
        data = load_products()
        uid = str(message.from_user.id)
        count = len(data.get(uid, {}))
        if uid in data:
            data[uid] = {}
            save_products(data)
        await message.answer(f"✅ Удалено {count} товаров!", reply_markup=main_kb())
        await state.clear()
        return

    if not text.startswith("🗑"):
        await message.answer("❌ Выбери из списка:")
        return

    name = text[1:].strip()
    result = delete_product(message.from_user.id, name)
    if result:
        remaining = len(get_products(message.from_user.id))
        await message.answer(f"✅ Товар «{name}» удалён!\n📦 Осталось: {remaining}", reply_markup=main_kb())
    else:
        await message.answer("❌ Не найден.", reply_markup=main_kb())
    await state.clear()

