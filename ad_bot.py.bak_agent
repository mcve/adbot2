@dp.message(ProductCheck.vis_repeat)
async def vis_repeat_h(message: types.Message, state: FSMContext):
    v = pyn(message.text)
    if v is None:
        await message.answer("❌ Да или Нет:")
        return
        await state.update_data(vis_repeat=v)

    d = await state.get_data()
    name = d["check_product_name"]

    no_sound = d.get("vis_no_sound", False)
    hook_3s = d.get("vis_3sec", False)
    wow = d.get("vis_wow", False)
    demo = d.get("vis_demo", False)
    repeat = d.get("vis_repeat", False)

    score, details = 0, []
    checks_list = [
        (no_sound, "Понятно без звука", 1.0),
        (hook_3s, "Hook за 3 секунды", 1.0),
        (wow, "WOW-эффект", 0.5),
        (demo, "Демонстрация в действии", 1.0),
        (repeat, "Легко повторить крео", 0.5),
    ]

    for val, label, weight in checks_list:
        if val:
            score += weight
            details.append(f"✅ {label}")
        else:
            details.append(f"❌ {label}")

    max_score = sum(w for _, _, w in checks_list)
    pct = score / max_score * 100 if max_score > 0 else 0

    if pct >= 70:
        ve, vt = "🟢", "ВИЗУАЛ ОГОНЬ"
    elif pct >= 45:
        ve, vt = "🟡", "ВИЗУАЛ СРЕДНИЙ"
    else:
        ve, vt = "🔴", "ВИЗУАЛ СЛАБЫЙ"

    # Доп. рекомендации
    recs = []
    if not no_sound:
        recs.append("💡 Добавь субтитры и текст на видео")
    if not hook_3s:
        recs.append("💡 Начни с проблемы или результата — 3 сек решают")
    if not demo:
        recs.append("💡 Покажи товар в действии — это ключевое")
    if not repeat:
        recs.append("💡 Упрости крео — снимай на телефон, без продакшна")

    vis_data = {
        "no_sound": no_sound, "hook_3sec": hook_3s, "wow": wow,
        "demo": demo, "easy_repeat": repeat,
        "score": round(pct, 1), "verdict": vt, "verdict_emoji": ve,
        "details": details, "recs": recs,
        "date": datetime.now().strftime("%d.%m.%Y %H:%M"),
    }
    update_product_field(message.from_user.id, name, "visual_hook", vis_data)

    report = f"""{ve} <b>ВИЗУАЛ: {name}</b>

━━━ ЧЕК-ЛИСТ ━━━
"""
    for det in details:
        report += f"{det}\n"

    report += f"\n━━━ ОЦЕНКА ({pct:.0f}%) ━━━\n{ve} <b>{vt}</b>"

    if recs:
        report += "\n\n━━━ 💡 СОВЕТЫ ━━━"
        for r in recs:
            report += f"\n{r}"

    await message.answer(report, parse_mode="HTML")
    p = get_products(message.from_user.id).get(name, {})
    await show_criteria_menu(message, state, name, p)


# ══════════════════════════════════════
# 7️⃣ ЭКОНОМИКА — ПРИВЯЗКА К ПЛАНУ
# ══════════════════════════════════════

async def econ_start(message, state):
    d = await state.get_data()
    name = d.get("check_product_name", "товар")
    plans = get_plans(message.from_user.id)

    if not plans:
        await message.answer(
            f"❌ Нет планов юнит-экономики.\n\n"
            f"Сначала рассчитай через «📊 Юнит-экономика»,\n"
            f"потом вернись и привяжи к товару «{name}».",
            reply_markup=main_kb()
        )
        await state.clear()
        return

    buttons = []
    for pname, p in plans.items():
        profit = p.get("net_profit", 0)
        rent = p.get("profitability", 0)
        emoji = "🟢" if rent >= 20 else ("🟡" if rent >= 10 else "🔴")
        buttons.append([KeyboardButton(text=f"{emoji} {pname} ({rent:.0f}%)")])
    buttons.append([KeyboardButton(text="❌ Отмена")])

    await message.answer(
        f"📊 <b>Экономика: {name}</b>\n\n"
        f"Привяжи план юнит-экономики к товару.\n"
        f"Это подтвердит рентабельность 20%+\n\n"
        f"Выбери план:",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True)
    )
    await state.set_state(ProductCheck.econ_plan)


@dp.message(ProductCheck.econ_plan)
async def econ_plan_h(message: types.Message, state: FSMContext):
    text = message.text.strip()

    # Убираем эмодзи и процент
    clean = text
    for e in ["🟢", "🟡", "🔴"]:
        if clean.startswith(e):
            clean = clean[len(e):].strip()
            break
    if "(" in clean:
        clean = clean[:clean.rfind("(")].strip()

    plan_name = clean
    plans = get_plans(message.from_user.id)

    if plan_name not in plans:
        # Поиск по частичному совпадению
        found = None
        for pn_key in plans:
            if pn_key in text:
                found = pn_key
                break
        if found:
            plan_name = found
        else:
            await message.answer("❌ План не найден. Выбери из списка:")
            return

    d = await state.get_data()
    name = d["check_product_name"]
    plan = plans[plan_name]

    update_product_field(message.from_user.id, name, "unit_plan", plan_name)

    profit = plan.get("net_profit", 0)
    rent = plan.get("profitability", 0)
    max_cpl = plan.get("max_cpl_20", 0) or plan.get("max_cpl", 0)
    max_cpl_0 = plan.get("max_cpl_0", 0)

    if rent >= 20:
        ve, vt = "🟢", "РЕНТАБЕЛЬНОСТЬ ПОДТВЕРЖДЕНА"
    elif rent >= 10:
        ve, vt = "🟡", "РЕНТАБЕЛЬНОСТЬ НИЗКАЯ"
    else:
        ve, vt = "🔴", "НЕРЕНТАБЕЛЬНО"

    report = f"""{ve} <b>ЭКОНОМИКА: {name}</b>

📋 План: <b>{plan_name}</b>

💰 Прибыль/выкуп: <b>{profit:.2f} BYN</b>
📈 Рентабельность: <b>{rent:.1f}%</b>
🎯 План CPL: <b>${max_cpl:.2f}</b>
⚠️ Безубыток: <b>${max_cpl_0:.2f}</b>

━━━━━━━━━━━━━━━━━━━━
{ve} <b>{vt}</b>
━━━━━━━━━━━━━━━━━━━━"""

    await message.answer(report, parse_mode="HTML")
    p = get_products(message.from_user.id).get(name, {})
    await show_criteria_menu(message, state, name, p)


# ══════════════════════════════════════
# 📊 ПОЛНАЯ КАРТОЧКА ТОВАРА
# ══════════════════════════════════════

async def show_full_card(message, state):
    d = await state.get_data()
    name = d.get("check_product_name", "")
    products = get_products(message.from_user.id)
    p = products.get(name)

    if not p:
        await message.answer("❌ Товар не найден.", reply_markup=main_kb())
        await state.clear()
        return

    checks = count_checks(p)
    ov = build_overall_verdict(p)

    report = f"""📊 <b>ПОЛНАЯ КАРТОЧКА ТОВАРА</b>

📦 <b>{name}</b>
🔍 Запрос: «{p.get('search_query', '—')}»
📅 Обновлено: {p.get('updated', '—')}

━━━━━━━━━━━━━━━━━━━━
{ov['emoji']} <b>ОБЩИЙ СКОРИНГ: {ov['score']:.0f}%</b>
{ov['emoji']} <b>{ov['verdict']}</b>
━━━━━━━━━━━━━━━━━━━━
Проверено: {checks}/7 критериев
"""

    # 1. AdHeart
    ah = p.get("adheart")
    if ah:
        report += f"""
━━━ {ah.get('verdict_emoji','⬜')} 1. ADHEART ({ah.get('score',0):.0f}%) ━━━
📅 {int(ah.get('days',0))} дн | 🎨 {ah.get('creatives',0)} крео | 👤 {ah.get('buyers',0)} байеров
🌍 {ah.get('geo','—')} | 🎬 {ah.get('formats','—')}"""
        if ah.get('notes'):
            report += f"\n📝 {ah['notes']}"
    else:
        report += "\n⬜ 1. AdHeart — не проверено"

    # 2. Спрос
    if p.get("demand_score", 0) > 0:
        report += f"""
━━━ {p.get('demand_emoji','⬜')} 2. СПРОС ({p['demand_score']:.0f}%) ━━━
📊 GT: {p.get('gt_trend','')} ({p.get('gt_trend_pct',0):+.1f}%)
📈 Вордстат: {int(p.get('ws_basic',0)):,} | точн: {int(p.get('ws_exact',0)):,}
🚫 Хейт: {p.get('hate_level','?')}"""
    else:
        report += "\n⬜ 2. Спрос — не проверено"

    # 3. TikTok
    tt = p.get("tiktok_reach")
    if tt:
        report += f"""
━━━ {tt.get('verdict_emoji','⬜')} 3. TIKTOK ({tt.get('score',0):.0f}%) ━━━
🎬 {tt.get('videos',0)} видео | ⚡ {tt.get('anomaly',0)} аномальных
👁 Макс: {format_number_short(tt.get('max_views',0))} | Средн: {format_number_short(tt.get('avg_views',0))}"""
    else:
        report += "\n⬜ 3. TikTok — не проверено"

    # 4. Интерес
    ic = p.get("interest_check")
    if ic:
        report += f"""
━━━ {ic.get('verdict_emoji','⬜')} 4. ИНТЕРЕС ({ic.get('score',0):.0f}%) ━━━"""
        for det in ic.get("details", []):
            report += f"\n{det}"
    else:
        report += "\n⬜ 4. Интерес — не проверено"

    # 5. WB
    wb = p.get("wb_check")
    if wb:
        report += f"""
━━━ {wb.get('verdict_emoji','⬜')} 5. WB ЦЕНЫ ({wb.get('score',0):.0f}%) ━━━
💰 Твоя: {wb.get('your_price',0):.2f} BYN | Закуп: {wb.get('ali_price',0):.2f} BYN
🛒 WB мин: {wb.get('wb_min',0):.2f} BYN | Товаров: {wb.get('wb_count',0)}"""
    else:
        report += "\n⬜ 5. WB — не проверено"

    # 6. Визуал
    vh = p.get("visual_hook")
    if vh and isinstance(vh, dict):
        report += f"""
━━━ {vh.get('verdict_emoji','⬜')} 6. ВИЗУАЛ ({vh.get('score',0):.0f}%) ━━━"""
        for det in vh.get("details", []):
            report += f"\n{det}"
    else:
        report += "\n⬜ 6. Визуал — не проверено"

    # 7. Экономика
    plan_name = p.get("unit_plan")
    if plan_name:
        plans = get_plans(message.from_user.id)
        plan = plans.get(plan_name, {})
        rent = plan.get("profitability", 0)
        profit = plan.get("net_profit", 0)
        max_cpl = plan.get("max_cpl_20", 0) or plan.get("max_cpl", 0)
        e = "🟢" if rent >= 20 else ("🟡" if rent >= 10 else "🔴")
        report += f"""
━━━ {e} 7. ЭКОНОМИКА ━━━
📋 План: {plan_name}
💰 Прибыль: {profit:.2f} BYN | Рент: {rent:.1f}% | CPL: ${max_cpl:.2f}"""
    else:
        report += "\n⬜ 7. Экономика — не привязана"

    # Итоговые рекомендации
    report += "\n\n━━━ 💡 РЕКОМЕНДАЦИИ ━━━"
    if ov["score"] >= 70:
        report += "\n🟢 Товар прошёл отбор — запускай!"
        report += "\n1. Закажи товар"
        report += "\n2. Сними крео"
        report += "\n3. Запусти тест на $10-20/день"
    elif ov["score"] >= 50:
        report += "\n🟡 Есть слабые места:"
        # Находим непройденные
        if not ah:
            report += "\n• Проверь AdHeart"
        elif ah.get("score", 0) < 50:
            report += "\n• AdHeart слабый — мало данных о конкурентах"
        if not tt:
            report += "\n• Проверь TikTok охват"
        elif tt.get("score", 0) < 50:
            report += "\n• TikTok охват слабый — мало вирусного контента"
        if wb and wb.get("score", 0) < 50:
            report += "\n• WB цены опасные — клиенты уйдут на маркетплейс!"
        if vh and isinstance(vh, dict) and vh.get("score", 0) < 50:
            report += "\n• Визуал слабый — нужно сильное крео"
    else:
        report += "\n🔴 Товар НЕ прошёл отбор"
        report += "\n• Ищи другой товар"
        report += "\n• Или исправь слабые критерии"

    report += f"""

━━━━━━━━━━━━━━━━━━━━
{ov['emoji']} <b>ИТОГ: {ov['verdict']}</b>
📊 Скоринг: <b>{ov['score']:.0f}%</b> | Проверено: {checks}/7
━━━━━━━━━━━━━━━━━━━━"""

    # Разбиваем если длинный
    if len(report) > 4096:
        parts = smart_split(report)
        for i, part in enumerate(parts):
            kb = main_kb() if i == len(parts) - 1 else None
            await message.answer(part, parse_mode="HTML", reply_markup=kb)
    else:
        await message.answer(report, parse_mode="HTML")

    # Кнопки после карточки
    buttons = [
        [KeyboardButton(text="📋 Проверить критерии")],
        [KeyboardButton(text="🔍 Отбор товара")],
        [KeyboardButton(text="🔙 Главное меню")]
    ]
    await message.answer("Что дальше?",
        reply_markup=ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True))
    await state.clear()


# ══════════════════════════════════════
# 📦 МОИ ТОВАРЫ
# ══════════════════════════════════════

@dp.message(F.text == "📦 Мои товары")
async def my_products_h(message: types.Message, state: FSMContext):
    await state.clear()
    products = get_products(message.from_user.id)

    if not products:
        await message.answer(
            "📦 <b>Мои товары</b>\n\nПусто.\nДобавь через «➕ Новый товар»",
            parse_mode="HTML", reply_markup=main_kb()
        )
        return

    text = "📦 <b>Мои товары</b>\n\n"
    for i, (name, p) in enumerate(products.items(), 1):
        checks = count_checks(p)
        ov = build_overall_verdict(p) if checks >= 3 else None
        emoji = ov["emoji"] if ov else "⏳"
        score_text = f"{ov['score']:.0f}%" if ov else "—"
        ws = int(p.get("ws_basic", 0))
        updated = p.get("updated", "—")

        text += f"{emoji} <b>{i}. {name}</b>\n"
        text += f"   📊 Скоринг: {score_text} | Проверено: {checks}/7\n"
        if ws > 0:
            text += f"   📈 Вордстат: {ws:,}\n"
        text += f"   📅 {updated}\n\n"

    text += f"Всего: {len(products)}"

    buttons = [
        [KeyboardButton(text="➕ Новый товар")],
        [KeyboardButton(text="📋 Проверить критерии")],
        [KeyboardButton(text="🗑 Удалить товар")],
        [KeyboardButton(text="🔙 Главное меню")]
    ]

    await message.answer(text, parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True))


