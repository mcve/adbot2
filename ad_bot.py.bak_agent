async def ask_plan_name(message, state):
    plans = get_plans(message.from_user.id)
    if plans:
        listing = "\n".join([f"  • {n}" for n in plans.keys()])
        extra = f"\n\n📋 Существующие планы:\n{listing}\n\n<i>Введи то же имя — перезапишется.</i>"
    else:
        extra = ""

    await message.answer(
        f"📝 <b>Название для сохранения</b>\n\n"
        f"Например: Кроссовки Nike, Пояс для спины{extra}",
        parse_mode="HTML", reply_markup=cancel_kb()
    )
    await state.set_state(UnitEcon.plan_name)


@dp.message(UnitEcon.plan_name)
async def unit_plan_name(message: types.Message, state: FSMContext):
    name = message.text.strip()
    if len(name) < 2:
        await message.answer("❌ Минимум 2 символа:")
        return
    if len(name) > 50:
        await message.answer("❌ Максимум 50 символов:")
        return
    await state.update_data(plan_name=name)
    await do_unit_calc(message, state)
    
async def do_unit_calc(message, state):
    try:
        d = await state.get_data()
        plan_name = d["plan_name"]
        report, plan_data = calculate_unit(d)
        save_plan(message.from_user.id, plan_name, plan_data)

        if len(report) <= 4096:
            await message.answer(report, parse_mode="HTML", reply_markup=main_kb())
        else:
            parts = smart_split(report)
            for i, p in enumerate(parts):
                kb = main_kb() if i == len(parts) - 1 else None
                await message.answer(p, parse_mode="HTML", reply_markup=kb)
    except Exception as e:
        logging.error(f"Calc error: {e}")
        await message.answer(
            f"❌ Ошибка расчёта:\n<code>{e}</code>",
            parse_mode="HTML", reply_markup=main_kb()
        )
    await state.clear()


def smart_split(text, limit=4096):
    parts = []
    while len(text) > limit:
        cut = text.rfind("\n", 0, limit)
        if cut == -1:
            cut = limit
        parts.append(text[:cut])
        text = text[cut:]
    parts.append(text)
    return parts


def _reverse_lead(max_client_cost, d):
    if max_client_cost <= 0:
        return 0
    max_lead_byn = max_client_cost * d["approval_pct"]
    if d["has_ad_tax"]:
        max_lead_byn = max_lead_byn / 1.20
    max_lead_byn = max_lead_byn / (1 + d["agent_commission_pct"])
    return max_lead_byn / d["usd_rate"]


def calculate_unit(d: dict):
    delivery = 0.5
    parcel_cost = 5.0

    # ЗАКУПКА
    purchase_byn = d["purchase_price_rub"] * d["rub_rate"]
    vat_amount = purchase_byn * 0.20 if d["has_import_vat"] else 0
    purchase_with_vat = purchase_byn + vat_amount
    purchase_total = purchase_with_vat + delivery

    # КРОССЕЙЛЫ
    cross_pct = d["cross_sell_pct"]
    units_sold = 1 + cross_pct
    cross_revenue = d["landing_price"] * cross_pct
    purchase_with_cross = purchase_total * units_sold

    # АПСЕЙЛЫ
    upsell_revenue = d["upsell_pct"] * d["upsell_amount"]

    # ВЫРУЧКА
    revenue_gross = d["landing_price"] + cross_revenue + upsell_revenue

    # ВЫКУП
    buyout = d["buyout_pct"]
    non_buyout = 1 - buyout
    revenue_after_buyout = revenue_gross * buyout
    returned_goods = purchase_with_cross * non_buyout
    effective_revenue = revenue_after_buyout + returned_goods

    # ПОКАТУШКИ
    return_shipping = parcel_cost * 1.5 * non_buyout

    # РЕКЛАМА
    lead_byn = d["lead_cost_usd"] * d["usd_rate"]
    lead_with_agent = lead_byn * (1 + d["agent_commission_pct"])
    ad_tax = lead_with_agent * 0.20 if d["has_ad_tax"] else 0
    lead_final = lead_with_agent + ad_tax
    client_cost = lead_final / d["approval_pct"]

    # ВОЗВРАТ НЕКАЧ
    defect_return = purchase_total * 0.015

    # ПРОЧИЕ
    cc = d["call_center_cost"]
    wh = d["warehouse_cost"]
    tgt = d.get("targetolog_cost", 0)

    # ЗАТРАТЫ
    costs_before_tax = (
        purchase_with_cross + return_shipping +
        client_cost + tgt + cc + wh + defect_return
    )

    # ПРИБЫЛЬ
    profit_before_tax = effective_revenue - costs_before_tax
    if d["has_profit_tax"] and profit_before_tax > 0:
        profit_tax = profit_before_tax * 0.20
    else:
        profit_tax = 0

    net_profit = profit_before_tax - profit_tax
    total_costs = costs_before_tax + profit_tax
    profitability = net_profit / total_costs if total_costs > 0 else 0

    # БЕЗУБЫТОЧНОСТЬ
    costs_no_ads = (
        purchase_with_cross + return_shipping +
        tgt + cc + wh + defect_return
    )

    max_costs_0 = effective_revenue
    max_cc_0 = max_costs_0 - costs_no_ads
    max_lead_0 = _reverse_lead(max_cc_0, d)

    # План CPL с мин. рентабельностью 20%
    if d["has_profit_tax"]:
        max_costs_20 = effective_revenue * 0.76 / 0.96
    else:
        max_costs_20 = effective_revenue / 1.20

    max_cc_20 = max_costs_20 - costs_no_ads
    max_lead_20 = _reverse_lead(max_cc_20, d) if max_cc_20 > 0 else 0

    if d["lead_cost_usd"] > 0 and max_lead_0 > 0:
        lead_margin = ((max_lead_0 / d["lead_cost_usd"]) - 1) * 100
    else:
        lead_margin = 0

    # БЕЗ ДОПОВ
    rev_no = d["landing_price"] * buyout + purchase_total * non_buyout
    cc_no = 1.0 if cc > 0 else 0
    costs_no = (
        purchase_total + return_shipping + client_cost +
        tgt + cc_no + wh + purchase_total * 0.015
    )
    pbt_no = rev_no - costs_no
    tax_no = pbt_no * 0.20 if d["has_profit_tax"] and pbt_no > 0 else 0
    np_no = pbt_no - tax_no
    tc_no = costs_no + tax_no
    rent_no = np_no / tc_no if tc_no > 0 else 0

    # СОВЕТЫ
    savings = []
    if d["approval_pct"] < 0.80:
        s = client_cost - lead_final / 0.80
        if s > 0.01:
            savings.append(("Поднять аппрув до 80%", s, "быстрый перезвон, скрипт"))
    if buyout < 0.95:
        r95 = revenue_gross * 0.95 + purchase_with_cross * 0.05
        ret95 = parcel_cost * 1.5 * 0.05
        s = (r95 - ret95) - (effective_revenue - return_shipping)
        if s > 0.01:
            savings.append(("Поднять выкуп до 95%", s, "СМС-дожим, звонки"))
    if cross_pct == 0:
        er = d["landing_price"] * 0.20 * buyout
        ec = purchase_total * 0.20
        s = er - ec
        if s > 0.01:
            savings.append(("Добавить кроссейлы (20%)", s, "доп. товар при звонке"))
    if d["upsell_pct"] == 0:
        s = 0.30 * 15 * buyout
        if s > 0.01:
            savings.append(("Добавить апсейлы (30%×15 BYN)", s, "набор подороже"))
    savings.sort(key=lambda x: x[1], reverse=True)

    # СТАТУС
    if profitability >= 0.25:
        se, st = "🟢", "ОТЛИЧНО"
    elif profitability >= 0.15:
        se, st = "🟡", "НОРМАЛЬНО"
    elif profitability > 0:
        se, st = "🟠", "НА ГРАНИ"
    else:
        se, st = "🔴", "УБЫТОК"

    tax_parts = []
    if d["has_import_vat"]:
        tax_parts.append("НДС 20%")
    if d["has_ad_tax"]:
        tax_parts.append("Нал.рекл. 20%")
    if d["has_profit_tax"]:
        tax_parts.append("Нал.приб. 20%")
    tax_mode = " + ".join(tax_parts) if tax_parts else "Без налогов"

    ag = d["agent_commission_pct"] * 100
    ap = d["approval_pct"] * 100
    
    # ═══ ФОРМИРУЕМ ОТЧЁТ ═══
    r = f"""{se} <b>ЮНИТ-ЭКОНОМИКА — {st}</b>

━━━ ⚙️ ДАННЫЕ ━━━

🏷 Цена на ленде: <b>{d['landing_price']:.2f} BYN</b>
📦 Закупка: {d['purchase_price_rub']:.0f}₽ × {d['rub_rate']:.4f} = {purchase_byn:.2f} BYN"""

    if vat_amount > 0:
        r += f"\n🏛 + НДС 20%: +{vat_amount:.2f} = {purchase_with_vat:.2f} BYN"

    r += f"""
🚚 + Доставка: {delivery:.2f} BYN
📦 <b>Закупка 1 ед.: {purchase_total:.2f} BYN</b>
💵 $1 = {d['usd_rate']:.4f} | ₽1 = {d['rub_rate']:.4f}
🏛 {tax_mode}

━━━ 💰 ВЫРУЧКА ━━━

Базовая: {d['landing_price']:.2f} BYN"""

    if cross_pct > 0:
        r += f"""
+ Кроссейлы ({cross_pct*100:.0f}%): +{cross_revenue:.2f} BYN
  <i>{cross_pct*100:.0f}% клиентов берут ещё 1 товар</i>"""

    if d["upsell_pct"] > 0:
        r += f"""
+ Апсейлы ({d['upsell_pct']*100:.0f}% × {d['upsell_amount']:.0f}): +{upsell_revenue:.2f} BYN
  <i>{d['upsell_pct']*100:.0f}% платят на {d['upsell_amount']:.0f} BYN больше</i>"""

    r += f"""

Выручка до выкупа: {revenue_gross:.2f} BYN
× выкуп {buyout*100:.0f}% = {revenue_after_buyout:.2f} BYN
+ возврат товара на склад: +{returned_goods:.2f} BYN
  <i>(невыкупленный товар вернётся)</i>
<b>= ВЫРУЧКА: {effective_revenue:.2f} BYN</b>

━━━ 📊 ЗАТРАТЫ ━━━

📦 <b>Закупка: {purchase_with_cross:.2f} BYN</b>"""

    if cross_pct > 0:
        r += f"\n   {purchase_total:.2f} × {units_sold:.2f} ед."

    r += f"""

📢 <b>Клиент: {client_cost:.2f} BYN</b>
   Лид ${d['lead_cost_usd']:.2f} × {d['usd_rate']:.4f} = {lead_byn:.2f} BYN"""

    if ag > 0:
        r += f"\n   + агент {ag:.0f}% = {lead_with_agent:.2f}"
    if ad_tax > 0:
        r += f"\n   + нал.рекл. 20% = {lead_final:.2f}"

    r += f"""
   ÷ аппрув {ap:.0f}% = <b>{client_cost:.2f} BYN</b>
   <i>Из 100 лидов {ap:.0f} покупают</i>"""

    if tgt > 0:
        r += f"\n\n🎯 <b>Таргетолог: {tgt:.2f} BYN</b>"
    if cc > 0:
        r += f"\n\n📞 <b>Колл-центр: {cc:.2f} BYN</b>"

    r += f"""

📮 <b>Почта/склад: {wh:.2f} BYN</b>

🔄 <b>Покатушки: {return_shipping:.2f} BYN</b>
   <i>5 BYN × 1.5 × {non_buyout*100:.0f}% невыкупа</i>

🔧 <b>Возврат некач.: {defect_return:.2f} BYN</b>
   <i>1.5% от закупки</i>"""

    if profit_tax > 0:
        r += f"""

📋 <b>Прибыль до налога: {profit_before_tax:.2f} BYN</b>
🏛 <b>Налог 20%: {profit_tax:.2f} BYN</b>"""

    r += f"""

━━━━━━━━━━━━━━━━━━━━
📊 <b>ИТОГО ЗАТРАТ: {total_costs:.2f} BYN</b>

━━━ ✅ РЕЗУЛЬТАТ ━━━

💵 Выручка: {effective_revenue:.2f} BYN
📊 Затраты: {total_costs:.2f} BYN
━━━━━━━━━━━━━━━━━━━━
💰 <b>ПРИБЫЛЬ: {net_profit:.2f} BYN</b>
📈 <b>РЕНТАБЕЛЬНОСТЬ: {profitability*100:.1f}%</b>
━━━━━━━━━━━━━━━━━━━━

━━━ 🎯 КОНТРОЛЬНЫЕ ТОЧКИ ━━━

🔴 <b>Безубыточность (0%)</b>
   Макс. лид: <b>${max_lead_0:.2f}</b>"""

    if lead_margin > 0:
        r += f" (запас {lead_margin:.0f}%)"
        r += f"\n   <i>Пока лид дешевле ${max_lead_0:.2f} — в плюсе</i>"
    else:
        r += "\n   ⚠️ Уже в убытке!"

    r += f"""

🟢 <b>Рентабельность 20%</b>
   Макс. лид: <b>${max_lead_20:.2f}</b>"""

    if d["lead_cost_usd"] <= max_lead_20:
        r += f"\n   ✅ Лид ${d['lead_cost_usd']:.2f} — проходишь!"
    else:
        r += f"\n   ❌ Нужно снизить на ${d['lead_cost_usd'] - max_lead_20:.2f}"

    if cross_pct > 0 or d["upsell_pct"] > 0:
        r += f"""

━━━ 📉 БЕЗ ДОПОВ ━━━
Прибыль: <b>{np_no:.2f} BYN</b> | Рент.: <b>{rent_no*100:.1f}%</b>
<i>Без апсейлов и кроссейлов</i>"""

    if savings:
        r += "\n\n━━━ 💡 ГДЕ СЭКОНОМИТЬ ━━━\n"
        for i, (name, save, hint) in enumerate(savings, 1):
            r += f"\n{i}. <b>{name}</b>"
            r += f"\n   +{save:.2f} BYN/заказ"
            r += f"\n   <i>{hint}</i>\n"
        total_save = sum(s[1] for s in savings)
        new_p = net_profit + total_save
        new_r = new_p / effective_revenue if effective_revenue > 0 else 0
        r += f"\n📊 Потенциал: <b>{new_p:.2f} BYN</b> ({new_r*100:.1f}%)"

    recs = []
    if profitability < 0:
        recs.append("🔴 Убыток — снижай лид или повышай цену")
    elif profitability < 0.15:
        recs.append("🟠 Маржа тонкая — попробуй +5-10 BYN к цене")
    if 0 < lead_margin < 30:
        recs.append("⚠️ Запас по лиду мал — любой скачок съест прибыль")
    if recs:
        r += "\n\n━━━ ⚠️ ВАЖНО ━━━\n\n" + "\n".join(recs)

    plan_name = d["plan_name"]
    r += f"""

💾 Сохранено как: «{plan_name}»
<i>🔄 За месяц можно обернуть 2-3 раза</i>"""

    # Данные для сохранения
    plan_data = {
        "landing_price": d["landing_price"],
        "purchase_rub": d["purchase_price_rub"],
        "purchase_byn": round(purchase_byn, 2),
        "purchase_total": round(purchase_total, 2),
        "usd_rate": d["usd_rate"],
        "rub_rate": d["rub_rate"],
        "has_import_vat": d["has_import_vat"],
        "has_ad_tax": d["has_ad_tax"],
        "has_profit_tax": d["has_profit_tax"],
        "cross_sell_pct": d["cross_sell_pct"],
        "upsell_pct": d["upsell_pct"],
        "upsell_amount": d.get("upsell_amount", 0),
        "buyout_pct": d["buyout_pct"] * 100,
        "lead_cost_usd": d["lead_cost_usd"],
        "agent_pct": d["agent_commission_pct"],
        "approve_pct": d["approval_pct"] * 100,
        "call_center": d["call_center_cost"],
        "warehouse": d["warehouse_cost"],
        "targetolog": d.get("targetolog_cost", 0),
        "net_profit": round(net_profit, 2),
        "profitability": round(profitability * 100, 1),
        "profit_per_buyout": round(net_profit, 2),
        "max_cpl_0_byn": round(max_lead_0 * d["usd_rate"], 2),   # безубыток BYN
        "max_cpl_0": round(max_lead_0, 2),                         # безубыток USD
        "max_cpl_20_byn": round(max_lead_20 * d["usd_rate"], 2),  # рент 20% BYN
        "max_cpl_20": round(max_lead_20, 2),                       # рент 20% USD
        "max_cpl_byn": round(max_lead_20 * d["usd_rate"], 2),     # основной план = рент 20%
        "max_cpl": round(max_lead_20, 2),                          # основной план = рент 20%
        "total_costs": round(total_costs, 2),
        "effective_revenue": round(effective_revenue, 2),
        "created": datetime.now().strftime("%d.%m.%Y %H:%M"),
    }

    return r, plan_data

# ══════════════════════════════════════
# АНАЛИЗ СВЯЗКИ
# ══════════════════════════════════════

@dp.message(F.text == "📈 Анализ связки")
async def analyze_start(message: types.Message, state: FSMContext):
    await state.clear()
    plans = get_plans(message.from_user.id)

    if plans:
        buttons = []
        for name in plans.keys():
            buttons.append([KeyboardButton(text=f"📋 {name}")])
        buttons.append([KeyboardButton(text="🔄 Без привязки к плану")])
        buttons.append([KeyboardButton(text="❌ Отмена")])
        kb = ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True)
        await message.answer(
            "📈 <b>Анализ связки</b>\n\n"
            "Привязать к юнит-экономике?\n"
            "Выбери план или анализируй без него:",
            parse_mode="HTML",
            reply_markup=kb
        )
        await state.set_state(Analyze.choose_plan)
    else:
        await state.update_data(linked_plan=None, plan_data=None)
        await message.answer(
            "📈 <b>Анализ связки</b>\n\n"
            "📋 У тебя пока нет планов. Анализируем без привязки.\n\n"
            "🌐 Выбери рекламную платформу:",
            parse_mode="HTML",
            reply_markup=platform_kb()
        )
        await state.set_state(Analyze.platform)

@dp.message(Analyze.choose_plan)
async def analyze_choose_plan(message: types.Message, state: FSMContext):
    text = message.text.strip()

    if "без привязки" in text.lower() or "🔄" in text:
        await state.update_data(linked_plan=None, plan_data=None)
    elif text.startswith("📋 "):
        plan_name = text[2:].strip()
        plans = get_plans(message.from_user.id)
        if plan_name not in plans:
            await message.answer("❌ План не найден. Выбери из списка:")
            return
        await state.update_data(linked_plan=plan_name, plan_data=plans[plan_name])
    else:
        await message.answer("❌ Выбери из списка или нажми «Без привязки»:")
        return

    await message.answer("🌐 Выбери рекламную платформу:", reply_markup=platform_kb())
    await state.set_state(Analyze.platform)

@dp.message(Analyze.platform)
async def analyze_platform(message: types.Message, state: FSMContext):
    p = parse_platform(message.text)
    if not p:
        await message.answer("❌ Выбери платформу кнопкой:")
        return
    await state.update_data(platform=p)
    await message.answer(
        f"✅ {PLATFORMS[p]['emoji']} {PLATFORMS[p]['name']}\n\n"
        f"📅 За какой период анализируем?\n"
        f"(откройте кабинет TikTok/FB и выберите такой же период)",
        reply_markup=period_kb()
    )
    await state.set_state(Analyze.period)

@dp.message(Analyze.period)
async def analyze_period(message: types.Message, state: FSMContext):
    text = message.text.strip().lower()

    periods = {
        "сегодня": "today",
        "вчера": "yesterday",
        "7 дней": "7days",
        "за всё время": "lifetime",
    }

    period = None
    for key, value in periods.items():
        if key in text:
            period = value
            break

    if not period:
        await message.answer("❌ Выбери период кнопкой:")
        return

    period_names = {
        "today": "📅 Сегодня",
        "yesterday": "📅 Вчера",
        "7days": "📅 Последние 7 дней",
        "lifetime": "📅 За всё время",
    }

    await state.update_data(period=period, period_name=period_names[period])
    await message.answer(
        f"✅ Период: {period_names[period]}\n\n"
        f"💰 Дневной бюджет ($):",
        reply_markup=cancel_kb()
    )
    await state.set_state(Analyze.budget)

@dp.message(Analyze.budget)
async def analyze_budget(message: types.Message, state: FSMContext):
    v = pn(message.text)
    if v is None or v <= 0:
        await message.answer("❌ Введи число больше 0:")
        return
    await state.update_data(budget=v)
    await message.answer(
        "🎯 Тип ставки:",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="🤖 Автоставка"), KeyboardButton(text="✋ Ручная ставка")],
            [KeyboardButton(text="❌ Отмена")]
        ], resize_keyboard=True)
    )
    await state.set_state(Analyze.bid_type)

@dp.message(Analyze.bid_type)
async def analyze_bid_type(message: types.Message, state: FSMContext):
    t = message.text.lower()
    if "авто" in t or "🤖" in t:
        await state.update_data(bid_type="auto", bid_value=None)
        await message.answer("⏰ Сколько часов крутится реклама?", reply_markup=cancel_kb())
        await state.set_state(Analyze.hours)
    elif "ручн" in t or "✋" in t:
        await state.update_data(bid_type="manual")
        await message.answer("💵 Ставка ($):", reply_markup=cancel_kb())
        await state.set_state(Analyze.bid_value)
    else:
        await message.answer("❌ Выбери кнопкой: Автоставка или Ручная:")
        return

@dp.message(Analyze.bid_value)
async def analyze_bid_value(message: types.Message, state: FSMContext):
    v = pn(message.text)
    if v is None or v <= 0:
        await message.answer("❌ Введи ставку числом больше 0:")
        return
    await state.update_data(bid_value=v)
    await message.answer("⏰ Сколько часов крутится реклама?", reply_markup=cancel_kb())
    await state.set_state(Analyze.hours)

@dp.message(Analyze.hours)
async def analyze_hours(message: types.Message, state: FSMContext):
    v = pn(message.text)
    if v is None or v <= 0 or v > 24:
        await message.answer("❌ Введи число от 0.5 до 24:")
        return
    await state.update_data(hours=v)
    await message.answer("💵 Текущий расход/спенд ($):", reply_markup=cancel_kb())
    await state.set_state(Analyze.spend)

@dp.message(Analyze.spend)
async def analyze_spend(message: types.Message, state: FSMContext):
    v = pn(message.text)
    if v is None or v < 0:
        await message.answer("❌ Введи число (0 если ещё нет расхода):")
        return
    await state.update_data(spend=v)
    await message.answer("👁 Количество показов (Impressions):", reply_markup=cancel_kb())
    await state.set_state(Analyze.impressions)

@dp.message(Analyze.impressions)
async def analyze_impressions(message: types.Message, state: FSMContext):
    v = pn_int(message.text)
    if v is None or v < 0:
        await message.answer("❌ Введи целое число:")
        return
    await state.update_data(impressions=v)
    await message.answer("🖱 Количество кликов (Link Clicks):", reply_markup=cancel_kb())
    await state.set_state(Analyze.clicks)

@dp.message(Analyze.clicks)
async def analyze_clicks(message: types.Message, state: FSMContext):
    v = pn_int(message.text)
    if v is None or v < 0:
        await message.answer("❌ Введи целое число:")
        return
    await state.update_data(clicks=v)
    await message.answer("📝 Количество лидов (заявок):", reply_markup=cancel_kb())
    await state.set_state(Analyze.leads)

@dp.message(Analyze.leads)
async def analyze_leads(message: types.Message, state: FSMContext):
    v = pn_int(message.text)
    if v is None or v < 0:
        await message.answer("❌ Введи целое число:")
        return
    await state.update_data(leads=v)

    if v > 0:
        await message.answer("✅ Есть подтверждённые лиды?", reply_markup=yes_no_kb())
        await state.set_state(Analyze.has_confirmed)
    else:
        await state.update_data(has_confirmed=False, confirmed=0)
        await message.answer("🔄 Частота (Frequency) — из кабинета:", reply_markup=cancel_kb())
        await state.set_state(Analyze.frequency)

@dp.message(Analyze.has_confirmed)
async def analyze_has_confirmed(message: types.Message, state: FSMContext):
    v = pyn(message.text)
    if v is None:
        await message.answer("❌ Нажми Да или Нет:")
        return
    if v:
        await state.update_data(has_confirmed=True)
        await message.answer("✅ Сколько подтверждённых лидов?", reply_markup=cancel_kb())
        await state.set_state(Analyze.confirmed)
    else:
        await state.update_data(has_confirmed=False, confirmed=0)
        await message.answer("🔄 Частота (Frequency) — из кабинета:", reply_markup=cancel_kb())
        await state.set_state(Analyze.frequency)

@dp.message(Analyze.confirmed)
async def analyze_confirmed(message: types.Message, state: FSMContext):
    v = pn_int(message.text)
    if v is None or v < 0:
        await message.answer("❌ Введи целое число:")
        return
    d = await state.get_data()
    if v > d["leads"]:
        await message.answer(f"❌ Подтверждённых ({v}) не может быть больше лидов ({d['leads']}):")
        return
    await state.update_data(confirmed=v)
    await message.answer("🔄 Частота (Frequency) — из кабинета:", reply_markup=cancel_kb())
    await state.set_state(Analyze.frequency)

@dp.message(Analyze.frequency)
async def analyze_frequency(message: types.Message, state: FSMContext):
    v = pn(message.text)
    if v is None or v < 0:
        await message.answer("❌ Введи число (например 1.3):")
        return
    await state.update_data(frequency=v)

    # Спрашиваем название связки
    await message.answer(
        "📝 Название связки:\n"
        "(например: Nike FB крео#3, TT тест пояс)\n\n"
        "Или нажми «Без названия»:",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="📎 Без названия")],
            [KeyboardButton(text="❌ Отмена")]
        ], resize_keyboard=True)
    )
    await state.set_state(Analyze.bundle_name)

@dp.message(Analyze.bundle_name)
async def analyze_bundle_name(message: types.Message, state: FSMContext):
    text = message.text.strip()

    if "без названия" in text.lower() or "📎" in text:
        name = None
    else:
        if len(text) < 2:
            await message.answer("❌ Минимум 2 символа:")
            return
        if len(text) > 50:
            await message.answer("❌ Максимум 50 символов:")
            return
        name = text

    await state.update_data(bundle_name=name)

    # ГЕНЕРАЦИЯ ОТЧЁТА
    d = await state.get_data()
    report, bundle_data = await build_report(d)

    await message.answer(report, parse_mode="HTML", reply_markup=main_kb())

    # Сохраняем если есть название
    if name:
        save_bundle(message.from_user.id, name, bundle_data)
        await message.answer(f"💾 Связка сохранена как: «{name}»", reply_markup=main_kb())
    else:
        # Предлагаем сохранить
        await state.update_data(bundle_data=bundle_data)
        await message.answer(
            "💾 Сохранить связку?",
            reply_markup=yes_no_kb()
        )
        await state.set_state(Analyze.save_bundle)
        return

    await state.clear()

@dp.message(Analyze.save_bundle)
async def analyze_save_bundle(message: types.Message, state: FSMContext):
    v = pyn(message.text)
    if v is None:
        await message.answer("❌ Нажми Да или Нет:")
        return
    if v:
        d = await state.get_data()
        ts = datetime.now().strftime("%d.%m %H:%M")
        p = d.get("platform", "uni")
        name = f"{PLATFORMS[p]['emoji']} Связка {ts}"
        save_bundle(message.from_user.id, name, d["bundle_data"])
        await message.answer(f"💾 Сохранено как: «{name}»", reply_markup=main_kb())
    else:
        await message.answer("👌 Не сохраняем.", reply_markup=main_kb())
    await state.clear()

# ══════════════════════════════════════
# ГЕНЕРАЦИЯ ОТЧЁТА
# ══════════════════════════════════════

async def build_report(d):
    p = d.get("platform", "uni")
    period_name = d.get("period_name", "📅 Не указан")   # ← НОВОЕ
    budget = d["budget"]
    bid_type = d["bid_type"]
    bid_value = d.get("bid_value")
    hours = d["hours"]
    spend = d["spend"]
    impressions = d["impressions"]
    clicks = d["clicks"]
    leads = d["leads"]
    confirmed = d.get("confirmed", 0)
    freq = d["frequency"]
    linked_plan = d.get("linked_plan")
    plan_data = d.get("plan_data")

    pf = PLATFORMS[p]
    min_imp = pf["min_imp"]
    enough = impressions >= min_imp

    # Расчёт метрик
    ctr = (clicks / impressions * 100) if impressions > 0 else 0
    cpc = (spend / clicks) if clicks > 0 else 0
    cpm = (spend / impressions * 1000) if impressions > 0 else 0
    cr = (leads / clicks * 100) if clicks > 0 else 0
    cpl = (spend / leads) if leads > 0 else 0
    cpo = (spend / confirmed) if confirmed > 0 else 0
    approve_rate = (confirmed / leads * 100) if leads > 0 else 0

    # Темп открутки
    expected_spend = (budget / 24) * hours
    pace = (spend / expected_spend * 100) if expected_spend > 0 else 0

    # Оценки метрик
    if enough:
        ctr_e, ctr_t = rate_higher_better(ctr, "ctr", p)
        cpm_e, cpm_t = rate_lower_better(cpm, "cpm", p)
        cpc_e, cpc_t = rate_lower_better(cpc, "cpc", p)
        cr_e, cr_t = rate_higher_better(cr, "cr", p) if clicks > 0 else ("⏳", "нет кликов")
    else:
        ctr_e = cpm_e = cpc_e = cr_e = "⏳"
        ctr_t = cpm_t = cpc_t = cr_t = "мало данных"

    freq_e, freq_t = rate_freq(freq) if freq > 0 else ("⏳", "нет данных")

    # Темп оценка
    if pace < 50:
        pace_e, pace_t = "🔴", "недокрут"
    elif pace < 80:
        pace_e, pace_t = "🟡", "слабый темп"
    elif pace <= 120:
        pace_e, pace_t = "🟢", "норма"
    else:
        pace_e, pace_t = "🟡", "перекрут"

    # ═══ СОВЕТЫ ═══
    tips = []

    if enough:
        if ctr < NORMS[p]["ctr"][0]:
            tips.append("🔸 Низкий CTR — тестируй новые крео/заголовки")
        if cpm > NORMS[p]["cpm"][1]:
            tips.append("🔸 Дорогой CPM — сузь аудиторию или смени плейсмент")
        if cpc > NORMS[p]["cpc"][1]:
            tips.append("🔸 Дорогой CPC — улучши релевантность объявления")
        if clicks > 10 and cr < NORMS[p]["cr"][0]:
            tips.append("🔸 Низкий CR — проверь лендинг/оффер")

    if freq > 3.0:
        tips.append("🔸 Высокая частота — аудитория выгорела, расширь таргет")
    elif freq > 2.0:
        tips.append("🔸 Частота растёт — следи за выгоранием")

    if pace < 50:
        tips.append("🔸 Слабый темп — подними ставку или расширь аудиторию")
    elif pace > 120:
        tips.append("🔸 Перекрут — можно снизить ставку")

    if linked_plan and plan_data and leads > 0:
        tip_cpl_0 = plan_data.get("max_cpl_0", 0) or plan_data.get("max_cpl", 0) or 0
        if tip_cpl_0 > 0 and cpl > tip_cpl_0:
            tips.append("🔸 CPL выше безубытка — связка убыточна!")

    # ═══ ВЕРДИКТ ═══
    reds = sum(1 for x in [ctr_e, cpm_e, cpc_e, cr_e, freq_e, pace_e] if x == "🔴")
    greens = sum(1 for x in [ctr_e, cpm_e, cpc_e, cr_e, freq_e, pace_e] if x == "🟢")

    if not enough:
        verdict = "⏳ МАЛО ДАННЫХ — подожди набора статистики"
        verdict_e = "⏳"
    elif reds >= 3:
        verdict = "🔴 ВЫКЛЮЧАЙ — связка не работает"
        verdict_e = "🔴"
    elif reds >= 2:
        verdict = "🟡 ПРОБЛЕМЫ — нужны изменения"
        verdict_e = "🟡"
    elif greens >= 4:
        verdict = "🟢 РАБОТАЕТ — масштабируй"
        verdict_e = "🟢"
    else:
        verdict = "🟡 НАБЛЮДАЙ — пока норм, но следи"
        verdict_e = "🟡"

    # ═══ ФОРМИРУЕМ ОТЧЁТ ═══
    report = f"""📈 <b>АНАЛИЗ СВЯЗКИ</b>
{pf['emoji']} {pf['name']}
{period_name}

━━━ ⚙️ НАСТРОЙКИ ━━━
💰 Бюджет:       ${budget:.2f}
🎯 Ставка:       {"авто" if bid_type == "auto" else f"${bid_value:.2f}"}
⏰ Часов:         {hours:.1f}

━━━ 📊 СЫРЫЕ ДАННЫЕ ━━━
💵 Расход:        ${spend:.2f}
👁 Показы:        {impressions:,}
🖱 Клики:         {clicks:,}
📝 Лиды:          {leads}
✅ Подтв:         {confirmed}
🔄 Частота:       {freq:.2f}

━━━ 📐 МЕТРИКИ ━━━
{ctr_e} CTR:          {ctr:.2f}% — {ctr_t}
{cpm_e} CPM:          ${cpm:.2f} — {cpm_t}
{cpc_e} CPC:          ${cpc:.2f} — {cpc_t}
{cr_e} CR:           {cr:.2f}% — {cr_t}"""

    if leads > 0:
        report += f"\n💰 CPL:          ${cpl:.2f}"
    if confirmed > 0:
        report += f"\n💰 CPO:          ${cpo:.2f}"
        report += f"\n📊 Аппрув:       {approve_rate:.1f}%"

    report += f"""

━━━ ⏱ ТЕМП ━━━
{pace_e} {pace:.0f}% — {pace_t}
Ожидание: ${expected_spend:.2f} | Факт: ${spend:.2f}"""

    # Привязка к плану
    if linked_plan and plan_data:
        max_cpl_20 = plan_data.get("max_cpl_20", 0) or plan_data.get("max_cpl", 0) or 0
        max_cpl_0 = plan_data.get("max_cpl_0", 0) or plan_data.get("max_cpl", 0) or 0
        profit_buyout = plan_data.get("profit_per_buyout", 0)

        report += f"""

━━━ 📋 ПЛАН: {linked_plan} ━━━
🎯 План CPL:     ${max_cpl_20:.2f} (рент. 20%)
⚠️ Безубыток:    ${max_cpl_0:.2f}
💰 Прибыль/выкуп: {profit_buyout:.2f} BYN"""

        if leads > 0 and max_cpl_20 > 0:
            if cpl <= max_cpl_20:
                report += f"\n🟢 CPL ${cpl:.2f} ≤ план ${max_cpl_20:.2f} — ПРИБЫЛЬ 20%+"
            elif cpl <= max_cpl_0:
                report += f"\n🟡 CPL ${cpl:.2f} ≤ безуб. ${max_cpl_0:.2f} — низкая рент."
            else:
                report += f"\n🔴 CPL ${cpl:.2f} > безуб. ${max_cpl_0:.2f} — УБЫТОК"

    # Советы
    if tips:
        report += "\n\n━━━ 💡 СОВЕТЫ ━━━"
        for tip in tips:
            report += f"\n{tip}"

    # Вердикт
    report += f"""

━━━━━━━━━━━━━━━━━━━
{verdict_e} <b>ВЕРДИКТ: {verdict}</b>
━━━━━━━━━━━━━━━━━━━"""

    # Данные для сохранения
    bundle_data = {
        "platform": p,
        "period": d.get("period", "unknown"),       # ← НОВОЕ
        "period_name": period_name,                   # ← НОВОЕ
        "linked_plan": linked_plan,
        "budget": budget,
        "bid_type": bid_type,
        "bid_value": bid_value,
        "hours": hours,
        "spend": spend,
        "impressions": impressions,
        "clicks": clicks,
        "leads": leads,
        "confirmed": confirmed,
        "frequency": freq,
        "ctr": round(ctr, 2),
        "cpm": round(cpm, 2),
        "cpc": round(cpc, 2),
        "cr": round(cr, 2),
        "cpl": round(cpl, 2) if leads > 0 else None,
        "verdict": verdict,
        "verdict_emoji": verdict_e,
    }

    return report, bundle_data

def build_delta(old, new):
    """Сравнивает старые и новые данные связки"""
    if not old or not old.get("spend"):
        return None

    o_spend = old.get("spend", 0)
    n_spend = new.get("spend", 0)
    o_imp = old.get("impressions", 0)
    n_imp = new.get("impressions", 0)
    o_clicks = old.get("clicks", 0)
    n_clicks = new.get("clicks", 0)
    o_leads = old.get("leads", 0)
    n_leads = new.get("leads", 0)
    o_conf = old.get("confirmed", 0)
    n_conf = new.get("confirmed", 0)

    d_spend = n_spend - o_spend
    d_imp = n_imp - o_imp
    d_clicks = n_clicks - o_clicks
    d_leads = n_leads - o_leads
    d_conf = n_conf - o_conf

    # Метрики за период
    p_ctr = (d_clicks / d_imp * 100) if d_imp > 0 else 0
    p_cpc = (d_spend / d_clicks) if d_clicks > 0 else 0
    p_cpm = (d_spend / d_imp * 1000) if d_imp > 0 else 0
    p_cr = (d_leads / d_clicks * 100) if d_clicks > 0 else 0
    p_cpl = (d_spend / d_leads) if d_leads > 0 else 0

    # Старые метрики
    o_ctr = old.get("ctr", 0)
    o_cpc = old.get("cpc", 0)
    o_cpm = old.get("cpm", 0)
    o_cr = old.get("cr", 0)
    o_cpl = old.get("cpl", 0) or 0

    # Новые общие
    n_ctr = new.get("ctr", 0)
    n_cpc = new.get("cpc", 0)
    n_cpm = new.get("cpm", 0)
    n_cr = new.get("cr", 0)
    n_cpl = new.get("cpl", 0) or 0

    old_date = old.get("date", "?")

    r = f"""📊 <b>ДИНАМИКА</b>
<i>Сравнение с {old_date}</i>

━━━ 🆕 ЗА ПЕРИОД ━━━
💵 +${d_spend:.2f} | 👁 +{d_imp:,} | 🖱 +{d_clicks}
📝 +{d_leads} лидов | ✅ +{d_conf} подтв."""

    if d_imp > 0:
        r += f"""

📐 Метрики за период:
   CTR: {p_ctr:.2f}% | CPC: ${p_cpc:.2f}
   CPM: ${p_cpm:.2f}"""
        if d_leads > 0:
            r += f" | CPL: ${p_cpl:.2f}"

    # Стрелки динамики
    r += "\n\n━━━ 📈 ТРЕНДЫ ━━━"

    def arrow(old_v, new_v, lower_better=False):
        if old_v == 0:
            return "🆕"
        diff_pct = ((new_v - old_v) / old_v) * 100
        if abs(diff_pct) < 1:
            return f"➡️ {diff_pct:+.1f}%"
        if lower_better:
            if diff_pct < -5:
                return f"🟢 {diff_pct:+.1f}%"
            elif diff_pct > 5:
                return f"🔴 {diff_pct:+.1f}%"
            else:
                return f"🟡 {diff_pct:+.1f}%"
        else:
            if diff_pct > 5:
                return f"🟢 {diff_pct:+.1f}%"
            elif diff_pct < -5:
                return f"🔴 {diff_pct:+.1f}%"
            else:
                return f"🟡 {diff_pct:+.1f}%"

    r += f"""
CTR: {o_ctr:.2f}% → {n_ctr:.2f}%  {arrow(o_ctr, n_ctr)}
CPC: ${o_cpc:.2f} → ${n_cpc:.2f}  {arrow(o_cpc, n_cpc, True)}
CPM: ${o_cpm:.2f} → ${n_cpm:.2f}  {arrow(o_cpm, n_cpm, True)}"""

    if o_cr > 0 or n_cr > 0:
        r += f"""
CR:  {o_cr:.2f}% → {n_cr:.2f}%  {arrow(o_cr, n_cr)}"""

    if o_cpl > 0 and n_cpl > 0:
        r += f"""
CPL: ${o_cpl:.2f} → ${n_cpl:.2f}  {arrow(o_cpl, n_cpl, True)}"""

    # Рекомендации по динамике
    tips = []

    # Минимальные пороги для рекомендаций
    min_imp_for_tips = PLATFORMS.get(new.get("platform", "uni"), {}).get("min_imp", 500)
    enough_data = n_imp >= min_imp_for_tips
    enough_period = d_imp >= 200  # минимум 200 новых показов за период

    if enough_data and enough_period:
        if n_cpl > 0 and o_cpl > 0:
            cpl_change = ((n_cpl - o_cpl) / o_cpl) * 100
            if cpl_change > 20:
                tips.append("⚠️ CPL вырос на {:.0f}% — связка дорожает".format(cpl_change))
            elif cpl_change < -15:
                tips.append("✅ CPL снизился на {:.0f}% — связка улучшается!".format(abs(cpl_change)))

        if n_ctr > 0 and o_ctr > 0:
            ctr_change = ((n_ctr - o_ctr) / o_ctr) * 100
            if ctr_change < -20:
                tips.append("⚠️ CTR падает — крео выгорает, тестируй новые")
            elif ctr_change > 20:
                tips.append("✅ CTR растёт — крео заходит!")

        o_freq = old.get("frequency", 0)
        n_freq = new.get("frequency", 0)
        if n_freq > o_freq + 0.5 and n_freq > 2.5:
            tips.append("⚠️ Частота растёт — аудитория выгорает")

        if tips:
            r += "\n\n━━━ 💡 ПО ДИНАМИКЕ ━━━"
            for tip in tips:
                r += f"\n{tip}"
    else:
        not_enough = max(0, min_imp_for_tips - n_imp)
        r += f"\n\n⏳ Мало данных для выводов по динамике"
        if not_enough > 0:
            r += f"\nНужно ещё ~{not_enough} показов"

    # История обновлений
    history = old.get("history", [])
    total_updates = len(history) + 1
    r += f"\n\n📊 Обновлений: {total_updates}"

    return r
# ══════════════════════════════════════
# МОИ ПЛАНЫ
# ══════════════════════════════════════

@dp.message(F.text == "📋 Мои планы")
async def my_plans(message: types.Message, state: FSMContext):
    await state.clear()
    plans = get_plans(message.from_user.id)

    if not plans:
        await message.answer(
            "📋 <b>Мои планы</b>\n\n"
            "У тебя пока нет сохранённых планов.\n"
            "Создай через «📊 Юнит-экономика»",
            parse_mode="HTML",
            reply_markup=main_kb()
        )
        return

    text = "📋 <b>Мои планы</b>\n\n"
    bundles = get_bundles(message.from_user.id)

    for i, (name, p) in enumerate(plans.items(), 1):
        profit = p.get("profit_per_buyout", 0)
        max_cpl = p.get("max_cpl_20", 0) or p.get("max_cpl", 0) or 0
        max_cpl_0 = p.get("max_cpl_0", 0) or p.get("max_cpl", 0) or 0
        created = p.get("created", "—")
        approve = p.get("approve_pct", 0)
        buyout = p.get("buyout_pct", 0)

        # Считаем связки привязанные к этому плану
        linked = sum(1 for b in bundles.values() if b.get("linked_plan") == name)

        text += f"{i}️⃣ <b>{name}</b>\n"
        text += f"   💰 Прибыль: {profit:.2f} BYN/выкуп\n"
        text += f"   🎯 План CPL: ${max_cpl:.2f} | Безуб: ${max_cpl_0:.2f}\n"
        text += f"   📊 Аппрув: {approve:.0f}% | Выкуп: {buyout:.0f}%\n"
        text += f"   📎 Связок: {linked}\n"
        text += f"   📅 {created}\n\n"

    text += f"Всего планов: {len(plans)}"

    buttons = [[KeyboardButton(text="🗑 Удалить план")]]
    buttons.append([KeyboardButton(text="📊 Юнит-экономика")])
    buttons.append([KeyboardButton(text="🔙 Главное меню")])
    kb = ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True)

    await message.answer(text, parse_mode="HTML", reply_markup=kb)

# ══════════════════════════════════════
# УДАЛЕНИЕ ПЛАНА
# ══════════════════════════════════════

@dp.message(F.text == "🗑 Удалить план")
async def delete_plan_start(message: types.Message, state: FSMContext):
    await state.clear()
    plans = get_plans(message.from_user.id)

    if not plans:
        await message.answer("📋 Нет планов для удаления.", reply_markup=main_kb())
        return

    buttons = []
    for name in plans.keys():
        buttons.append([KeyboardButton(text=f"🗑 {name}")])
    buttons.append([KeyboardButton(text="❌ Отмена")])
    kb = ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True)

    await message.answer(
        "🗑 <b>Удалить план</b>\n\n"
        "Выбери план для удаления:\n"
        "⚠️ Связки привязанные к плану НЕ удалятся",
        parse_mode="HTML",
        reply_markup=kb
    )
    await state.set_state(DeletePlan.choose)

@dp.message(DeletePlan.choose)
async def delete_plan_confirm(message: types.Message, state: FSMContext):
    text = message.text.strip()

    if not text.startswith("🗑 "):
        await message.answer("❌ Выбери план из списка или нажми Отмена:")
        return

    name = text[2:].strip()
    plans = get_plans(message.from_user.id)

    if name not in plans:
        await message.answer("❌ План не найден. Выбери из списка:")
        return

    # Удаляем
    result = delete_plan(message.from_user.id, name)

    if result:
        await message.answer(
            f"✅ План «{name}» удалён!",
            reply_markup=main_kb()
        )
    else:
        await message.answer("❌ Ошибка удаления.", reply_markup=main_kb())

    await state.clear()

# ══════════════════════════════════════
# МОИ СВЯЗКИ
# ══════════════════════════════════════

@dp.message(F.text == "📎 Мои связки")
async def my_bundles(message: types.Message, state: FSMContext):
    await state.clear()
    bundles = get_bundles(message.from_user.id)

    if not bundles:
        await message.answer(
            "📎 <b>Мои связки</b>\n\n"
            "У тебя пока нет сохранённых связок.\n"
            "Создай через «📈 Анализ связки»",
            parse_mode="HTML",
            reply_markup=main_kb()
        )
        return

    text = "📎 <b>Мои связки</b>\n\n"

    for i, (name, b) in enumerate(bundles.items(), 1):
        p = b.get("platform", "uni")
        pf = PLATFORMS.get(p, PLATFORMS["uni"])
        verdict_e = b.get("verdict_emoji", "⏳")
        date = b.get("date", "—")
        spend = b.get("spend", 0)
        leads = b.get("leads", 0)
        cpl = b.get("cpl")
        ctr = b.get("ctr", 0)
        linked = b.get("linked_plan")

        text += f"{i}️⃣ {verdict_e} <b>{name}</b>\n"
        text += f"   {pf['emoji']} {pf['name']}\n"
        text += f"   💵 ${spend:.2f} | 📝 {leads} лидов"

        if cpl and cpl > 0:
            text += f" | CPL ${cpl:.2f}"

        text += f"\n   📊 CTR {ctr:.2f}%"

        if linked:
            text += f"\n   📋 План: {linked}"
        else:
            text += f"\n   📋 Без плана"

        text += f"\n   📅 {date}\n\n"

    text += f"Всего связок: {len(bundles)}"

    # Если текст слишком длинный — разбиваем
    if len(text) > 4000:
        parts = []
        current = "📎 <b>Мои связки</b>\n\n"
        for i, (name, b) in enumerate(bundles.items(), 1):
            p = b.get("platform", "uni")
            pf = PLATFORMS.get(p, PLATFORMS["uni"])
            verdict_e = b.get("verdict_emoji", "⏳")
            date = b.get("date", "—")
            spend = b.get("spend", 0)
            leads = b.get("leads", 0)
            cpl = b.get("cpl")
            linked = b.get("linked_plan")

            chunk = f"{i}️⃣ {verdict_e} <b>{name}</b>\n"
            chunk += f"   {pf['emoji']} | 💵 ${spend:.2f} | 📝 {leads}"
            if cpl and cpl > 0:
                chunk += f" | CPL ${cpl:.2f}"
            if linked:
                chunk += f"\n   📋 {linked}"
            chunk += f"\n   📅 {date}\n\n"

            if len(current) + len(chunk) > 3900:
                parts.append(current)
                current = ""
            current += chunk

        if current:
            parts.append(current)

        for part in parts:
            await message.answer(part, parse_mode="HTML")
    else:
        await message.answer(text, parse_mode="HTML")

    buttons = [[KeyboardButton(text="🔄 Обновить связку")]]
    buttons.append([KeyboardButton(text="🗑 Удалить связку")])
    buttons.append([KeyboardButton(text="📈 Анализ связки")])
    buttons.append([KeyboardButton(text="🔙 Главное меню")])
    kb = ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True)

    await message.answer("Выбери действие:", reply_markup=kb)

# ══════════════════════════════════════
# УДАЛЕНИЕ СВЯЗКИ
# ══════════════════════════════════════

@dp.message(F.text == "🗑 Удалить связку")
async def delete_bundle_start(message: types.Message, state: FSMContext):
    await state.clear()
    bundles = get_bundles(message.from_user.id)

    if not bundles:
        await message.answer("📎 Нет связок для удаления.", reply_markup=main_kb())
        return

    buttons = []
    for name, b in bundles.items():
        verdict_e = b.get("verdict_emoji", "⏳")
        buttons.append([KeyboardButton(text=f"🗑 {verdict_e} {name}")])
    buttons.append([KeyboardButton(text="🗑🗑 Удалить ВСЕ связки")])
    buttons.append([KeyboardButton(text="❌ Отмена")])
    kb = ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True)

    await message.answer(
        "🗑 <b>Удалить связку</b>\n\n"
        "Выбери связку для удаления:",
        parse_mode="HTML",
        reply_markup=kb
    )
    await state.set_state(DeleteBundle.choose)

@dp.message(DeleteBundle.choose)
async def delete_bundle_confirm(message: types.Message, state: FSMContext):
    text = message.text.strip()

    # Удалить ВСЕ
    if "удалить все" in text.lower() or "🗑🗑" in text:
        bundles = get_bundles(message.from_user.id)
        count = len(bundles)
        data = load_data()
        uid = str(message.from_user.id)
        if uid in data:
            data[uid]["bundles"] = {}
            save_data(data)
        await message.answer(
            f"✅ Удалено {count} связок!",
            reply_markup=main_kb()
        )
        await state.clear()
        return

    if not text.startswith("🗑"):
        await message.answer("❌ Выбери связку из списка или нажми Отмена:")
        return

    # Убираем "🗑 🟢 " или "🗑 🔴 " и т.д.
    clean = text[1:].strip()  # убрали первый 🗑
    # Убираем вердикт эмодзи
    for emoji in ["🟢", "🟡", "🔴", "⏳"]:
        if clean.startswith(emoji):
            clean = clean[len(emoji):].strip()
            break

    name = clean
    bundles = get_bundles(message.from_user.id)

    if name not in bundles:
        # Пробуем найти по частичному совпадению
        found = None
        for bname in bundles.keys():
            if bname in text or text.endswith(bname):
                found = bname
                break
        if found:
            name = found
        else:
            await message.answer("❌ Связка не найдена. Выбери из списка:")
            return

    result = delete_bundle(message.from_user.id, name)

    if result:
        remaining = len(get_bundles(message.from_user.id))
        await message.answer(
            f"✅ Связка «{name}» удалена!\n"
            f"📎 Осталось связок: {remaining}",
            reply_markup=main_kb()
        )
    else:
        await message.answer("❌ Ошибка удаления.", reply_markup=main_kb())

    await state.clear()

