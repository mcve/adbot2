        ], resize_keyboard=True)
    )
    await state.set_state(ProductCheck.tt_hashtags)

@dp.message(ProductCheck.tt_hashtags)
async def tt_hash_h(message: types.Message, state: FSMContext):
    text = message.text.strip()
    hashtags = "" if ("пропустить" in text.lower() or "пропуск" in text) else text
    d = await state.get_data()
    name = d["check_product_name"]

    videos = d.get("tt_videos_count", 0)
    anomaly = d.get("tt_anomaly_count", 0)
    max_v = d.get("tt_max_views", 0)
    avg_v = d.get("tt_avg_views", 0)

    score, details = 0, []

    # Аномальные видео
    if anomaly >= 5:
        score += 1; details.append(f"✅ {anomaly} аномальных видео — отлично")
    elif anomaly >= 3:
        score += 0.7; details.append(f"🟡 {anomaly} аномальных — норма")
    elif anomaly >= 1:
        score += 0.3; details.append(f"🟡 {anomaly} аномальное — мало")
    else:
        details.append(f"❌ 0 аномальных — TT не продвигает")

    # Макс просмотры
    if max_v >= 1_000_000:
        score += 1; details.append(f"✅ Макс: {format_number_short(max_v)} — вирусный")
    elif max_v >= 100_000:
        score += 0.7; details.append(f"🟡 Макс: {format_number_short(max_v)} — хорошо")
    elif max_v >= 10_000:
        score += 0.3; details.append(f"🟡 Макс: {format_number_short(max_v)} — средне")
    else:
        details.append(f"❌ Макс: {format_number_short(max_v)} — мало")

    # Общее кол-во видео
    if videos >= 10:
        score += 1; details.append(f"✅ {videos} видео — тема популярна")
    elif videos >= 5:
        score += 0.5; details.append(f"🟡 {videos} видео — есть контент")
    else:
        details.append(f"❌ {videos} видео — мало контента")

    pct = score / 3 * 100
    if pct >= 70: ve, vt = "🟢", "ОХВАТ ПОДТВЕРЖДЁН"
    elif pct >= 45: ve, vt = "🟡", "СРЕДНИЙ ОХВАТ"
    else: ve, vt = "🔴", "ОХВАТ СЛАБЫЙ"

    tt_data = {
        "videos": videos, "anomaly": anomaly,
        "max_views": max_v, "avg_views": avg_v,
        "hashtags": hashtags, "score": round(pct, 1),
        "verdict": vt, "verdict_emoji": ve, "details": details,
        "date": datetime.now().strftime("%d.%m.%Y %H:%M"),
    }
    update_product_field(message.from_user.id, name, "tiktok_reach", tt_data)

    report = f"""{ve} <b>TIKTOK: {name}</b>

🎬 Видео: <b>{videos}</b> | ⚡ Аномальных: <b>{anomaly}</b>
👁 Макс: <b>{format_number_short(max_v)}</b> | Средн: <b>{format_number_short(avg_v)}</b>
"""
    if hashtags:
        report += f"#️⃣ {hashtags}\n"
    report += f"\n━━━ ОЦЕНКА ({pct:.0f}%) ━━━\n"
    for det in details:
        report += f"{det}\n"
    report += f"\n{ve} <b>{vt}</b>"

    await message.answer(report, parse_mode="HTML")
    p = get_products(message.from_user.id).get(name, {})
    await show_criteria_menu(message, state, name, p)


