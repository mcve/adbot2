        f"💬 <b>Интерес: {name}</b>\n\n"
        f"Посмотри комменты под видео в TikTok/Reels.\n\n"
        f"1️⃣ Есть <b>свежие комменты</b> (за последний месяц)?",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="✅ Да, свежие"), KeyboardButton(text="❌ Нет, старые")],
            [KeyboardButton(text="❌ Отмена")]
        ], resize_keyboard=True)
    )
    await state.set_state(ProductCheck.int_fresh)

@dp.message(ProductCheck.int_fresh)
async def int_fresh_h(message: types.Message, state: FSMContext):
    v = pyn(message.text)
    if v is None:
        await message.answer("❌ Да или Нет:")
        return
    await state.update_data(int_fresh=v)
    await message.answer(
        "2️⃣ Есть комменты с <b>намерением купить</b>?\n\n"
        "<i>«Где купить?», «Хочу такой», «Ссылку дайте!»</i>",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="✅ Много таких"), KeyboardButton(text="🟡 Есть немного")],
            [KeyboardButton(text="❌ Нет таких")],
            [KeyboardButton(text="❌ Отмена")]
        ], resize_keyboard=True)
    )
    await state.set_state(ProductCheck.int_buy_intent)

@dp.message(ProductCheck.int_buy_intent)
async def int_buy_h(message: types.Message, state: FSMContext):
    t = message.text.strip().lower()
    if "много" in t or "✅" in message.text:
        val = "many"
    elif "немного" in t or "🟡" in message.text:
        val = "some"
    else:
        val = "none"
    await state.update_data(int_buy_intent=val)

    await message.answer(
        "3️⃣ Есть вопросы про <b>цену</b>?\n\n"
        "<i>«Сколько стоит?», «Цена?», «Почём?»</i>",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="✅ Да, спрашивают"), KeyboardButton(text="❌ Нет")],
            [KeyboardButton(text="❌ Отмена")]
        ], resize_keyboard=True)
    )
    await state.set_state(ProductCheck.int_price_q)

@dp.message(ProductCheck.int_price_q)
async def int_price_h(message: types.Message, state: FSMContext):
    v = pyn(message.text)
    if v is None:
        await message.answer("❌ Да или Нет:")
        return
    await state.update_data(int_price_q=v)

    await message.answer(
        "4️⃣ Есть <b>негативные</b> комменты?\n\n"
        "<i>«Фигня», «Не работает», «Развод»</i>",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="✅ Нет негатива")],
            [KeyboardButton(text="🟡 Немного есть")],
            [KeyboardButton(text="🔴 Много негатива")],
            [KeyboardButton(text="❌ Отмена")]
        ], resize_keyboard=True)
    )
    await state.set_state(ProductCheck.int_negative)

@dp.message(ProductCheck.int_negative)
async def int_neg_h(message: types.Message, state: FSMContext):
    t = message.text.strip().lower()
    if "нет негатива" in t or ("✅" in message.text and "нет" in t):
        neg = "none"
    elif "немного" in t or "🟡" in message.text:
        neg = "some"
    else:
        neg = "heavy"
    await state.update_data(int_negative=neg)

    await message.answer(
        "5️⃣ <b>Заметки</b> по комментам (необязательно)",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="  Пропустить")], [KeyboardButton(text="❌ Отмена")]
        ], resize_keyboard=True)
    )
    await state.set_state(ProductCheck.int_notes)

@dp.message(ProductCheck.int_notes)
async def int_notes_h(message: types.Message, state: FSMContext):
    text = message.text.strip()
    notes = "" if ("пропустить" in text.lower() or "пропуск" in text) else text
    d = await state.get_data()
    name = d["check_product_name"]

    fresh = d.get("int_fresh", False)
    buy = d.get("int_buy_intent", "none")
    price_q = d.get("int_price_q", False)
    neg = d.get("int_negative", "none")

    score, details = 0, []

    if fresh:
        score += 1; details.append("✅ Свежие комменты — тема живая")
    else:
        details.append("❌ Старые комменты — тема остыла")

    if buy == "many":
        score += 1; details.append("✅ Много «Где купить?» — спрос горячий")
    elif buy == "some":
        score += 0.5; details.append("🟡 Немного интереса к покупке")
    else:
        details.append("❌ Нет намерения купить — только лайки")

    if price_q:
        score += 0.5; details.append("✅ Спрашивают цену — готовы платить")

    if neg == "none":
        score += 0.5; details.append("✅ Нет негатива")
    elif neg == "some":
        details.append("🟡 Немного негатива — мониторь")
    else:
        score -= 0.5; details.append("🔴 Много негатива — риск невыкупа!")

    pct = max(0, score / 3 * 100)
    if pct >= 70: ve, vt = "🟢", "ИНТЕРЕС ПОДТВЕРЖДЁН"
    elif pct >= 40: ve, vt = "🟡", "СРЕДНИЙ ИНТЕРЕС"
    else: ve, vt = "🔴", "ИНТЕРЕС СЛАБЫЙ"

    int_data = {
        "fresh": fresh, "buy_intent": buy, "price_questions": price_q,
        "negative": neg, "notes": notes, "score": round(pct, 1),
        "verdict": vt, "verdict_emoji": ve, "details": details,
        "date": datetime.now().strftime("%d.%m.%Y %H:%M"),
    }
    update_product_field(message.from_user.id, name, "interest_check", int_data)

    report = f"""{ve} <b>ИНТЕРЕС: {name}</b>

━━━ ОЦЕНКА ({pct:.0f}%) ━━━
"""
    for det in details:
        report += f"{det}\n"
    if notes:
        report += f"\n📝 {notes}"
    report += f"\n{ve} <b>{vt}</b>"

    await message.answer(report, parse_mode="HTML")
    p = get_products(message.from_user.id).get(name, {})
    await show_criteria_menu(message, state, name, p)


# ══════════════════════════════════════
# 5️⃣ WB ПРОВЕРКА ЦЕН
# ══════════════════════════════════════

async def wb_start(message, state):
    d = await state.get_data()
    name = d.get("check_product_name", "товар")
    products = get_products(message.from_user.id)
    p = products.get(name, {})
    query = p.get("search_query", name)

    await message.answer(
        f"🛒 <b>WB проверка: {name}</b>\n\n"
        f"Проверим цены на Wildberries.\n\n"
        f"🔍 <b>Поисковой запрос</b> для WB:\n\n"
        f"Введи или используй сохранённый:",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text=f"✅ {query[:35]}")],
            [KeyboardButton(text="❌ Отмена")]
        ], resize_keyboard=True)
    )
    await state.set_state(ProductCheck.wb_query)

@dp.message(ProductCheck.wb_query)
async def wb_query_h(message: types.Message, state: FSMContext):
    text = message.text.strip()
    d = await state.get_data()
    name = d["check_product_name"]
    products = get_products(message.from_user.id)
    p = products.get(name, {})

    query = p.get("search_query", name) if text.startswith("✅") else text
    await state.update_data(wb_query=query)

    await message.answer(f"⏳ Ищу «{query}» на Wildberries...")

    result = await wb_search_prices(query, limit=10)

    if result["ok"] and result["data"]:
        items = result["data"]
        prices = [i["price"] for i in items if i["price"] > 0]
        min_price = min(prices) if prices else 0
        max_price = max(prices) if prices else 0
        avg_price = sum(prices) / len(prices) if prices else 0

        report = f"🛒 <b>WB: «{query}»</b>\n\n"
        report += f"Найдено: {len(items)} товаров\n"
        report += f"💰 Мин: <b>{min_price:.2f} BYN</b>\n"
        report += f"💰 Макс: <b>{max_price:.2f} BYN</b>\n"
        report += f"💰 Средн: <b>{avg_price:.2f} BYN</b>\n\n"

        report += "━━━ ТОП-5 ━━━\n"
        for i, item in enumerate(items[:5], 1):
            stars = "⭐" * int(item["rating"]) if item["rating"] else ""
            report += f"{i}. <b>{item['price']:.2f} BYN</b> — {item['name'][:40]}\n"
            report += f"   {item['brand']} | {stars} | {item['feedbacks']} отзывов\n"

        await state.update_data(wb_prices=prices, wb_min=min_price, wb_avg=avg_price)
        await message.answer(report, parse_mode="HTML")

        await message.answer(
            "💰 <b>Твоя цена на ленде</b> (BYN)\n\n"
            "<i>По которой продаёшь/планируешь</i>\n\n"
            "Например: <code>59.9</code>",
            parse_mode="HTML", reply_markup=cancel_kb()
        )
        await state.set_state(ProductCheck.wb_your_price)
    else:
        await message.answer(
            f"😐 На WB не найдено по запросу «{query}»\n\n"
            "Это может быть ПЛЮС — нет конкурентов на маркетплейсе!\n\n"
            "💰 <b>Твоя цена на ленде</b> (BYN):",
            parse_mode="HTML", reply_markup=cancel_kb()
        )
        await state.update_data(wb_prices=[], wb_min=0, wb_avg=0)
        await state.set_state(ProductCheck.wb_your_price)

@dp.message(ProductCheck.wb_your_price)
async def wb_your_h(message: types.Message, state: FSMContext):
    v = pn(message.text)
    if v is None or v <= 0:
        await message.answer("❌ Число больше 0:")
        return
    await state.update_data(wb_your_price=v)

    await message.answer(
        "📦 <b>Цена закупки</b> (BYN)\n\n"
        "<i>Сколько стоит закупить 1 шт (с доставкой)?\n"
        "Или цена с Ali/1688 в BYN</i>\n\n"
        "Например: <code>15</code>",
        parse_mode="HTML", reply_markup=cancel_kb()
    )
    await state.set_state(ProductCheck.wb_ali_price)

@dp.message(ProductCheck.wb_ali_price)
async def wb_ali_h(message: types.Message, state: FSMContext):
    v = pn(message.text)
    if v is None or v <= 0:
        await message.answer("❌ Число больше 0:")
        return

    d = await state.get_data()
    name = d["check_product_name"]
    your_price = d["wb_your_price"]
    ali_price = v
    wb_min = d.get("wb_min", 0)
    wb_avg = d.get("wb_avg", 0)
    wb_prices = d.get("wb_prices", [])

    score, details = 0, []

    # Наценка: твоя цена vs закуп
    if ali_price > 0:
        markup = your_price / ali_price
        if markup >= 3:
            score += 1; details.append(f"✅ Наценка x{markup:.1f} — отличная маржа")
        elif markup >= 2:
            score += 0.5; details.append(f"🟡 Наценка x{markup:.1f} — нормально")
        else:
            details.append(f"❌ Наценка x{markup:.1f} — маржа тонкая")

    # WB vs твоя цена
    if wb_min > 0:
        ratio = wb_min / ali_price if ali_price > 0 else 0
        if wb_min >= your_price * 1.5:
            score += 1; details.append(f"✅ На WB от {wb_min:.0f} BYN — дороже тебя в {wb_min/your_price:.1f}x")
        elif wb_min >= your_price:
            score += 0.5; details.append(f"🟡 На WB от {wb_min:.0f} BYN — примерно как у тебя")
        elif wb_min > 0:
            details.append(f"🔴 На WB от {wb_min:.0f} BYN — ДЕШЕВЛЕ тебя! Клиент уйдёт!")
        
        if ratio >= 2:
            score += 1; details.append(f"✅ WB/закуп = x{ratio:.1f} — маркетплейс не демпингует")
        elif ratio >= 1.5:
            score += 0.5; details.append(f"🟡 WB/закуп = x{ratio:.1f}")
    else:
        score += 1; details.append("✅ На WB нет этого товара — нет конкурентов!")

    max_score = 3
    pct = max(0, score / max_score * 100)
    if pct >= 70: ve, vt = "🟢", "ЦЕНЫ ОК"
    elif pct >= 40: ve, vt = "🟡", "ЕСТЬ РИСКИ"
    else: ve, vt = "🔴", "ОПАСНО — WB ДЕШЕВЛЕ"

    wb_data = {
        "query": d.get("wb_query", ""), "your_price": your_price,
        "ali_price": ali_price, "wb_min": wb_min, "wb_avg": wb_avg,
        "wb_count": len(wb_prices), "score": round(pct, 1),
        "verdict": vt, "verdict_emoji": ve, "details": details,
        "date": datetime.now().strftime("%d.%m.%Y %H:%M"),
    }
    update_product_field(message.from_user.id, name, "wb_check", wb_data)

    report = f"""{ve} <b>WB ПРОВЕРКА: {name}</b>

💰 Твоя цена: <b>{your_price:.2f} BYN</b>
📦 Закуп: <b>{ali_price:.2f} BYN</b>
🛒 WB мин: <b>{wb_min:.2f} BYN</b> | средн: <b>{wb_avg:.2f} BYN</b>

━━━ ОЦЕНКА ({pct:.0f}%) ━━━
"""
    for det in details:
        report += f"{det}\n"
    report += f"\n{ve} <b>{vt}</b>"

    await message.answer(report, parse_mode="HTML")
    p = get_products(message.from_user.id).get(name, {})
    await show_criteria_menu(message, state, name, p)


