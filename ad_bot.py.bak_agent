@dp.message(ProductCheck.quick_ah_buyers)
async def quick_ah_buy_h(message: types.Message, state: FSMContext):
    v = pn_int(message.text)
    if v is None or v < 0:
        await message.answer("❌ Число:")
        return
    await state.update_data(ah_buyers=v)

    await message.answer(
        "4️⃣ <b>На какие ГЕО льют?</b>",
        parse_mode="HTML",
