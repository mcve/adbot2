@dp.message(F.text == "💬 Свободный вопрос")
async def ai_free_chat(message: types.Message, state: FSMContext):
    await state.clear()
    ctx = build_product_context(message.from_user.id)

    await message.answer("⏳ <b>Загружаю данные для контекста...</b>", parse_mode="HTML")

    # Добавляем LIVE данные из TikTok/Facebook
    uid = str(message.from_user.id)
    plans = get_plans(int(uid))
    live_ctx = ""

    if plans:
        for plan_name, plan in plans.items():
            campaigns = plan.get("linked_campaigns", [])
            for c in campaigns:
                try:
                    if c.get("source") == "tt":
                        adgroups = await tt_get_adgroup_insights(c["id"], "today")
                        if adgroups:
                            active_ags = [ag for ag in adgroups if ag.get("is_active", True)]
                            spend = sum(ag["spend"] for ag in active_ags)
                            leads = sum(ag["leads"] for ag in active_ags)
                            clicks = sum(ag["clicks"] for ag in active_ags)
                            imp = sum(ag["impressions"] for ag in active_ags)
                            ctr = (clicks / imp * 100) if imp > 0 else 0
                            cpc = (spend / clicks) if clicks > 0 else 0
                            cpl = (spend / leads) if leads > 0 else 0
                            live_ctx += f"\n🎵 {c['name'][:30]}: ${spend:.2f} | {clicks} кликов | CTR {ctr:.1f}% | CPC ${cpc:.2f} | Лидов: {leads}"
                            if leads > 0:
                                live_ctx += f" | CPL ${cpl:.2f}"

                            for ag in active_ags:
                                if ag["spend"] == 0 and ag["impressions"] == 0:
                                    continue
                                live_ctx += f"\n  Связка {ag['name'][:25]} [АКТИВНА]: ${ag['spend']:.2f} | CTR {ag['ctr']:.1f}% | CPC ${ag.get('cpc',0):.2f} | Лидов: {ag['leads']}"
                                if ag["leads"] > 0:
                                    live_ctx += f" | CPL ${ag['cpl']:.2f}"

                    elif c.get("source") == "fb":
                        result = await fb_get_campaign_insights(c["id"], date_preset="today")
                        if result["ok"] and result["data"]:
                            row = result["data"][0]
                            spend = float(row.get("spend", 0))
                            leads = fb_extract_leads(row.get("actions"))
                            cpl = (spend / leads) if leads > 0 else 0
                            live_ctx += f"\n📘 {c['name'][:30]}: ${spend:.2f} | Лидов: {leads}"
                            if leads > 0:
                                live_ctx += f" | CPL ${cpl:.2f}"
                except Exception as e:
                    logging.error(f"Free chat live data error: {e}")

    # Формируем полный контекст
    full_context = ctx
    if live_ctx:
        full_context += f"\n\nLIVE ДАННЫЕ РЕКЛАМЫ (сегодня):{live_ctx}"

    if plans:
        full_context += "\n\nЮНИТ-ПЛАНЫ:"
        for pname, plan in plans.items():
            max_cpl_20 = plan.get("max_cpl_20", 0) or plan.get("max_cpl", 0) or 0
            max_cpl_0 = plan.get("max_cpl_0", 0) or plan.get("max_cpl", 0) or 0
            full_context += f"\n  {pname}: CPL план=${max_cpl_20:.2f}, безубыток=${max_cpl_0:.2f}"

    await state.update_data(ai_context=full_context, ai_product=None)

    await message.answer(
        "💬 <b>Свободный чат с AI</b>\n\n"
        "Я загрузил контекст твоих товаров и рекламы.\n"
        "Спрашивай что угодно — анализ, советы, стратегия.\n\n"
        "Примеры:\n"
        "• <i>Как снизить CPL по пылесосу?</i>\n"
        "• <i>Какой товар самый прибыльный?</i>\n"
        "• <i>Стоит ли масштабировать?</i>",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="🚪 Выход из чата")]
        ], resize_keyboard=True)
    )
    await state.set_state(AIChat.chatting)

@dp.message(F.text == "🔍 AI анализ товара")
async def ai_product_start(message: types.Message, state: FSMContext):
    await state.clear()
    products = get_products(message.from_user.id)

    if not products:
        await message.answer("❌ Нет товаров. Добавь через «➕ Новый товар»", reply_markup=main_kb())
        return

    buttons = []
    for name, p in products.items():
        checks = count_checks(p)
        emoji = build_overall_verdict(p)["emoji"] if checks >= 3 else "⏳"
        buttons.append([KeyboardButton(text=f"🔍 {emoji} {name}")])
    buttons.append([KeyboardButton(text="❌ Отмена")])

    await message.answer(
        "🔍 <b>AI анализ товара</b>\n\nВыбери товар:",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True)
    )
    await state.set_state(AIChat.choose_product)


@dp.message(AIChat.choose_product)
async def ai_product_analyze(message: types.Message, state: FSMContext):
    text = message.text.strip()

    clean = text
    if clean.startswith("🔍"):
        clean = clean[1:].strip()
    for e in ["🟢", "🟡", "🔴", "⏳"]:
        if clean.startswith(e):
            clean = clean[len(e):].strip()
            break

    name = clean
    products = get_products(message.from_user.id)

    if name not in products:
        for pname in products:
            if pname in text:
                name = pname
                break
        else:
            await message.answer("❌ Товар не найден:")
            return

    await message.answer("🤖 <b>Анализирую товар...</b>", parse_mode="HTML")

    ctx = build_product_context(message.from_user.id, name)
    prompt = (
        f"Проанализируй товар «{name}» по всем доступным данным.\n\n"
        "Дай оценку по каждому критерию (что хорошо, что плохо).\n"
        "В конце — чёткий вердикт: БРАТЬ / ДОРАБОТАТЬ / ПРОПУСТИТЬ.\n"
        "И конкретный план действий (3-5 шагов)."
    )

    response = await ai_ask(prompt, ctx)

    await message.answer(f"🤖 <b>AI АНАЛИЗ: {name}</b>\n\n{response}", parse_mode="HTML")

    await state.update_data(ai_context=ctx, ai_product=name)
    await message.answer(
        "💬 Хочешь уточнить? Напиши вопрос:",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="🚪 Выход из чата")]
        ], resize_keyboard=True)
    )
    await state.set_state(AIChat.chatting)


