@dp.message(ProductCheck.quick_ah_notes)
async def quick_ah_notes_h(message: types.Message, state: FSMContext):
    text = message.text.strip()
    notes = "" if "пропустить" in text.lower() else text

    d = await state.get_data()
    name = d["quick_ah_product"]
    days = d.get("ah_days", 0)
    creo = d.get("ah_creatives", 0)
    buyers = d.get("ah_buyers", 0)

    # ═══ СКОРИНГ ═══
    score, details = 0, []

    if days >= 14:
        score += 1; details.append(f"✅ {int(days)} дней — стабильно льют")
    elif days >= 10:
        score += 0.7; details.append(f"🟡 {int(days)} дней — норма")
    elif days >= 5:
        score += 0.3; details.append(f"🟡 {int(days)} дней — мало")
    else:
        details.append(f"❌ {int(days)} дней — слишком мало")

    if creo >= 7:
        score += 1; details.append(f"✅ {creo} крео — активно тестируют")
    elif creo >= 5:
        score += 0.7; details.append(f"🟡 {creo} крео — нормально")
    elif creo >= 3:
        score += 0.3; details.append(f"🟡 {creo} крео — мало тестов")
    else:
        details.append(f"❌ {creo} крео — почти не тестируют")

    if buyers >= 3:
        score += 1; details.append(f"✅ {buyers} байеров — массово льют")
    elif buyers >= 2:
        score += 0.5; details.append(f"🟡 {buyers} байера — есть конкуренция")
    else:
        score += 0.2; details.append(f"🟡 {buyers} байер — мало данных")

    pct = score / 3 * 100
    if pct >= 70:
        ve, vt = "🟢", "ПРОШЁЛ — проверяй дальше!"
    elif pct >= 45:
        ve, vt = "🟡", "СОМНЕНИЯ — но можно проверить спрос"
    else:
        ve, vt = "🔴", "НЕ ПРОШЁЛ — ищи другой товар"

    adheart_data = {
        "days": days, "creatives": creo, "buyers": buyers,
        "geo": d.get("ah_geo", ""), "formats": d.get("ah_formats", ""),
        "notes": notes, "score": round(pct, 1), "verdict": vt,
        "verdict_emoji": ve, "details": details,
        "date": datetime.now().strftime("%d.%m.%Y %H:%M"),
    }

    # ═══ ОТЧЁТ ═══
    report = f"""{ve} <b>ADHEART: {name}</b>

📅 Дней: <b>{int(days)}</b> | 🎨 Крео: <b>{creo}</b> | 👤 Байеров: <b>{buyers}</b>
🌍 ГЕО: {d.get('ah_geo','—')} | 🎬 {d.get('ah_formats','—')}

━━━ ОЦЕНКА ({pct:.0f}%) ━━━
"""
    for det in details:
        report += f"{det}\n"
    if notes:
        report += f"\n📝 {notes}"

    report += f"""

━━━━━━━━━━━━━━━━━━━━
{ve} <b>{vt}</b>
━━━━━━━━━━━━━━━━━━━━"""

    # Рекомендации
    if pct >= 70:
        report += "\n\n💡 <b>Следующий шаг:</b> проверь спрос через «➕ Новый товар»"
    elif pct >= 45:
        report += "\n\n💡 Можно проверить спрос — вдруг тренд растущий"
    else:
        report += "\n\n💡 Не трать время — ищи товар с 14+ днями и 3+ байерами"

    await message.answer(report, parse_mode="HTML")

    # Предлагаем сохранить
    await state.update_data(adheart_data=adheart_data)

    if pct >= 45:
        await message.answer(
            f"💾 Сохранить «{name}» и продолжить проверку?",
            reply_markup=ReplyKeyboardMarkup(keyboard=[
                [KeyboardButton(text="💾 Сохранить и проверить спрос")],
                [KeyboardButton(text="💾 Сохранить")],
                [KeyboardButton(text="🔍 Проверить другой товар")],
                [KeyboardButton(text="🔙 Главное меню")]
            ], resize_keyboard=True)
        )
    else:
        await message.answer(
            "Что дальше?",
            reply_markup=ReplyKeyboardMarkup(keyboard=[
                [KeyboardButton(text="💾 Сохранить всё равно")],
                [KeyboardButton(text="🔍 Проверить другой товар")],
                [KeyboardButton(text="🔙 Главное меню")]
            ], resize_keyboard=True)
        )
    await state.set_state(ProductCheck.quick_ah_save)


@dp.message(ProductCheck.quick_ah_save)
async def quick_ah_save_h(message: types.Message, state: FSMContext):
    text = message.text.strip().lower()
    d = await state.get_data()
    name = d.get("quick_ah_product", "")
    adheart_data = d.get("adheart_data", {})

    if "сохранить" in text or "💾" in message.text:
        # Создаём товар с AdHeart
        product_data = {
            "search_query": name,
            "extra_queries": [],
            "demand_score": 0,
            "demand_verdict": "",
            "demand_emoji": "⬜",
            "gt_trend": "",
            "gt_trend_pct": 0,
            "ws_basic": 0,
            "ws_exact": 0,
            "ws_vol_text": "",
            "hate_level": "",
            "adheart": adheart_data,
            "tiktok_reach": None,
            "interest_check": None,
            "wb_check": None,
            "visual_hook": None,
            "unit_plan": None,
        }
        save_product(message.from_user.id, name, product_data)
        await message.answer(f"💾 Товар «{name}» сохранён с AdHeart!")

        # Если хочет проверить спрос — сразу запускаем
        if "спрос" in text:
            await state.clear()
            await state.update_data(product_name=name)
            await message.answer(
                f"🔍 <b>Проверка спроса: {name}</b>\n\n"
                f"Поисковой запрос для проверки:\n\n"
                f"Введи запрос или используй название:",
                parse_mode="HTML",
                reply_markup=ReplyKeyboardMarkup(keyboard=[
                    [KeyboardButton(text=f"✅ {name[:35]}")],
                    [KeyboardButton(text="❌ Отмена")]
                ], resize_keyboard=True)
            )
            await state.set_state(DemandCheck.search_query)
            return

        await message.answer("Что дальше?", reply_markup=main_kb())
        await state.clear()

    elif "другой" in text or "проверить" in text:
        await state.clear()
        await quick_ah_start(message, state)

    else:
        await message.answer("👌", reply_markup=main_kb())
        await state.clear()

