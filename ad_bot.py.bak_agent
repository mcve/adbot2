@dp.message(LinkCampaign.choose_plan)
async def link_choose_plan(message: types.Message, state: FSMContext):
    text = message.text.strip()
    if not text.startswith("📋 "):
        await message.answer("❌ Выбери план из списка:")
        return

    # Извлекаем имя плана (убираем "📋 " и " (X кампаний)")
    name = text[2:].strip()
    if "(" in name:
        name = name[:name.rfind("(")].strip()

    plans = get_plans(message.from_user.id)
    if name not in plans:
        await message.answer("❌ План не найден:")
        return

    await state.update_data(link_plan_name=name)

    kb = ReplyKeyboardMarkup(keyboard=[
        [KeyboardButton(text="📘 Загрузить из Facebook")],
        [KeyboardButton(text="🎵 Загрузить из TikTok")],
        [KeyboardButton(text="❌ Отмена")]
    ], resize_keyboard=True)

    current = get_plan_campaigns(message.from_user.id, name)
    if current:
        text = f"🔗 План: <b>{name}</b>\n\n📎 Текущие кампании:\n"
        for c in current:
            text += f"  {c['source_emoji']} {c['name']}\n"
        text += "\nДобавить ещё?"
    else:
        text = f"🔗 План: <b>{name}</b>\n\nОткуда загрузить кампании?"

    await message.answer(text, parse_mode="HTML", reply_markup=kb)
    await state.set_state(LinkCampaign.choose_source)


@dp.message(LinkCampaign.choose_source)
async def link_choose_source(message: types.Message, state: FSMContext):
    text = message.text.strip()

    if "Facebook" in text or "📘" in text:
        await message.answer("⏳ Загружаю кампании из Facebook...")
        result = await fb_get_active_campaigns()

        if not result["ok"]:
            await message.answer(f"❌ Ошибка: {result['error']}", reply_markup=main_kb())
            await state.clear()
            return

        campaigns = result["data"]
        if not campaigns:
            await message.answer("😐 Нет активных кампаний в Facebook.", reply_markup=main_kb())
            await state.clear()
            return

        # Сохраняем список кампаний
        await state.update_data(
            available_campaigns=[
                {"id": c["id"], "name": c["name"], "status": c.get("status", ""),
                 "source": "fb", "source_emoji": "📘"}
                for c in campaigns
            ],
            selected_indices=[]
        )

        buttons = []
        for i, c in enumerate(campaigns):
            status = "✅" if c.get("status") == "ACTIVE" else "⏸"
            short_name = c["name"][:35] + "..." if len(c["name"]) > 35 else c["name"]
            buttons.append([KeyboardButton(text=f"{'✅' if False else '⬜'} {i+1}. {short_name}")])

        buttons.append([KeyboardButton(text="✅ Выбрать все")])
        buttons.append([KeyboardButton(text="📎 Готово — привязать")])
        buttons.append([KeyboardButton(text="❌ Отмена")])
        kb = ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True)

        text = "📘 <b>Кампании Facebook</b>\n\nНажимай на кампании чтобы выбрать:"
        for i, c in enumerate(campaigns):
            status = "🟢" if c.get("status") == "ACTIVE" else "⏸"
            text += f"\n{status} {i+1}. {c['name']}"

        text += "\n\nВыбери нужные → жми «📎 Готово»"

        await message.answer(text, parse_mode="HTML", reply_markup=kb)
        await state.set_state(LinkCampaign.choose_campaigns)

    elif "TikTok" in text or "🎵" in text:
        await message.answer("⏳ Загружаю кампании из TikTok...")
        result = await tt_get_campaigns()

        if not result["ok"]:
            await message.answer(f"❌ Ошибка: {result['error']}", reply_markup=main_kb())
            await state.clear()
            return

        campaigns = result["data"]
        if not campaigns:
            await message.answer("😐 Нет кампаний в TikTok.", reply_markup=main_kb())
            await state.clear()
            return

        await state.update_data(
            available_campaigns=[
                {"id": c["campaign_id"], "name": c["campaign_name"], "status": c.get("status", ""),
                 "source": "tt", "source_emoji": "🎵"}
                for c in campaigns
            ],
            selected_indices=[]
        )

        buttons = []
        for i, c in enumerate(campaigns):
            short_name = c["campaign_name"][:35] + "..." if len(c["campaign_name"]) > 35 else c["campaign_name"]
            buttons.append([KeyboardButton(text=f"⬜ {i+1}. {short_name}")])

        buttons.append([KeyboardButton(text="✅ Выбрать все")])
        buttons.append([KeyboardButton(text="📎 Готово — привязать")])
        buttons.append([KeyboardButton(text="❌ Отмена")])
        kb = ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True)

        text_msg = "🎵 <b>Кампании TikTok</b>\n\nНажимай на кампании чтобы выбрать:"
        for i, c in enumerate(campaigns):
            text_msg += f"\n{i+1}. {c['campaign_name']}"
        text_msg += "\n\nВыбери нужные → жми «📎 Готово»"

        await message.answer(text_msg, parse_mode="HTML", reply_markup=kb)
        await state.set_state(LinkCampaign.choose_campaigns)
    else:
        await message.answer("❌ Выбери источник кнопкой:")


@dp.message(LinkCampaign.choose_campaigns)
async def link_toggle_campaign(message: types.Message, state: FSMContext):
    text = message.text.strip()
    d = await state.get_data()
    campaigns = d.get("available_campaigns", [])
    selected = d.get("selected_indices", [])

    # Выбрать все
    if "выбрать все" in text.lower() or text == "✅ Выбрать все":
        selected = list(range(len(campaigns)))
        await state.update_data(selected_indices=selected)
        await message.answer(
            f"✅ Выбрано все {len(campaigns)} кампаний!\n\nЖми «📎 Готово — привязать»"
        )
        return

    # Готово
    if "готово" in text.lower() or "📎" in text:
        if not selected:
            await message.answer("❌ Не выбрано ни одной кампании. Выбери или нажми Отмена:")
            return

        plan_name = d["link_plan_name"]
        existing = get_plan_campaigns(message.from_user.id, plan_name)

        new_campaigns = []
        for idx in selected:
            if idx < len(campaigns):
                c = campaigns[idx]
                # Проверяем что ещё не привязана
                already = any(e["id"] == c["id"] for e in existing)
                if not already:
                    new_campaigns.append(c)

        all_campaigns = existing + new_campaigns
        save_plan_campaigns(message.from_user.id, plan_name, all_campaigns)

        report = f"✅ <b>Привязано к плану «{plan_name}»</b>\n\n"
        for c in all_campaigns:
            report += f"  {c['source_emoji']} {c['name']}\n"
        report += f"\nВсего кампаний: {len(all_campaigns)}"
        report += "\n\nТеперь жми «📊 Дашборд по плану» для отчёта!"

        await message.answer(report, parse_mode="HTML", reply_markup=main_kb())
        await state.clear()
        return

    # Переключение конкретной кампании
    try:
        import re
        # Ищем номер в начале: "⬜ 3. Название" → извлекаем 3
        match = re.search(r'(\d+)\.', text)
        if match:
            num = int(match.group(1))
            i = num - 1  # индекс = номер - 1
            if 0 <= i < len(campaigns):
                if i in selected:
                    selected.remove(i)
                    await message.answer(f"❌ Убрана: {campaigns[i]['name'][:40]}\nВыбрано: {len(selected)}")
                else:
                    selected.append(i)
                    await message.answer(f"✅ Добавлена: {campaigns[i]['name'][:40]}\nВыбрано: {len(selected)}")
                await state.update_data(selected_indices=selected)
                return
    except Exception as e:
        logging.error(f"Toggle error: {e}")

    await message.answer("❌ Нажми на кампанию или «📎 Готово»")

