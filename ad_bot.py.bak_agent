@dp.message(F.text == "🔍 Быстрая проверка AdHeart")
async def quick_ah_start(message: types.Message, state: FSMContext):
    await state.clear()
    await message.answer(
        "🔍 <b>БЫСТРАЯ ПРОВЕРКА AdHeart</b>\n\n"
        "Это первый фильтр — отсеиваем мусор.\n"
