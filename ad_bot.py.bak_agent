    await message.answer(
        "3️⃣ <b>Сколько разных байеров</b> льют этот товар?\n\n"
        "<i>Разные рекламные аккаунты/страницы.\n"
        "• 3+ байеров = товар точно рабочий 🟢\n"
        "• 2 байера = есть конкуренция 🟡\n"
        "• 1 байер = может быть уникальный случай 🟡</i>\n\n"
        "Например: <code>4</code>",
        parse_mode="HTML", reply_markup=cancel_kb()
    )
