@dp.message(F.text == "⏰ Уведомления")
async def notifications_menu(message: types.Message, state: FSMContext):
    await state.clear()
    reminders = get_reminders()
    uid = str(message.from_user.id)
    rdata = reminders.get(uid, {})

    current_times = rdata.get("report_times", [])
    times_str = ", ".join(current_times) if current_times else "не настроено"
    reports_on = rdata.get("reports_enabled", True)
    alerts_on = rdata.get("alerts_enabled", True)
    triggers_on = rdata.get("triggers_enabled", True)
    r_icon = "✅" if reports_on else "❌"
    a_icon = "✅" if alerts_on else "❌"
    t_icon = "✅" if triggers_on else "❌"

    buttons = [
        [KeyboardButton(text="📊 Настроить время отчётов")],
        [KeyboardButton(text=f"🛑 Триггеры правил: {'ВЫКЛ' if triggers_on else 'ВКЛ'}")],
        [KeyboardButton(text=f"⚠️ Алерты метрик: {'ВЫКЛ' if alerts_on else 'ВКЛ'}")],
        [KeyboardButton(text=f"📊 Полные отчёты: {'ВЫКЛ' if reports_on else 'ВКЛ'}")],
        [KeyboardButton(text="🚫 Выключить всё"), KeyboardButton(text="✅ Включить всё")],
        [KeyboardButton(text="🔙 Главное меню")],
    ]

    await message.answer(
        f"⏰ <b>УВЕДОМЛЕНИЯ</b>\n\n"
        f"{r_icon} <b>📊 Полный отчёт:</b> {times_str}\n"
        f"{t_icon} <b>🛑 Триггеры правил TT:</b> каждые 15 мин\n"
        f"{a_icon} <b>⚠️ Алерты метрик:</b> каждые 30 мин\n",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True)
    )
    await state.set_state(ReportSchedule.waiting_times)

@dp.message(F.text.in_({"🤖 Включить Товарного Бро", "🔔 Включить оповещения",
