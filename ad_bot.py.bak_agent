@dp.message(DemandCheck.product_name)
async def demand_name(message: types.Message, state: FSMContext):
    name = message.text.strip()
    if len(name) < 2 or len(name) > 100:
        await message.answer("❌ От 2 до 100 символов:")
        return
    await state.update_data(product_name=name)
    await message.answer(
        f"📦 Товар: <b>{name}</b>\n\n"
        f"🔍 <b>Поисковой запрос</b> для проверки:\n\n"
        f"<i>Как люди ищут этот товар?\n"
        f"Например: вместо «корректор осанки магнитный»\n"
        f"→ «корректор осанки»</i>\n\n"
        f"Введи запрос или используй название:",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text=f"✅ {name[:35]}")],
            [KeyboardButton(text="❌ Отмена")]
        ], resize_keyboard=True)
    )
    await state.set_state(DemandCheck.search_query)


@dp.message(DemandCheck.search_query)
async def demand_query(message: types.Message, state: FSMContext):
    text = message.text.strip()
    d = await state.get_data()
    # Проверяем начинается ли с ✅ или с названия товара
    if text.startswith("✅") or text == d["product_name"]:
        query = d["product_name"]
    else:
        query = text
    if len(query) < 2:
        await message.answer("❌ Минимум 2 символа:")
        return
    await state.update_data(search_query=query)

    await message.answer(
        f"🔍 Запрос: <b>{query}</b>\n\n"
        f"Доп. запросы через запятую?\n"
        f"<i>Синонимы: «массажер для шеи», «электромассажер»</i>",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="Пропустить")],
            [KeyboardButton(text="❌ Отмена")]
        ], resize_keyboard=True)
    )
    await state.set_state(DemandCheck.extra_queries)


@dp.message(DemandCheck.extra_queries)
async def demand_extra(message: types.Message, state: FSMContext):
    text = message.text.strip()
    if "пропустить" in text.lower() or "пропус" in text.lower():
        extra = []
    else:
        extra = [q.strip() for q in text.split(",") if q.strip()]
    await state.update_data(extra_queries=extra)

    # ... остальной код без изменений

    d = await state.get_data()
    query = d["search_query"]

    # Предупреждение о времени
    await message.answer(
        f"⏳ <b>Анализирую Google Trends...</b>\n"
        f"🔍 «{query}»\n\n"
        f"⏱ Это займёт <b>30-60 секунд</b>\n"
        f"<i>(задержки нужны чтобы Google не блокировал)</i>",
        parse_mode="HTML"
    )

    loop = asyncio.get_event_loop()
    try:
        gt_world = await loop.run_in_executor(None, analyze_google_trends, query, "")
    except:
        gt_world = {"ok": False, "error": "таймаут"}
    try:
        gt_ru = await loop.run_in_executor(None, analyze_google_trends, query, "RU")
    except:
        gt_ru = {"ok": False, "error": "таймаут"}
    try:
        hate_results = await loop.run_in_executor(None, check_hate_queries, query)
    except:
        hate_results = []

    await state.update_data(gt_world=gt_world, gt_ru=gt_ru, hate_results=hate_results)

    # ... остальной код отчёта без изменений ...

    # Отчёт GT
    report = f"📊 <b>GOOGLE TRENDS: «{query}»</b>\n"
    if gt_world and gt_world.get("ok"):
        g = gt_world
        report += f"\n━━━ 🌍 Мировой ━━━\n{g['sparkline']}\n"
        report += f"{g['trend_emoji']} Тренд: <b>{g['trend']}</b> ({g['trend_pct']:+.1f}%)\n"
        report += f"📊 Интерес: {g['current']}/100 (ср: {g['avg']})\n"
        report += f"{g['season_emoji']} {g['season_text']}\n📆 Пик: {g['peak_month']}"
    else:
        report += f"\n🌍 Мировой: ❌ {gt_world.get('error', '?') if gt_world else '?'}"

    if gt_ru and gt_ru.get("ok"):
        g = gt_ru
        report += f"\n\n━━━ 🇷🇺 Россия ━━━\n{g['sparkline']}\n"
        report += f"{g['trend_emoji']} Тренд: <b>{g['trend']}</b> ({g['trend_pct']:+.1f}%)\n"
        report += f"📊 Интерес: {g['current']}/100 (ср: {g['avg']})"
    else:
        report += f"\n\n🇷🇺 Россия: ⚠️ мало данных"

    if hate_results:
        report += "\n\n━━━ 🚫 ХЕЙТ ━━━"
        for h in hate_results[:5]:
            report += f"\n⚠️ «{h['query']}» — {h['interest']}"
    else:
        report += "\n\n✅ Хейт не найден"

    await message.answer(report, parse_mode="HTML")

    # Вордстат
    await message.answer(
        f"━━━━━━━━━━━━━━━━━━━━\n\n"
        f"📈 <b>Яндекс Вордстат</b>\n\n"
        f"Открой <a href='https://wordstat.yandex.ru/'>wordstat.yandex.ru</a>\n"
        f"Запрос: <code>{query}</code>\n\n"
        f"Введи число показов <b>без кавычек</b>:\n"
        f"Например: <code>45000</code>",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="Пропустить Вордстат")],
            [KeyboardButton(text="❌ Отмена")]
        ], resize_keyboard=True)
    )
    await state.set_state(DemandCheck.wordstat_basic)


@dp.message(DemandCheck.wordstat_basic)
async def demand_ws_basic(message: types.Message, state: FSMContext):
    text = message.text.strip()
    if "пропустить" in text.lower() or "пропуск" in text:
        await state.update_data(ws_data=None)
        await ask_hate_confirm(message, state)
        return

    v = pn(text)
    if v is None or v < 0:
        await message.answer("❌ Число. Например: <code>45000</code>", parse_mode="HTML")
        return
    await state.update_data(ws_basic=v)
    d = await state.get_data()
    query = d["search_query"]

    await message.answer(
        f"✅ Базовая: <b>{int(v):,}</b>\n\n"
        f"Теперь в кавычках: <code>\"{query}\"</code>\n\n"
        f"Введи число показов:",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="Не знаю")],
            [KeyboardButton(text="❌ Отмена")]
        ], resize_keyboard=True)
    )
    await state.set_state(DemandCheck.wordstat_exact)


@dp.message(DemandCheck.wordstat_exact)
async def demand_ws_exact(message: types.Message, state: FSMContext):
    text = message.text.strip()
    if "пропустить" in text.lower() or "не знаю" in text.lower() or "пропуск" in text:
        d = await state.get_data()
        await state.update_data(ws_exact=d.get("ws_basic", 0) * 0.1)
    else:
        v = pn(text)
        if v is None or v < 0:
            await message.answer("❌ Число:")
            return
        await state.update_data(ws_exact=v)

    await message.answer(
        "📈 <b>Тренд в Вордстат</b>\n\n"
        "Нажми «История запросов».\nКак график?",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="📈 Растёт"), KeyboardButton(text="➡️ Стабильно")],
            [KeyboardButton(text="📉 Падает"), KeyboardButton(text="🔄 Сезонный")],
            [KeyboardButton(text="  Не смотрел")],
            [KeyboardButton(text="❌ Отмена")]
        ], resize_keyboard=True)
    )
    await state.set_state(DemandCheck.wordstat_trend)


@dp.message(DemandCheck.wordstat_trend)
async def demand_ws_trend(message: types.Message, state: FSMContext):
    text = message.text.strip()
    trend_map = {
        "📈 Растёт": "растёт", "➡️ Стабильно": "стабильно",
        "📉 Падает": "падает", "🔄 Сезонный": "сезонный", "  Не смотрел": "",
    }
    await state.update_data(ws_trend=trend_map.get(text, text.lower()))

    await message.answer(
        "🌍 <b>Регионы</b>\n\n"
        "В Вордстат «По регионам» — где ищут?\n"
        "<i>Например: Москва 35%, СПб 12%</i>",
        parse_mode="HTML",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="  Пропустить")],
            [KeyboardButton(text="❌ Отмена")]
        ], resize_keyboard=True)
    )
    await state.set_state(DemandCheck.wordstat_region)


@dp.message(DemandCheck.wordstat_region)
async def demand_ws_region(message: types.Message, state: FSMContext):
    text = message.text.strip()
    region = "" if ("пропустить" in text.lower() or "пропуск" in text) else text
    await state.update_data(ws_region=region)

    d = await state.get_data()
    ws_data = analyze_wordstat_data(
        d.get("ws_basic", 0), d.get("ws_exact", 0),
        d.get("ws_trend", ""), region,
    )
    await state.update_data(ws_data=ws_data)

    report = f"""📈 <b>ЯНДЕКС ВОРДСТАТ</b>

{ws_data['vol_emoji']} Базовая: <b>{int(ws_data['basic']):,}</b> — {ws_data['vol_text']}
📌 Точная: <b>{int(ws_data['exact']):,}</b>
{ws_data['prec_emoji']} Точность: <b>{ws_data['precision']:.1f}%</b> — {ws_data['prec_text']}
{ws_data['trend_emoji']} Тренд: {ws_data['trend_result']}"""
    if region:
        report += f"\n🌍 Регионы: {region}"

    await message.answer(report, parse_mode="HTML")
    await ask_hate_confirm(message, state)


async def ask_hate_confirm(message, state):
    d = await state.get_data()
    hate_results = d.get("hate_results", [])
    query = d.get("search_query", "")

    if hate_results:
        text = "🚫 <b>Хейт-проверка</b>\n\nGoogle нашёл негатив. Проверь вручную:\n"
        for h in hate_results[:3]:
            text += f"  🔍 <code>{h['query']}</code>\n"
        text += "\nЕсть реальные жалобы?"
    else:
        text = (
            f"🚫 <b>Хейт-проверка</b>\n\n✅ Автоматически не найден\n\n"
            f"Проверь вручную:\n"
            f"🔍 <code>{query} развод</code>\n"
            f"🔍 <code>{query} обман</code>\n"
            f"🔍 <code>{query} не работает</code>\n\n"
            f"Есть жалобы?"
        )

    await message.answer(text, parse_mode="HTML", reply_markup=ReplyKeyboardMarkup(keyboard=[
        [KeyboardButton(text="✅ Нет хейта")],
        [KeyboardButton(text="⚠️ Немного негатива")],
        [KeyboardButton(text="🔴 Много негатива")],
        [KeyboardButton(text="❌ Отмена")]
    ], resize_keyboard=True))
    await state.set_state(DemandCheck.hate_manual)


@dp.message(DemandCheck.hate_manual)
async def demand_hate(message: types.Message, state: FSMContext):
    text = message.text.strip()
    if "нет хейта" in text.lower() or "✅" in text:
        hate_manual, hate_level = False, "clean"
    elif "немного" in text.lower() or "⚠️" in text:
        hate_manual, hate_level = False, "some"
    elif "много" in text.lower() or "🔴" in text:
        hate_manual, hate_level = True, "heavy"
    else:
        await message.answer("❌ Выбери кнопкой:")
        return

    await state.update_data(hate_manual=hate_manual, hate_level=hate_level)
    d = await state.get_data()

    # Вердикт спроса
    gt_data = d.get("gt_world") or d.get("gt_ru")
    ws_data = d.get("ws_data")
    hate_results = d.get("hate_results", [])
    product_name = d["product_name"]
    query = d["search_query"]

    verdict = build_demand_verdict(gt_data, ws_data, hate_results, hate_manual)

    report = f"""{verdict['verdict_emoji']} <b>ИТОГ ПРОВЕРКИ СПРОСА</b>

📦 Товар: <b>{product_name}</b>
🔍 Запрос: «{query}»

━━━ 📊 СКОРИНГ: {verdict['score']:.1f}/{verdict['max_score']} ({verdict['pct']:.0f}%) ━━━
"""
    for detail in verdict["details"]:
        report += f"\n{detail}"

    hate_texts = {"clean": "\n\n✅ Хейт: чисто", "some": "\n\n🟡 Хейт: немного — мониторь", "heavy": "\n\n🔴 Хейт: много — РИСК!"}
    report += hate_texts.get(hate_level, "")
    report += f"\n\n━━━━━━━━━━━━━━━━━━━━\n{verdict['verdict_emoji']} <b>{verdict['verdict']}</b>\n━━━━━━━━━━━━━━━━━━━━"

    await message.answer(report, parse_mode="HTML")
    await message.answer("💾 Сохранить товар?", reply_markup=ReplyKeyboardMarkup(keyboard=[
        [KeyboardButton(text="💾 Сохранить")],
        [KeyboardButton(text="🔄 Другой товар")],
        [KeyboardButton(text="🔙 Главное меню")]
    ], resize_keyboard=True))
    await state.set_state(DemandCheck.save_result)


def build_demand_verdict(gt_data, ws_data, hate_results, hate_manual=False):
    score = 0
    max_score = 0
    details = []

    if gt_data and gt_data.get("ok"):
        max_score += 3
        if gt_data["trend_emoji"] == "🟢":
            score += 1
            details.append(f"✅ GT тренд: {gt_data['trend']} ({gt_data['trend_pct']:+.1f}%)")
        elif gt_data["trend_emoji"] == "🟡":
            score += 0.5
            details.append(f"🟡 GT тренд: {gt_data['trend']}")
        else:
            details.append(f"❌ GT тренд: {gt_data['trend']}")

        if gt_data["current"] >= 50:
            score += 1
            details.append(f"✅ GT интерес: {gt_data['current']}/100")
        elif gt_data["current"] >= 25:
            score += 0.5
            details.append(f"🟡 GT интерес: {gt_data['current']}/100")
        else:
            details.append(f"❌ GT интерес: {gt_data['current']}/100")

        if gt_data["season_emoji"] == "🟢":
            score += 1
        else:
            score += 0.5
            details.append(f"🟡 {gt_data['season_text']}")

    if ws_data:
        max_score += 3
        for key, s_val in [("vol_emoji", 1), ("prec_emoji", 1), ("trend_emoji", 1)]:
            if ws_data[key] == "🟢":
                score += s_val
            elif ws_data[key] == "🟡":
                score += 0.5
        details.append(f"{ws_data['vol_emoji']} Вордстат: {int(ws_data['basic']):,} — {ws_data['vol_text']}")

    max_score += 1
    if not hate_results and not hate_manual:
        score += 1
        details.append("✅ Хейт не найден")
    elif hate_manual:
        score -= 0.5
        details.append("🔴 Хейт обнаружен!")
    else:
        for h in hate_results[:3]:
            details.append(f"⚠️ «{h['query']}» ({h['interest']})")

    pct = (score / max_score * 100) if max_score > 0 else 0
    if pct >= 70:
        ve, v = "🟢", "СПРОС ПОДТВЕРЖДЁН"
    elif pct >= 45:
        ve, v = "🟡", "СПРОС СРЕДНИЙ"
    else:
        ve, v = "🔴", "СПРОС СЛАБЫЙ"

    return {"score": score, "max_score": max_score, "pct": round(pct, 1), "verdict_emoji": ve, "verdict": v, "details": details}


@dp.message(DemandCheck.save_result)
async def demand_save(message: types.Message, state: FSMContext):
    text = message.text.strip()
    if "сохранить" in text.lower() or "💾" in text:
        d = await state.get_data()
        name = d["product_name"]
        gt_world = d.get("gt_world", {})
        ws_data = d.get("ws_data")
        verdict = build_demand_verdict(
            gt_world if gt_world and gt_world.get("ok") else d.get("gt_ru"),
            ws_data, d.get("hate_results", []), d.get("hate_manual", False)
        )
        product_data = {
            "search_query": d.get("search_query", ""),
            "extra_queries": d.get("extra_queries", []),
            "demand_score": verdict["pct"],
            "demand_verdict": verdict["verdict"],
            "demand_emoji": verdict["verdict_emoji"],
            "gt_trend": gt_world.get("trend", "") if gt_world and gt_world.get("ok") else "",
            "gt_trend_pct": gt_world.get("trend_pct", 0) if gt_world and gt_world.get("ok") else 0,
            "ws_basic": ws_data.get("basic", 0) if ws_data else 0,
            "ws_exact": ws_data.get("exact", 0) if ws_data else 0,
            "ws_vol_text": ws_data.get("vol_text", "") if ws_data else "",
            "hate_level": d.get("hate_level", "clean"),
            "adheart": None, "tiktok_reach": None, "interest_check": None,
            "wb_check": None, "visual_hook": None, "unit_plan": None,
        }
        save_product(message.from_user.id, name, product_data)
        await message.answer(f"💾 Товар «{name}» сохранён!\n\nТеперь проверь остальные критерии через «📋 Проверить критерии»", reply_markup=main_kb())
    elif "другой" in text.lower() or "🔄" in text:
        await state.clear()
        await demand_start(message, state)
        return
    else:
        await message.answer("👌", reply_markup=main_kb())
    await state.clear()
    
    # ══════════════════════════════════════
# 📋 МЕНЮ КРИТЕРИЕВ ТОВАРА
# ══════════════════════════════════════

@dp.message(F.text == "📋 Проверить критерии")
async def criteria_menu_start(message: types.Message, state: FSMContext):
    await state.clear()
    products = get_products(message.from_user.id)
    if not products:
        await message.answer("❌ Сначала добавь товар через «➕ Новый товар»", reply_markup=main_kb())
        return

    buttons = []
    for name, p in products.items():
        checks = count_checks(p)
        emoji = build_overall_verdict(p)["emoji"] if checks >= 3 else "⏳"
        buttons.append([KeyboardButton(text=f"📋 {emoji} {name} [{checks}/7]")])
    buttons.append([KeyboardButton(text="❌ Отмена")])

    await message.answer("📋 <b>Выбери товар:</b>", parse_mode="HTML",
                         reply_markup=ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True))
    await state.set_state(ProductCheck.choose_product)


@dp.message(ProductCheck.choose_product)
async def criteria_choose_product(message: types.Message, state: FSMContext):
    text = message.text.strip()
    if not text.startswith("📋"):
        await message.answer("❌ Выбери из списка:")
        return

    clean = text[1:].strip()
    for e in ["🟢", "🟡", "🔴", "⏳", "⬜"]:
        if clean.startswith(e):
            clean = clean[len(e):].strip()
            break
    if "[" in clean:
        clean = clean[:clean.rfind("[")].strip()

    name = clean
    products = get_products(message.from_user.id)
    if name not in products:
        for pname in products:
            if pname in text:
                name = pname
                break
        else:
            await message.answer("❌ Не найден:")
            return

    await state.update_data(check_product_name=name)
    await show_criteria_menu(message, state, name, products[name])


async def show_criteria_menu(message, state, name, p):
    s = {k: criteria_status(p, k) for k in ["adheart", "demand", "tiktok", "interest", "wb", "visual", "econ"]}
    checks = count_checks(p)

    if checks >= 3:
        ov = build_overall_verdict(p)
        header = f"{ov['emoji']} <b>ИТОГ: {ov['verdict']}</b> ({ov['score']:.0f}%)"
    else:
        header = f"⏳ Проверено {checks}/7"

    text = f"""📋 <b>{name}</b>
{header}

{s['adheart']} 1. AdHeart
{s['demand']} 2. Спрос
{s['tiktok']} 3. TikTok охват
{s['interest']} 4. Интерес (комменты)
{s['wb']} 5. WB цены
{s['visual']} 6. Визуал (Hook)
{s['econ']} 7. Экономика (ROI)"""

    buttons = [
        [KeyboardButton(text=f"{s['adheart']} 1.AdHeart"), KeyboardButton(text=f"{s['demand']} 2.Спрос")],
        [KeyboardButton(text=f"{s['tiktok']} 3.TikTok"), KeyboardButton(text=f"{s['interest']} 4.Интерес")],
        [KeyboardButton(text=f"{s['wb']} 5.WB"), KeyboardButton(text=f"{s['visual']} 6.Визуал")],
        [KeyboardButton(text=f"{s['econ']} 7.Экономика")],
    ]
    if checks >= 5:
        buttons.append([KeyboardButton(text="📊 Полная карточка")])
    buttons.append([KeyboardButton(text="🔙 Главное меню")])

    await message.answer(text, parse_mode="HTML",
                         reply_markup=ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True))
    await state.set_state(ProductCheck.choose_criteria)


@dp.message(ProductCheck.choose_criteria)
async def criteria_dispatch(message: types.Message, state: FSMContext):
    t = message.text.strip().lower()
    if "1" in t or "adheart" in t:
        await adheart_start(message, state)
    elif "2" in t or "спрос" in t:
        await message.answer("Спрос проверяется через «➕ Новый товар».\nРезультат уже привязан.", reply_markup=main_kb())
        await state.clear()
    elif "3" in t or "tiktok" in t or "тикток" in t:
        await tiktok_start(message, state)
    elif "4" in t or "интерес" in t:
        await interest_start(message, state)
    elif "5" in t or "wb" in t:
        await wb_start(message, state)
    elif "6" in t or "визуал" in t:
        await visual_start(message, state)
    elif "7" in t or "эконом" in t:
        await econ_start(message, state)
    elif "полная карточка" in t or "📊" in t:
        await show_full_card(message, state)
    else:
        await message.answer("❌ Выбери кнопкой:")


