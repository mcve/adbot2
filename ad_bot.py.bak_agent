def build_product_context(user_id, product_name=None):
    """Собирает контекст по товару для AI"""
    ctx = ""

    if product_name:
        products = get_products(user_id)
        p = products.get(product_name, {})
        if p:
            ctx += f"ТОВАР: {product_name}\n"
            ctx += f"Поисковой запрос: {p.get('search_query', '—')}\n"

            ah = p.get("adheart")
            if ah:
                ctx += f"AdHeart: {ah.get('days',0)} дней, {ah.get('creatives',0)} крео, {ah.get('buyers',0)} байеров, оценка {ah.get('score',0)}%\n"

            if p.get("demand_score", 0) > 0:
                ctx += f"Спрос: {p['demand_score']}%, Вордстат: {p.get('ws_basic',0)}, тренд GT: {p.get('gt_trend','')}\n"

            tt = p.get("tiktok_reach")
            if tt:
                ctx += f"TikTok: {tt.get('videos',0)} видео, {tt.get('anomaly',0)} аномальных, макс {tt.get('max_views',0)} просмотров\n"

            ic = p.get("interest_check")
            if ic:
                ctx += f"Интерес: оценка {ic.get('score',0)}%, покупательское намерение: {ic.get('buy_intent','—')}\n"

            wb = p.get("wb_check")
            if wb:
                ctx += f"WB: мин цена {wb.get('wb_min',0)} BYN, твоя цена {wb.get('your_price',0)} BYN, закуп {wb.get('ali_price',0)} BYN\n"

            vh = p.get("visual_hook")
            if vh and isinstance(vh, dict):
                ctx += f"Визуал: оценка {vh.get('score',0)}%\n"

            if p.get("unit_plan"):
                ctx += f"Юнит-план: {p['unit_plan']}\n"

    plans = get_plans(user_id)
    if plans:
        ctx += "\nЮНИТ-ПЛАНЫ:\n"
        for pname, plan in plans.items():
            ctx += f"  {pname}: прибыль {plan.get('net_profit',0)} BYN, рент {plan.get('profitability',0)}%, CPL план ${plan.get('max_cpl_20',0)}, безуб ${plan.get('max_cpl_0',0)}\n"

    bundles = get_bundles(user_id)
    if bundles:
        ctx += "\nСВЯЗКИ:\n"
        for bname, b in list(bundles.items())[:5]:
            ctx += f"  {bname}: ${b.get('spend',0)} спенд, {b.get('leads',0)} лидов, CPL ${b.get('cpl',0) or 0}, CTR {b.get('ctr',0)}%, вердикт: {b.get('verdict','')}\n"

    return ctx

