@dp.message(ProductCheck.quick_ah_name)
async def quick_ah_name_h(message: types.Message, state: FSMContext):
    name = message.text.strip()
    if len(name) < 2 or len(name) > 100:
        await message.answer("❌ От 2 до 100 символов:")
        return
    await state.update_data(quick_ah_product=name)

    await message.answer(
        f"📦 Товар: <b>{name}</b>\n\n"
        f"Открой <a href='https://adheart.me'>adheart.me</a>\n"
        f"Найди рекламу этого товара.\n\n"
        f"1️⃣ <b>Сколько дней</b> крутится реклама?\n\n"
        f"<i>Смотри дату первого и последнего крео.\n"
        f"• 14+ дней = товар в плюсе 🟢\n"
        f"• 10-14 дней = на грани 🟡\n"
        f"• 5-10 дней = мало, тестируют 🟡\n"
        f"• менее 5 = слишком мало 🔴</i>\n\n"
        f"Например: <code>15</code>",
        parse_mode="HTML",
        reply_markup=cancel_kb()
    )
    await state.set_state(ProductCheck.quick_ah_days)


@dp.message(ProductCheck.quick_ah_days)
async def quick_ah_days_h(message: types.Message, state: FSMContext):
    v = pn(message.text)
    if v is None or v < 0:
        await message.answer("❌ Число дней:")
        return
    await state.update_data(ah_days=v)

    await message.answer(
        "2️⃣ <b>Сколько разных креативов</b> у одного байера?\n\n"
        "<i>Считай уникальные видео/картинки.\n"
        "• 7+ крео = активно тестируют 🟢\n"
        "• 5-7 = нормально 🟡\n"
        "• 3-5 = мало тестов 🟡\n"
        "• менее 3 = почти не тестируют 🔴</i>\n\n"
        "Например: <code>8</code>",
        parse_mode="HTML", reply_markup=cancel_kb()
    )
    await state.set_state(ProductCheck.quick_ah_creatives)


@dp.message(ProductCheck.quick_ah_creatives)
async def quick_ah_creo_h(message: types.Message, state: FSMContext):
    v = pn_int(message.text)
    if v is None or v < 0:
        await message.answer("❌ Число:")
