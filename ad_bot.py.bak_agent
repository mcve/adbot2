@dp.message(F.text == "📊 Юнит-экономика")
async def unit_start(message: types.Message, state: FSMContext):
    await state.clear()
    await message.answer("⏳ Загружаю курсы НБРБ...", reply_markup=cancel_kb())
    rates = await get_exchange_rates()
    if rates["usd"] and rates["rub"]:
        await state.update_data(usd_rate=rates["usd"], rub_rate=rates["rub"])
        await message.answer(
            f"✅ <b>Курсы НБРБ:</b>\n\n"
            f"💵 $1 = <b>{rates['usd']:.4f} BYN</b>\n"
            f"🪙 ₽1 = <b>{rates['rub']:.4f} BYN</b>\n\n"
            f"Актуальные?",
            parse_mode="HTML", reply_markup=yes_no_kb()
        )
        await state.set_state(UnitEcon.confirm_rates)
    else:
        await state.update_data(rate_step="waiting_rub")
        await message.answer(
            "⚠️ Не загрузились. Введи курс ₽ к BYN\n\n"
            "Например: <code>0.037</code>",
            parse_mode="HTML", reply_markup=cancel_kb()
        )
        await state.set_state(UnitEcon.confirm_rates)


async def get_exchange_rates() -> dict:
    rates = {"usd": None, "rub": None}
    try:
        async with aiohttp.ClientSession() as session:
            try:
                async with session.get(
                    "https://api.nbrb.by/exrates/rates/431",
                    timeout=aiohttp.ClientTimeout(total=5)
                ) as resp:
                    if resp.status == 200:
                        data = await resp.json()
                        rates["usd"] = data.get("Cur_OfficialRate")
            except:
                pass
            try:
                async with session.get(
                    "https://api.nbrb.by/exrates/rates/456",
                    timeout=aiohttp.ClientTimeout(total=5)
                ) as resp:
                    if resp.status == 200:
                        data = await resp.json()
                        r100 = data.get("Cur_OfficialRate")
                        if r100:
                            rates["rub"] = r100 / 100
            except:
                pass
    except:
        pass
    return rates
# ══════════════════════════════════════
# FACEBOOK API ЗАПРОСЫ
# ══════════════════════════════════════

async def fb_get_insights(date_preset=None, since=None, until=None, level="account"):
    """Получает статистику из Facebook Ads API"""
    params = {
        "access_token": FB_ACCESS_TOKEN,
        "fields": "spend,impressions,clicks,cpc,ctr,cpm,actions,cost_per_action_type,campaign_name,frequency",
        "level": level,
    }
    if date_preset:
        params["date_preset"] = date_preset
    elif since and until:
        params["time_range"] = json.dumps({"since": since, "until": until})

    url = f"{FB_BASE_URL}/{FB_AD_ACCOUNT_ID}/insights"

    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(url, params=params, timeout=aiohttp.ClientTimeout(total=15)) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    return {"ok": True, "data": data.get("data", [])}
                else:
                    error = await resp.text()
                    logging.error(f"FB API error {resp.status}: {error}")
                    return {"ok": False, "error": f"HTTP {resp.status}"}
    except asyncio.TimeoutError:
        return {"ok": False, "error": "Таймаут запроса"}
    except Exception as e:
        logging.error(f"FB API exception: {e}")
        return {"ok": False, "error": str(e)}


async def fb_get_campaigns(date_preset="today"):
    """Получает статистику по кампаниям"""
    return await fb_get_insights(date_preset=date_preset, level="campaign")


def fb_format_number(value, prefix="", suffix="", decimals=2):
    """Форматирует число для отчёта"""
    try:
        num = float(value)
        if num >= 1000000:
            return f"{prefix}{num/1000000:.1f}M{suffix}"
        elif num >= 1000:
            return f"{prefix}{num/1000:.1f}K{suffix}"
        else:
            return f"{prefix}{num:.{decimals}f}{suffix}"
    except:
        return f"{prefix}0{suffix}"


def fb_extract_leads(actions):
    """Извлекает количество лидов из actions"""
    if not actions:
        return 0
    for action in actions:
        if action.get("action_type") in ["lead", "onsite_conversion.lead_grouped", "offsite_conversion.fb_pixel_lead"]:
            return int(action.get("value", 0))
    return 0


def fb_extract_purchases(actions):
    """Извлекает количество покупок из actions"""
    if not actions:
        return 0
    for action in actions:
        if action.get("action_type") in ["purchase", "offsite_conversion.fb_pixel_purchase"]:
            return int(action.get("value", 0))
    return 0


def fb_build_report(data_list, title="📊 Facebook Ads"):
    """Строит текстовый отчёт из данных FB API"""
    if not data_list:
        return f"{title}\n\n😐 Нет данных за этот период."

    # Если несколько строк (кампании) — суммируем для общей
    total_spend = 0
    total_impressions = 0
    total_clicks = 0
    total_leads = 0
    total_purchases = 0

    for row in data_list:
        total_spend += float(row.get("spend", 0))
        total_impressions += int(row.get("impressions", 0))
        total_clicks += int(row.get("clicks", 0))
        total_leads += fb_extract_leads(row.get("actions"))
        total_purchases += fb_extract_purchases(row.get("actions"))

    # Метрики
    ctr = (total_clicks / total_impressions * 100) if total_impressions > 0 else 0
    cpc = (total_spend / total_clicks) if total_clicks > 0 else 0
    cpm = (total_spend / total_impressions * 1000) if total_impressions > 0 else 0
    cpl = (total_spend / total_leads) if total_leads > 0 else 0

    # Оценки
    ctr_e = "🟢" if ctr >= 1.5 else ("🟡" if ctr >= 0.8 else "🔴")
    cpc_e = "🟢" if cpc <= 0.15 else ("🟡" if cpc <= 0.5 else "🔴")
    cpm_e = "🟢" if cpm <= 3 else ("🟡" if cpm <= 8 else "🔴")

    report = f"""📘 <b>{title}</b>

━━━ 💰 РАСХОДЫ ━━━
💵 Потрачено: <b>${total_spend:.2f}</b>

━━━ 📊 ПОКАЗАТЕЛИ ━━━
👁 Показы: <b>{total_impressions:,}</b>
🖱 Клики: <b>{total_clicks:,}</b>
{ctr_e} CTR: <b>{ctr:.2f}%</b>
{cpc_e} CPC: <b>${cpc:.2f}</b>
{cpm_e} CPM: <b>${cpm:.2f}</b>"""

    if total_leads > 0:
        report += f"""

━━━ 📝 КОНВЕРСИИ ━━━
📝 Лиды: <b>{total_leads}</b>
💰 CPL: <b>${cpl:.2f}</b>"""

    if total_purchases > 0:
        cpp = total_spend / total_purchases if total_purchases > 0 else 0
        report += f"""
🛒 Покупки: <b>{total_purchases}</b>
💰 CPA: <b>${cpp:.2f}</b>"""

    # Период
    if data_list:
        d_start = data_list[0].get("date_start", "")
        d_stop = data_list[0].get("date_stop", "")
        if d_start and d_stop:
            report += f"\n\n📅 {d_start} — {d_stop}"

    return report


def fb_build_campaigns_report(data_list, title="📊 По кампаниям"):
    """Строит отчёт с разбивкой по кампаниям"""
    if not data_list:
        return f"{title}\n\n😐 Нет активных кампаний."

    report = f"📘 <b>{title}</b>\n"

    for i, row in enumerate(data_list, 1):
        name = row.get("campaign_name", "Без названия")
        spend = float(row.get("spend", 0))
        impressions = int(row.get("impressions", 0))
        clicks = int(row.get("clicks", 0))
        ctr = float(row.get("ctr", 0))
        cpc = float(row.get("cpc", 0))
        leads = fb_extract_leads(row.get("actions"))
        cpl = (spend / leads) if leads > 0 else 0

        # Короткое имя кампании (макс 30 символов)
        short_name = name[:30] + "..." if len(name) > 30 else name

        # Светофор
        if spend == 0:
            status = "⏸"
        elif ctr >= 1.5 and cpc <= 0.3:
            status = "🟢"
        elif ctr >= 0.8:
            status = "🟡"
        else:
            status = "🔴"

        report += f"""
{status} <b>{i}. {short_name}</b>
   💵 ${spend:.2f} | 👁 {impressions:,} | 🖱 {clicks}
   CTR {ctr:.2f}% | CPC ${cpc:.2f}"""

        if leads > 0:
            report += f" | 📝 {leads} | CPL ${cpl:.2f}"
        report += "\n"

    return report


