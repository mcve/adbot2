@dp.message(F.text == "🔍 Отбор товара")
async def product_menu(message: types.Message, state: FSMContext):
    await state.clear()
    products = get_products(message.from_user.id)

    text = "🔍 <b>ОТБОР ТОВАРА</b>\n\n"
    text += "7 критериев для проверки:\n"
    text += "1️⃣ AdHeart (спенд конкурентов)\n"
    text += "2️⃣ Поисковой спрос (GT + Вордстат)\n"
    text += "3️⃣ TikTok охват\n"
    text += "4️⃣ Интерес (комменты)\n"
    text += "5️⃣ WB vs закуп (цены)\n"
    text += "6️⃣ Визуал (hook)\n"
    text += "7️⃣ Экономика (ROI)\n"

    if products:
        text += f"\n📦 Твоих товаров: {len(products)}\n"
        for name, p in products.items():
            checks = count_checks(p)
            ov = build_overall_verdict(p) if checks >= 3 else None
            emoji = ov["emoji"] if ov else "⏳"
            text += f"\n{emoji} <b>{name}</b> — {checks}/7 критериев"

    kb = ReplyKeyboardMarkup(keyboard=[
        [KeyboardButton(text="🔍 Быстрая проверка AdHeart")],
        [KeyboardButton(text="➕ Новый товар (полная проверка)")],
        [KeyboardButton(text="📋 Проверить критерии")],
        [KeyboardButton(text="📦 Мои товары")],
        [KeyboardButton(text="🔙 Главное меню")]
    ], resize_keyboard=True)

    await message.answer(text, parse_mode="HTML", reply_markup=kb)


