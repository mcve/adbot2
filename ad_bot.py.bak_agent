def count_checks(p):
    checks = 0
    if p.get("adheart"): checks += 1
    if p.get("demand_score", 0) > 0: checks += 1
    if p.get("tiktok_reach"): checks += 1
    if p.get("interest_check"): checks += 1
    if p.get("wb_check"): checks += 1
    if p.get("visual_hook") is not None: checks += 1
    if p.get("unit_plan"): checks += 1
    return checks

def criteria_status(p, key):
    mapping = {
        "adheart": "adheart",
        "demand": None,
        "tiktok": "tiktok_reach",
        "interest": "interest_check",
        "wb": "wb_check",
        "visual": "visual_hook",
        "econ": "unit_plan",
    }
    if key == "demand":
        if p.get("demand_score", 0) > 0:
            return p.get("demand_emoji", "⬜")
        return "⬜"
    if key == "econ":
        return "🟢" if p.get("unit_plan") else "⬜"
    field = mapping.get(key)
    if not field:
        return "⬜"
    d = p.get(field)
    if d is None:
        return "⬜"
    if isinstance(d, dict):
        return d.get("verdict_emoji", "⬜")
    return "⬜"

def build_sparkline(values, width=20):
    if not values:
        return ""
    if len(values) > width:
        step = len(values) / width
        compressed = []
        for i in range(width):
            idx = int(i * step)
            compressed.append(values[min(idx, len(values)-1)])
        values = compressed
    max_v = max(values) if values else 1
    if max_v == 0:
        max_v = 1
    blocks = " ▁▂▃▄▅▆▇█"
    return "".join(blocks[int(v / max_v * (len(blocks) - 1))] for v in values)

def format_number_short(n):
    if n >= 1_000_000:
        return f"{n/1_000_000:.1f}M"
    elif n >= 1_000:
        return f"{n/1_000:.1f}K"
    return str(int(n))

def parse_views(text):
    text = text.strip().lower().replace(" ", "").replace(",", ".")
    multiplier = 1
    if text.endswith("m") or text.endswith("м"):
        text = text[:-1]
        multiplier = 1_000_000
    elif text.endswith("k") or text.endswith("к"):
        text = text[:-1]
        multiplier = 1_000
    v = pn(text)
    if v is None or v < 0:
        return None
    return v * multiplier


# ══════════════════════════════════════
# GOOGLE TRENDS
# ══════════════════════════════════════

def analyze_google_trends(keyword, geo=""):
    """С задержками и retry для обхода 429"""
    for attempt in range(3):
        try:
            # Задержка между запросами
            time.sleep(random.uniform(2, 5))
            
            pytrends = TrendReq(
    hl='ru', 
    tz=180, 
    timeout=(10, 30),
)
            pytrends.build_payload([keyword], timeframe='today 12-m', geo=geo)
            df = pytrends.interest_over_time()
            
            if df.empty:
                return {"ok": False, "error": "Нет данных — слишком редкий запрос"}

            values = df[keyword].tolist()
            dates = df.index.tolist()
            current = values[-1] if values else 0
            avg = sum(values) / len(values) if values else 0
            max_val = max(values) if values else 0
            min_val = min(values) if values else 0

            if len(values) >= 24:
                recent = values[-12:]
                older = values[-24:-12]
            elif len(values) >= 8:
                mid = len(values) // 2
                recent, older = values[mid:], values[:mid]
            else:
                recent = older = values

            avg_recent = sum(recent) / len(recent) if recent else 0
            avg_older = sum(older) / len(older) if older else 0
            trend_pct = ((avg_recent - avg_older) / avg_older * 100) if avg_older > 0 else 0

            if trend_pct > 20:
                trend, trend_emoji = "📈 Растущий", "🟢"
            elif trend_pct > -10:
                trend, trend_emoji = "➡️ Стабильный", "🟢"
            elif trend_pct > -30:
                trend, trend_emoji = "📉 Снижается", "🟡"
            else:
                trend, trend_emoji = "📉 Сильно падает", "🔴"

            seasonality = (max_val - min_val) / max_val * 100 if max_val > 0 else 0
            if seasonality > 60:
                season_text, season_emoji = "🔄 Сильная сезонность", "🟡"
            elif seasonality > 30:
                season_text, season_emoji = "🔄 Умеренная сезонность", "🟢"
            else:
                season_text, season_emoji = "✅ Стабильный спрос", "🟢"

            peak_idx = values.index(max_val)
            peak_month = dates[peak_idx].strftime("%B %Y") if peak_idx < len(dates) else "—"

            return {
                "ok": True, "current": current, "avg": round(avg, 1),
                "max": max_val, "min": min_val,
                "trend": trend, "trend_emoji": trend_emoji, "trend_pct": round(trend_pct, 1),
                "seasonality": round(seasonality, 1),
                "season_text": season_text, "season_emoji": season_emoji,
                "peak_month": peak_month,
                "sparkline": build_sparkline(values),
            }
        
        except Exception as e:
            error_str = str(e)
            if "429" in error_str:
                wait = (attempt + 1) * 10  # 10, 20, 30 сек
                logging.warning(f"GT 429 — жду {wait} сек (попытка {attempt+1}/3)")
                time.sleep(wait)
                continue
            return {"ok": False, "error": error_str}
    
    return {"ok": False, "error": "Google блокирует — попробуй через 5 минут"}

def check_hate_queries(keyword):
    """Проверка хейта — только 3 самых важных слова"""
    hate_words = ["развод", "обман", "не работает"]  # Сократили с 8 до 3
    results = []
    try:
        for hate in hate_words:
            time.sleep(random.uniform(3, 6))  # Задержка!
            query = f"{keyword} {hate}"
            try:
                pytrends = TrendReq(hl='ru', tz=180, timeout=(10, 25))
                pytrends.build_payload([query], timeframe='today 12-m', geo='')
                df = pytrends.interest_over_time()
                if not df.empty:
                    avg_interest = df[query].mean()
                    if avg_interest > 5:
                        results.append({"query": query, "interest": round(avg_interest, 1), "word": hate})
            except Exception as e:
                if "429" in str(e):
                    logging.warning(f"GT hate 429 — пропускаю остальные")
                    break  # Стоп если 429
                continue
    except Exception as e:
        logging.error(f"Hate check error: {e}")
    return results

def analyze_wordstat_data(basic, exact, trend_text="", region_text=""):
    if basic >= 50000:
        vol_emoji, vol_text = "🟢", "Высокий спрос"
    elif basic >= 10000:
        vol_emoji, vol_text = "🟢", "Хороший спрос"
    elif basic >= 3000:
        vol_emoji, vol_text = "🟡", "Средний спрос"
    elif basic >= 500:
        vol_emoji, vol_text = "🟡", "Низкий спрос"
    else:
        vol_emoji, vol_text = "🔴", "Очень низкий спрос"

    precision = (exact / basic * 100) if basic > 0 else 0
    if precision >= 10:
        prec_emoji, prec_text = "🟢", "Целевой запрос"
    elif precision >= 3:
        prec_emoji, prec_text = "🟡", "Размытый запрос"
    else:
        prec_emoji, prec_text = "🔴", "Очень размытый"

    trend_lower = trend_text.lower().strip() if trend_text else ""
    if any(w in trend_lower for w in ["раст", "вверх", "+"]):
        trend_emoji, trend_result = "🟢", "📈 Растущий"
    elif any(w in trend_lower for w in ["стабил", "ровн", "норм"]):
        trend_emoji, trend_result = "🟢", "➡️ Стабильный"
    elif any(w in trend_lower for w in ["пада", "сниж", "вниз", "-"]):
        trend_emoji, trend_result = "🔴", "📉 Падающий"
    else:
        trend_emoji, trend_result = "🟡", "❓ Не определён"

    return {
        "basic": basic, "exact": exact, "precision": round(precision, 1),
        "vol_emoji": vol_emoji, "vol_text": vol_text,
        "prec_emoji": prec_emoji, "prec_text": prec_text,
        "trend_emoji": trend_emoji, "trend_result": trend_result,
        "region_text": region_text,
    }


# ══════════════════════════════════════
# WB ПАРСИНГ ЦЕН
# ══════════════════════════════════════

async def wb_search_prices(query, limit=10):
    url = "https://search.wb.ru/exactmatch/ru/common/v4/search"
    params = {
        "appType": 1, "curr": "byn", "dest": -59257,
        "query": query, "resultset": "catalog",
        "sort": "popular", "spp": 30, "suppressSpellcheck": "false",
    }
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
        "Accept": "application/json",
    }
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(url, params=params, headers=headers,
                                   timeout=aiohttp.ClientTimeout(total=15)) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    products = data.get("data", {}).get("products", [])
                    results = []
                    for p in products[:limit]:
                        price_byn = p.get("salePriceU", 0) / 100
                        results.append({
                            "name": p.get("name", "—"),
                            "brand": p.get("brand", "—"),
                            "price": price_byn,
                            "rating": p.get("rating", 0),
                            "feedbacks": p.get("feedbacks", 0),
                            "id": p.get("id", 0),
                        })
                    return {"ok": True, "data": results}
                else:
                    return {"ok": False, "error": f"HTTP {resp.status}"}
    except Exception as e:
        return {"ok": False, "error": str(e)}


# ══════════════════════════════════════
# ОБЩИЙ ВЕРДИКТ ПО ТОВАРУ
# ══════════════════════════════════════

def build_overall_verdict(p):
    score = 0
    max_score = 0
    details = []

    ah = p.get("adheart")
    if ah:
        max_score += 1
        score += ah.get("score", 0) / 100
        details.append(f"{ah.get('verdict_emoji','⬜')} AdHeart: {ah.get('score',0):.0f}%")

    if p.get("demand_score", 0) > 0:
        max_score += 1
        score += p["demand_score"] / 100
        details.append(f"{p.get('demand_emoji','⬜')} Спрос: {p['demand_score']:.0f}%")

    tt = p.get("tiktok_reach")
    if tt:
        max_score += 1
        score += tt.get("score", 0) / 100
        details.append(f"{tt.get('verdict_emoji','⬜')} TikTok: {tt.get('score',0):.0f}%")

    ic = p.get("interest_check")
    if ic:
        max_score += 1
        score += ic.get("score", 0) / 100
        details.append(f"{ic.get('verdict_emoji','⬜')} Интерес: {ic.get('score',0):.0f}%")

    wb = p.get("wb_check")
    if wb:
        max_score += 1
        score += wb.get("score", 0) / 100
        details.append(f"{wb.get('verdict_emoji','⬜')} WB: {wb.get('score',0):.0f}%")

    vh = p.get("visual_hook")
    if vh is not None and isinstance(vh, dict):
        max_score += 1
        score += vh.get("score", 0) / 100
        details.append(f"{vh.get('verdict_emoji','⬜')} Визуал: {vh.get('score',0):.0f}%")

    if p.get("unit_plan"):
        max_score += 1
        score += 1
        details.append(f"🟢 Экономика: «{p['unit_plan']}»")

    pct = (score / max_score * 100) if max_score > 0 else 0
    if pct >= 70:
        emoji, verdict = "🟢", "БРАТЬ — товар прошёл отбор"
    elif pct >= 50:
        emoji, verdict = "🟡", "ДОРАБОТАТЬ — есть слабые места"
    else:
        emoji, verdict = "🔴", "ПРОПУСТИТЬ — слишком рискованно"

    return {"score": round(pct, 1), "emoji": emoji, "verdict": verdict, "details": details, "checks": count_checks(p)}

