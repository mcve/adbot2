def parse_platform(text):
    t = text.lower()
    if any(x in t for x in ["facebook", "fb", "instagram", "📘"]):
        return "fb"
    if any(x in t for x in ["tiktok", "тикток", "tt", "🎵"]):
        return "tt"
    if any(x in t for x in ["google", "гугл", "🔍"]):
        return "goog"
    if any(x in t for x in ["друг", "📢"]):
        return "uni"
    return None

# ══════════════════════════════════════
# ФУНКЦИИ ОЦЕНКИ (СВЕТОФОР)
# ══════════════════════════════════════

def rate_higher_better(value, metric, platform="uni"):
    n = NORMS.get(platform, NORMS["uni"])
    if metric not in n:
        return "⏳", "мало данных"
    low, high = n[metric]
    if value >= high:
        return "🟢", "отлично"
    elif value >= low:
        return "🟡", "нормально"
    else:
        return "🔴", "низкий"

def rate_lower_better(value, metric, platform="uni"):
    n = NORMS.get(platform, NORMS["uni"])
    if metric not in n:
        return "⏳", "мало данных"
    low, high = n[metric]
    if value <= low:
        return "🟢", "отлично"
    elif value <= high:
        return "🟡", "нормально"
    else:
        return "🔴", "дорого"

def rate_freq(freq):
    if freq <= 2.0:
        return "🟢", "норм"
    elif freq <= 3.0:
        return "🟡", "аудитория выгорает"
    else:
        return "🔴", "аудитория выгорела"

