class UpdateBundle(StatesGroup):
    choose = State()
    spend = State()
    impressions = State()
    clicks = State()
    leads = State()
    has_confirmed = State()
    confirmed = State()
    frequency = State()

class LinkCampaign(StatesGroup):
    choose_plan = State()
    choose_source = State()
    choose_campaigns = State()
    confirm = State()

class UnlinkCampaign(StatesGroup):
    choose_plan = State()
    choose_campaign = State()

class PlanDashboard(StatesGroup):
    choose_plan = State()
    choose_period = State()

@dp.message(F.text == "🔄 Обновить связку")
async def update_bundle_start(message: types.Message, state: FSMContext):
    await state.clear()
    bundles = get_bundles(message.from_user.id)

    if not bundles:
        await message.answer(
            "📎 Нет связок для обновления.\n"
            "Создай через «📈 Анализ связки»",
            reply_markup=main_kb()
        )
        return

    buttons = []
    for name, b in bundles.items():
        ve = b.get("verdict_emoji", "⏳")
        p = b.get("platform", "uni")
        pf = PLATFORMS.get(p, PLATFORMS["uni"])
        buttons.append([KeyboardButton(text=f"🔄 {ve} {name}")])
    buttons.append([KeyboardButton(text="❌ Отмена")])
    kb = ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True)

    await message.answer(
        "🔄 <b>Обновить связку</b>\n\n"
        "Выбери связку для обновления:",
        parse_mode="HTML",
        reply_markup=kb
    )
    await state.set_state(UpdateBundle.choose)


@dp.message(UpdateBundle.choose)
async def update_bundle_choose(message: types.Message, state: FSMContext):
    text = message.text.strip()

    if not text.startswith("🔄"):
        await message.answer("❌ Выбери связку из списка:")
        return

    # Убираем "🔄 " и вердикт эмодзи
    clean = text[1:].strip()
    for emoji in ["🟢", "🟡", "🔴", "⏳"]:
        if clean.startswith(emoji):
            clean = clean[len(emoji):].strip()
            break

    name = clean
    bundles = get_bundles(message.from_user.id)

    if name not in bundles:
        found = None
        for bname in bundles.keys():
            if bname in text or text.endswith(bname):
                found = bname
                break
        if found:
            name = found
        else:
            await message.answer("❌ Связка не найдена:")
            return

    b = bundles[name]
    p = b.get("platform", "uni")
    pf = PLATFORMS.get(p, PLATFORMS["uni"])

    await state.update_data(
        update_name=name,
        platform=p,
        budget=b.get("budget", 0),
        bid_type=b.get("bid_type", "auto"),
        bid_value=b.get("bid_value"),
        hours=b.get("hours", 24),
        linked_plan=b.get("linked_plan"),
        plan_data=None
    )

    # Подгружаем план если привязан
    if b.get("linked_plan"):
        plans = get_plans(message.from_user.id)
        plan_data = plans.get(b["linked_plan"])
        if plan_data:
            await state.update_data(plan_data=plan_data)

    old_spend = b.get("spend", 0)
    old_leads = b.get("leads", 0)
    old_imp = b.get("impressions", 0)
    old_clicks = b.get("clicks", 0)
    old_conf = b.get("confirmed", 0)
    old_freq = b.get("frequency", 0)

    await message.answer(
        f"🔄 <b>Обновляем: {name}</b>\n"
        f"{pf['emoji']} {pf['name']}\n\n"
        f"📊 Текущие данные:\n"
        f"💵 ${old_spend:.2f} | 👁 {old_imp:,} | 🖱 {old_clicks}\n"
        f"📝 {old_leads} | ✅ {old_conf} | 🔄 {old_freq:.2f}\n\n"
        f"⚡ <b>Быстрый ввод — одним сообщением:</b>\n"
        f"<code>расход показы клики лиды подтв частота</code>\n\n"
        f"Пример: <code>12.5 4500 95 6 4 1.8</code>\n\n"
        f"Или введи <b>только расход</b> ($) — пойдём пошагово:",
        parse_mode="HTML",
        reply_markup=cancel_kb()
    )
    await state.set_state(UpdateBundle.spend)


@dp.message(UpdateBundle.spend)
async def update_spend(message: types.Message, state: FSMContext):
    text = message.text.strip()
    parts = text.replace(",", ".").split()

    # Быстрый ввод: 6 чисел в одном сообщении
    if len(parts) == 6:
        try:
            spend = float(parts[0])
            impressions = int(float(parts[1]))
            clicks = int(float(parts[2]))
            leads = int(float(parts[3]))
            confirmed = int(float(parts[4]))
            frequency = float(parts[5])

            if spend < 0 or impressions < 0 or clicks < 0:
                raise ValueError

            await state.update_data(
                spend=spend,
                impressions=impressions,
                clicks=clicks,
                leads=leads,
                confirmed=confirmed,
                has_confirmed=confirmed > 0,
                frequency=frequency
            )

            d = await state.get_data()
            name = d["update_name"]

            # Старые данные для динамики
            bundles = get_bundles(message.from_user.id)
            old = bundles.get(name, {})

            # Генерация отчёта
            report, bundle_data = await build_report(d)
            save_bundle(message.from_user.id, name, bundle_data)

            await message.answer(report, parse_mode="HTML")

            delta_report = build_delta(old, bundle_data)
            if delta_report:
                await message.answer(delta_report, parse_mode="HTML")

            await message.answer(
                f"✅ Связка «{name}» обновлена!",
                reply_markup=main_kb()
            )
            await state.clear()
            return

        except (ValueError, IndexError):
            await message.answer(
                "❌ Неверный формат. Нужно 6 чисел:\n"
                "<code>расход показы клики лиды подтв частота</code>\n\n"
                "Или введи только расход ($) — пойдём пошагово:",
                parse_mode="HTML"
            )
            return

    # Пошаговый ввод — только расход
    v = pn(text)
    if v is None or v < 0:
        await message.answer(
            "❌ Введи число или 6 чисел:\n"
            "<code>расход показы клики лиды подтв частота</code>",
            parse_mode="HTML"
        )
        return
    await state.update_data(spend=v)
    await message.answer("👁 Новое кол-во показов:", reply_markup=cancel_kb())
    await state.set_state(UpdateBundle.impressions)


@dp.message(UpdateBundle.impressions)
async def update_impressions(message: types.Message, state: FSMContext):
    v = pn_int(message.text)
    if v is None or v < 0:
        await message.answer("❌ Целое число:")
        return
    await state.update_data(impressions=v)
    await message.answer("🖱 Новое кол-во кликов:", reply_markup=cancel_kb())
    await state.set_state(UpdateBundle.clicks)


@dp.message(UpdateBundle.clicks)
async def update_clicks(message: types.Message, state: FSMContext):
    v = pn_int(message.text)
    if v is None or v < 0:
        await message.answer("❌ Целое число:")
        return
    await state.update_data(clicks=v)
    await message.answer("📝 Новое кол-во лидов:", reply_markup=cancel_kb())
    await state.set_state(UpdateBundle.leads)


@dp.message(UpdateBundle.leads)
async def update_leads(message: types.Message, state: FSMContext):
    v = pn_int(message.text)
    if v is None or v < 0:
        await message.answer("❌ Целое число:")
        return
    await state.update_data(leads=v)

    if v > 0:
        await message.answer("✅ Есть подтверждённые лиды?", reply_markup=yes_no_kb())
        await state.set_state(UpdateBundle.has_confirmed)
    else:
        await state.update_data(has_confirmed=False, confirmed=0)
        await message.answer("🔄 Частота (Frequency):", reply_markup=cancel_kb())
        await state.set_state(UpdateBundle.frequency)


@dp.message(UpdateBundle.has_confirmed)
async def update_has_confirmed(message: types.Message, state: FSMContext):
    v = pyn(message.text)
    if v is None:
        await message.answer("❌ Да или Нет:")
        return
    if v:
        await state.update_data(has_confirmed=True)
        await message.answer("✅ Сколько подтверждённых?", reply_markup=cancel_kb())
        await state.set_state(UpdateBundle.confirmed)
    else:
        await state.update_data(has_confirmed=False, confirmed=0)
        await message.answer("🔄 Частота (Frequency):", reply_markup=cancel_kb())
        await state.set_state(UpdateBundle.frequency)


@dp.message(UpdateBundle.confirmed)
async def update_confirmed(message: types.Message, state: FSMContext):
    v = pn_int(message.text)
    if v is None or v < 0:
        await message.answer("❌ Целое число:")
        return
    d = await state.get_data()
    if v > d["leads"]:
        await message.answer(f"❌ Не может быть больше лидов ({d['leads']}):")
        return
    await state.update_data(confirmed=v)
    await message.answer("🔄 Частота (Frequency):", reply_markup=cancel_kb())
    await state.set_state(UpdateBundle.frequency)


@dp.message(UpdateBundle.frequency)
async def update_frequency(message: types.Message, state: FSMContext):
    v = pn(message.text)
    if v is None or v < 0:
        await message.answer("❌ Число:")
        return
    await state.update_data(frequency=v)

    d = await state.get_data()
    name = d["update_name"]

    # Получаем старые данные для сравнения
    bundles = get_bundles(message.from_user.id)
    old = bundles.get(name, {})

    # Генерация отчёта
    report, bundle_data = await build_report(d)

    # Сохраняем (с историей)
    save_bundle(message.from_user.id, name, bundle_data)

    # Отправляем основной отчёт
    await message.answer(report, parse_mode="HTML")

    # Считаем динамику
    delta_report = build_delta(old, bundle_data)
    if delta_report:
        await message.answer(delta_report, parse_mode="HTML")

    await message.answer(
        f"✅ Связка «{name}» обновлена!",
        reply_markup=main_kb()
    )
    await state.clear()  

