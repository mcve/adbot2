        reply_markup=kb
    )
    await state.set_state(ReminderSetup.interval)


@dp.message(ReminderSetup.interval)
async def reminder_save(message: types.Message, state: FSMContext):
    text = message.text.strip().lower()
    intervals = {
        "30 минут": 1800,
        "1 час": 3600,
        "2 часа": 7200,
        "3 часа": 10800,
        "4 часа": 14400,
        "6 часов": 21600,
    }
    seconds = intervals.get(message.text.strip())
    if not seconds:
        v = pn(text)
        if v and 10 <= v <= 1440:
            seconds = int(v * 60)
        else:
            await message.answer("❌ Выбери из кнопок или введи минуты (10-1440):")
            return

    save_reminder(message.from_user.id, {
        "enabled": True,
        "use_ai": True,
        "interval": seconds,
        "next": (datetime.now() + timedelta(seconds=seconds)).isoformat(),
        "last_alerts": {},
        "last_ok_sent": "",
    })

    h = seconds // 3600
    m = (seconds % 3600) // 60
    ts = f"{h}ч {m}мин" if h > 0 else f"{m}мин"

    await state.clear()
    await message.answer(
        f"🤖 <b>Товарный Бро активирован!</b>\n\n"
        f"🔄 Разбор каждые {ts}\n"
        f"🧠 AI анализ: включён\n\n"
        f"Бро сам загрузит данные и пришлёт разбор.\n"
        f"Первый отчёт — через {ts} 🚀",
        parse_mode="HTML",
        reply_markup=main_kb()
    )


@dp.message(F.text.in_({"🔕 Выключить Товарного Бро", "🔕 Выключить оповещения",
                          "🔕 Выключить напоминания"}))
async def reminder_off(message: types.Message, state: FSMContext):
    await state.clear()
    delete_reminder(message.from_user.id)
    await message.answer("🔕 Товарный Бро выключен.", reply_markup=main_kb())


@dp.message(F.text == "🤖 Вкл/Выкл AI разбор")
async def toggle_ai(message: types.Message, state: FSMContext):
    await state.clear()
    reminders = get_reminders()
    uid = str(message.from_user.id)
    current = reminders.get(uid, {})

    use_ai = current.get("use_ai", True)
    new_val = not use_ai

    current["use_ai"] = new_val
    save_reminder(message.from_user.id, current)

    status = "✅ Включён" if new_val else "❌ Выключен"
    mode = "AI разбор каждой связки" if new_val else "Только алерты (без AI)"

    await message.answer(
        f"🧠 AI разбор: <b>{status}</b>\n\n"
        f"Режим: {mode}",
        parse_mode="HTML",
        reply_markup=main_kb()
    )

@dp.message(F.text.in_({"🔕 Выключить оповещения", "🔕 Выключить напоминания"}))
async def reminder_off(message: types.Message, state: FSMContext):
    await state.clear()
    delete_reminder(message.from_user.id)
    await message.answer("🔕 Оповещения выключены.", reply_markup=main_kb())


