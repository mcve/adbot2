@dp.message(F.text == "🎵 Дашборд TikTok")
async def ai_tt_live(message: types.Message, state: FSMContext):
    await message.answer("⏳ <b>Загружаю данные из TikTok...</b>", parse_mode="HTML")

    # 1. Загружаем кампании
    camps_result = await tt_get_campaigns()
    if not camps_result["ok"] or not camps_result["data"]:
        await message.answer("❌ Не удалось загрузить кампании TikTok.", reply_markup=main_kb())
        return

    campaigns = camps_result["data"]
    active_camps = [c for c in campaigns if
                    c.get("operation_status") in ["ENABLE", "CAMPAIGN_STATUS_ENABLE"] or
                    c.get("secondary_status") in ["CAMPAIGN_STATUS_ENABLE", "CAMPAIGN_STATUS_BUDGET_EXCEED"]]

    if not active_camps:
        active_camps = campaigns[:10]

    await message.answer(
        f"📊 Найдено кампаний: {len(campaigns)}\n"
        f"🟢 Активных: {len(active_camps)}\n"
        f"⏳ Загружаю связки...",
        parse_mode="HTML"
    )

    # 2. Загружаем юнит-планы
    plans = get_plans(message.from_user.id)

    total_spend = 0.0
    total_leads = 0
    dashboard_messages = []   # Сообщения для юзера (дашборд)
    ai_context = ""           # Контекст для AI
    all_ag_verdicts = []      # Вердикты связок для AI
    rules_triggered = []      # Сработавшие правила

    for camp in active_camps[:10]:
        camp_id = camp.get("campaign_id", "")
        camp_name = camp.get("campaign_name", "Без названия")

        # Загружаем adgroups
        adgroups = await tt_get_adgroup_insights(camp_id, "today")

        camp_spend = sum(ag["spend"] for ag in adgroups) if adgroups else 0
        camp_leads = sum(ag["leads"] for ag in adgroups) if adgroups else 0
        camp_clicks = sum(ag["clicks"] for ag in adgroups) if adgroups else 0
        camp_imp = sum(ag["impressions"] for ag in adgroups) if adgroups else 0

        if not adgroups:
            camp_stats = await tt_get_campaign_insights(camp_id, "today")
            if camp_stats and camp_stats.get("ok") and camp_stats.get("data"):
                m = camp_stats["data"]
                camp_spend = float(m.get("spend", 0) or 0)
                camp_imp = int(float(m.get("impressions", 0) or 0))
                camp_clicks = int(float(m.get("clicks", 0) or 0))
                camp_leads = int(float(m.get("conversion", 0) or 0))

        if camp_spend == 0 and camp_imp == 0:
            continue

        total_spend += camp_spend
        total_leads += camp_leads

        camp_ctr = (camp_clicks / camp_imp * 100) if camp_imp > 0 else 0
        camp_cpc = (camp_spend / camp_clicks) if camp_clicks > 0 else 0
        camp_cpl = (camp_spend / camp_leads) if camp_leads > 0 else 0

        # Находим юнит-план
        plan_cpl_20 = 0
        plan_cpl_0 = 0
        plan_info = None
        plan_name_found = ""
        if plans:
            for pname, plan in plans.items():
                for lc in plan.get("linked_campaigns", []):
                    if str(lc.get("id", "")) == str(camp_id):
                        plan_cpl_20 = plan.get("max_cpl_20", 0) or plan.get("max_cpl", 0) or 0
                        plan_cpl_0 = plan.get("max_cpl_0", 0) or plan.get("max_cpl", 0) or 0
                        plan_info = plan
                        plan_name_found = pname
                        break

        # ══════════════════════════════════════════
        # ДАШБОРД — железные цифры, формируем кодом
        # ══════════════════════════════════════════
        dash = f"\n📦 <b>{camp_name[:35]}</b>\n"

        # Юнит-план
        if plan_info:
            dash += f"┌─ ЮНИТ-ПЛАН ──────────────────┐\n"
            dash += f"│ Цена: {plan_info.get('landing_price', '?')} BYN\n"
            dash += f"│ Прибыль/лид: {plan_info.get('net_profit', '?')} BYN\n"
            prof = plan_info.get('profitability', 0)
            dash += f"│ Рентабельность: {prof}%\n"
            dash += f"│ CPL план (рент {prof}%): <b>${plan_cpl_20:.2f}</b>\n"
            dash += f"│ CPL безубыток: <b>${plan_cpl_0:.2f}</b>\n"
            dash += f"└──────────────────────────────┘\n"
        else:
            dash += f"⚠️ Юнит-план не привязан\n"

        # Реклама сегодня
        dash += f"┌─ РЕКЛАМА СЕГОДНЯ ────────────┐\n"
        dash += f"│ 💵 Расход: <b>${camp_spend:.2f}</b>\n"
        dash += f"│ 👁 Показы: {camp_imp} | 👆 Клики: {camp_clicks}\n"
        dash += f"│ 📊 CTR: {camp_ctr:.2f}% | CPC: ${camp_cpc:.2f}\n"
        dash += f"│ 📝 Лидов: <b>{camp_leads}</b>"
        if camp_leads > 0:
            dash += f" | 💰 CPL: <b>${camp_cpl:.2f}</b>\n"
            # Вердикт по плану
            if plan_cpl_20 > 0:
                if camp_cpl <= plan_cpl_20:
                    diff = ((plan_cpl_20 - camp_cpl) / plan_cpl_20) * 100
                    dash += f"│ ✅ CPL ниже плана на {diff:.0f}%\n"
                elif camp_cpl <= plan_cpl_0:
                    over = ((camp_cpl - plan_cpl_20) / plan_cpl_20) * 100
                    dash += f"│ ⚠️ CPL выше плана на {over:.0f}% (но не убыток)\n"
                else:
                    over = ((camp_cpl - plan_cpl_0) / plan_cpl_0) * 100
                    dash += f"│ 🔴 УБЫТОК! CPL выше безубытка на {over:.0f}%\n"
        else:
            dash += f"\n│ ⏳ Лидов пока нет\n"
        dash += f"└──────────────────────────────┘\n"

        # ══════════════════════════════════════════
        # СВЯЗКИ — с автоматическими вердиктами
        # ══════════════════════════════════════════
        dash += f"┌─ СВЯЗКИ ────────────────────┐\n"

        active_ags = []
        disabled_ags = []

        if adgroups:
            for ag in adgroups:
                ag_name = ag["name"][:25]
                ag_spend = ag["spend"]
                ag_leads = ag["leads"]
                ag_cpl = ag["cpl"]
                ag_clicks = ag["clicks"]
                ag_ctr = ag["ctr"]
                ag_cpc = ag.get("cpc", 0)
                ag_imp = ag["impressions"]
                ag_budget = ag.get("budget", 0)
                is_active = ag.get("is_active", True)

                if not is_active:
                    # Выключена — отмечаем как сработавшее правило
                    reason = ""
                    if ag_spend > 0 and ag_leads == 0:
                        reason = f"${ag_spend:.2f} без лидов"
                    elif ag_leads > 0 and plan_cpl_0 > 0 and ag_cpl > plan_cpl_0:
                        reason = f"CPL ${ag_cpl:.2f} > безуб ${plan_cpl_0:.2f}"
                    elif ag_cpc > 0.25:
                        reason = f"CPC ${ag_cpc:.2f} дорогой"
                    else:
                        reason = "выключена"

                    disabled_ags.append(f"│ ⛔ {ag_name} — {reason}\n")
                    rules_triggered.append(f"⛔ {ag_name}: {reason}")
                    continue

                if ag_spend == 0 and ag_imp == 0:
                    continue

                # ═══ АВТОМАТИЧЕСКИЙ ВЕРДИКТ (код, не AI!) ═══
                verdict = ""
                emoji = ""
                action = ""
                budget_str = f"${ag_budget:.2f}" if ag_budget > 0 else "?"

                if ag_leads > 0 and plan_cpl_20 > 0:
                    if ag_cpl <= plan_cpl_20 * 0.7 and ag_leads >= 2:
                        emoji = "🟢"
                        verdict = "ОГОНЬ"
                        if ag_budget > 0:
                            new_b = ag_budget * 1.3
                            action = f"Масштабируй! Бюджет {budget_str} → ${new_b:.2f}"
                        else:
                            action = "Масштабируй! Подними бюджет на 30%"
                    elif ag_cpl <= plan_cpl_20:
                        emoji = "🟢"
                        verdict = "ПЕРСПЕКТИВНАЯ"
                        if ag_budget > 0:
                            new_b = ag_budget * 1.2
                            action = f"Поднять бюджет {budget_str} → ${new_b:.2f}"
                        else:
                            action = "Поднять бюджет на 20%"
                    elif ag_cpl <= plan_cpl_0:
                        emoji = "⚠️"
                        verdict = "РЕНТ ПАДАЕТ"
                        action = "Наблюдать 24ч, если CPL не упадёт — выключить"
                    else:
                        emoji = "🔴"
                        verdict = "УБЫТОК"
                        action = "Выключить! CPL выше безубытка"
                elif ag_leads > 0 and plan_cpl_20 == 0:
                    if ag_cpl <= 2.5:
                        emoji = "🟢"
                        verdict = "ПЕРСПЕКТИВНАЯ"
                        action = "Поднять бюджет на 20%"
                    else:
                        emoji = "⚠️"
                        verdict = "CPL ВЫСОКИЙ"
                        action = "Привяжи план чтобы оценить точнее"
                elif ag_leads == 0:
                    stop_threshold = plan_cpl_0 if plan_cpl_0 > 0 else 5.0

                    if ag_spend >= stop_threshold:
                        emoji = "🛑"
                        verdict = "СТОП"
                        action = f"Выключить! ${ag_spend:.2f} без лидов (порог ${stop_threshold:.2f})"
                    elif ag_spend >= 2.0 and (ag_cpc > 0.25 or (ag_imp > 500 and ag_ctr < 1.0)):
                        emoji = "🔴"
                        verdict = "МЁРТВАЯ"
                        problems = []
                        if ag_cpc > 0.25:
                            problems.append(f"CPC ${ag_cpc:.2f}")
                        if ag_imp > 500 and ag_ctr < 1.0:
                            problems.append(f"CTR {ag_ctr:.1f}%")
                        action = f"Выключить! {', '.join(problems)}"
                    elif ag_spend >= 2.0:
                        emoji = "🟡"
                        remaining = stop_threshold - ag_spend
                        verdict = "НАБИРАЕТ"
                        action = f"Не трогать, до вывода ещё ${remaining:.2f}"
                    else:
                        emoji = "🟡"
                        remaining = 2.0 - ag_spend
                        verdict = "ТЕСТ ИДЁТ"
                        action = f"Ждать ещё ~${remaining:.2f}"

                # Формируем строку дашборда
                line = f"│ {emoji} <b>{ag_name}</b> — {verdict}\n"
                line += f"│   💵${ag_spend:.2f}"
                if ag_budget > 0:
                    line += f" (бюдж {budget_str})"
                line += f" | 👁{ag_imp} | 👆{ag_clicks}\n"
                line += f"│   CTR {ag_ctr:.2f}% | CPC ${ag_cpc:.2f}"
                if ag_leads > 0:
                    line += f" | 📝{ag_leads} лид | CPL ${ag_cpl:.2f}"
                line += f"\n│   → {action}\n"

                active_ags.append(line)

                # Контекст для AI
                all_ag_verdicts.append({
                    "camp": camp_name[:30],
                    "name": ag_name,
                    "spend": ag_spend,
                    "budget": ag_budget,
                    "imp": ag_imp,
                    "clicks": ag_clicks,
                    "ctr": ag_ctr,
                    "cpc": ag_cpc,
                    "leads": ag_leads,
                    "cpl": ag_cpl,
                    "verdict": verdict,
                    "action": action,
                    "plan_cpl_20": plan_cpl_20,
                    "plan_cpl_0": plan_cpl_0,
                })

        for line in active_ags:
            dash += line
        for line in disabled_ags:
            dash += line

        dash += f"└──────────────────────────────┘\n"

        # Сработавшие правила
        camp_rules = [r for r in rules_triggered if True]
        if disabled_ags:
            dash += f"┌─ 🛡 ПРАВИЛА (выключено) ─────┐\n"
            for da in disabled_ags:
                dash += da
            dash += f"└──────────────────────────────┘\n"

        dashboard_messages.append(dash)

    # ══════════════════════════════════════════
    # 3. ОТПРАВЛЯЕМ ДАШБОРД
    # ══════════════════════════════════════════
    total_cpl = (total_spend / total_leads) if total_leads > 0 else 0

    header = f"🤖 <b>ТОВАРНЫЙ БРО</b> | {datetime.now().strftime('%H:%M')}\n"
    header += f"━━━━━━━━━━━━━━━━━━━━\n"
    header += f"💵 Общий расход: <b>${total_spend:.2f}</b>\n"
    header += f"📝 Всего лидов: <b>{total_leads}</b>\n"
    if total_leads > 0:
        header += f"💰 Средний CPL: <b>${total_cpl:.2f}</b>\n"
    header += f"━━━━━━━━━━━━━━━━━━━━"

    await message.answer(header, parse_mode="HTML")

    for dash_block in dashboard_messages:
        if len(dash_block) > 4000:
            parts = smart_split(dash_block, 4000)
            for part in parts:
                try:
                    await message.answer(part, parse_mode="HTML")
                except Exception:
                    await message.answer(part)
        else:
            try:
                await message.answer(dash_block, parse_mode="HTML")
            except Exception:
                await message.answer(dash_block)

    # ══════════════════════════════════════════
    # 4. AI РЕКОМЕНДАЦИИ (только советы, цифры уже показаны)
    # ══════════════════════════════════════════
    await message.answer("🤖 <b>Формирую рекомендации...</b>", parse_mode="HTML")

    # Собираем контекст для AI
    ai_data = "ДАШБОРД (цифры уже показаны пользователю, НЕ ПОВТОРЯЙ их):\n\n"
    ai_data += f"Общий расход: ${total_spend:.2f}, лидов: {total_leads}\n\n"

    for v in all_ag_verdicts:
        ai_data += f"Связка: {v['name']} (кампания: {v['camp']})\n"
        ai_data += f"  Расход: ${v['spend']:.2f} | Бюджет: ${v['budget']:.2f}\n"
        ai_data += f"  Показы: {v['imp']} | Клики: {v['clicks']} | CTR: {v['ctr']:.2f}% | CPC: ${v['cpc']:.2f}\n"
        ai_data += f"  Лиды: {v['leads']}"
        if v['leads'] > 0:
            ai_data += f" | CPL: ${v['cpl']:.2f}"
        ai_data += f"\n"
        ai_data += f"  ВЕРДИКТ СИСТЕМЫ: {v['verdict']}\n"
        ai_data += f"  ДЕЙСТВИЕ СИСТЕМЫ: {v['action']}\n"
        ai_data += f"  План CPL: ${v['plan_cpl_20']:.2f} | Безубыток: ${v['plan_cpl_0']:.2f}\n\n"

    if rules_triggered:
        ai_data += "ВЫКЛЮЧЕННЫЕ ПРАВИЛАМИ:\n"
        for rt in rules_triggered:
            ai_data += f"  {rt}\n"
        ai_data += "\n"

    if plans:
        ai_data += "ЮНИТ-ПЛАНЫ:\n"
        for pname, plan in plans.items():
            max_cpl_20 = plan.get("max_cpl_20", 0) or plan.get("max_cpl", 0) or 0
            max_cpl_0 = plan.get("max_cpl_0", 0) or plan.get("max_cpl", 0) or 0
            ai_data += f"  {pname}: CPL план=${max_cpl_20:.2f}, безубыток=${max_cpl_0:.2f}, "
            ai_data += f"прибыль={plan.get('net_profit', 0)} BYN, цена={plan.get('landing_price', 0)} BYN\n"

    prompt = (
        "Ты — AI-помощник таргетолога. Пользователю УЖЕ показан дашборд с цифрами и вердиктами.\n\n"
        "ТВОЯ ЗАДАЧА — дополнить дашборд ЭКСПЕРТНЫМ МНЕНИЕМ. НЕ повторяй цифры и вердикты!\n\n"
        "СТРОГИЕ ПРАВИЛА:\n"
        "1. НЕ ПОВТОРЯЙ цифры — они уже на экране\n"
        "2. НЕ СПОРЬ с вердиктами системы — они рассчитаны по юнит-плану\n"
        "3. Если система сказала УБЫТОК — подтверди и объясни ПОЧЕМУ\n"
        "4. Если система сказала СТОП — подтверди, НЕ говори 'ждать'\n"
        "5. Добавляй ИНСАЙТЫ которые код не может: паттерны, тренды, стратегию\n"
        "6. Отвечай ТОЛЬКО на русском\n"
        "7. БЮДЖЕТ ≠ РАСХОД. Бюджет = дневной лимит. Расход = потрачено сегодня\n\n"
        "ФОРМАТ:\n"
        "━━━ 🧠 ЭКСПЕРТНОЕ МНЕНИЕ ━━━\n"
        "[2-4 предложения: общая картина, тренд, что работает/нет]\n\n"
        "━━━ 💡 ИНСАЙТЫ ━━━\n"
        "[Что код не видит: паттерны CTR/CPC между связками, аномалии, "
        "рекомендации по крео, аудитории, времени суток]\n\n"
        "━━━ 🎯 СТРАТЕГИЯ ━━━\n"
        "[Что делать дальше: масштабирование, новые крео, апсейлы, "
        "перераспределение бюджета]\n\n"
        "Коротко, по делу, как друг-таргетолог."
    )

    response = await ai_ask(prompt, ai_data)

    import html as html_module
    safe_response = html_module.escape(response)

    if len(safe_response) > 4000:
        parts = smart_split(safe_response, 4000)
        for part in parts:
            try:
                await message.answer(part, parse_mode="HTML")
            except Exception:
                await message.answer(part)
    else:
        try:
            await message.answer(safe_response, parse_mode="HTML")
        except Exception:
            await message.answer(response)

    await state.update_data(ai_context=ai_data, ai_product=None)
    await message.answer(
        "💬 Уточни или спроси ещё:",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="🔄 Обновить данные")],
            [KeyboardButton(text="🚪 Выход из чата")]
        ], resize_keyboard=True)
    )
    await state.set_state(AIChat.chatting)

@dp.message(F.text == "🔄 Обновить данные")
async def ai_refresh(message: types.Message, state: FSMContext):
    await state.clear()
    await ai_tt_live(message, state)


@dp.message(F.text == "📘 Дашборд Facebook")
async def dashboard_fb(message: types.Message, state: FSMContext):
    uid = message.from_user.id
    await message.answer("⏳ <b>Загружаю Facebook...</b>", parse_mode="HTML")

    plans = get_plans(uid)

    # Собираем данные FB
    result = await fb_get_campaigns(date_preset="today")
    if not result["ok"] or not result["data"]:
        await message.answer("❌ Нет данных Facebook за сегодня.", reply_markup=main_kb())
        return

    now = datetime.now()
    total_spend = 0
    total_leads = 0
    campaigns_info = []

    for row in result["data"]:
        name = row.get("campaign_name", "Без названия")[:35]
        camp_id = row.get("campaign_id", "")
        spend = float(row.get("spend", 0))
        imp = int(row.get("impressions", 0))
        clicks = int(row.get("clicks", 0))
        ctr = float(row.get("ctr", 0))
        cpc = float(row.get("cpc", 0))
        freq = float(row.get("frequency", 0))
        leads = fb_extract_leads(row.get("actions"))
        cpl = (spend / leads) if leads > 0 else 0

        total_spend += spend
        total_leads += leads

        campaigns_info.append({
            "name": name, "id": camp_id,
            "spend": spend, "imp": imp, "clicks": clicks,
            "ctr": ctr, "cpc": cpc, "freq": freq,
            "leads": leads, "cpl": cpl,
        })

    total_cpl = (total_spend / total_leads) if total_leads > 0 else 0

    # ═══ ЮНИТ-ПЛАН ═══
    msg = f"📘 <b>ДАШБОРД FACEBOOK</b> | {now.strftime('%H:%M')}\n"
    msg += f"━━━━━━━━━━━━━━━━━━━━\n"

    # Показываем планы с FB кампаниями
    plan_shown = False
    matched_plan = None
    if plans:
        for plan_name, plan in plans.items():
            fb_linked = [c for c in plan.get("linked_campaigns", []) if c.get("source") == "fb"]
            if not fb_linked:
                continue

            matched_plan = plan
            max_cpl_20 = plan.get("max_cpl_20", 0) or plan.get("max_cpl", 0) or 0
            max_cpl_0 = plan.get("max_cpl_0", 0) or plan.get("max_cpl", 0) or 0
            profit = plan.get("net_profit", 0)
            rent = plan.get("profitability", 0)

            msg += f"\n📦 <b>{plan_name}</b>\n"
            msg += f"┌─ ЮНИТ-ПЛАН ──────────────────┐\n"
            msg += f"│ Прибыль/лид: {profit} BYN\n"
            msg += f"│ Рентабельность: {rent}%\n"
            msg += f"│ CPL план: ${max_cpl_20:.2f}\n"
            msg += f"│ CPL безубыток: ${max_cpl_0:.2f}\n"
            msg += f"└──────────────────────────────┘\n"
            plan_shown = True

    if not plan_shown:
        msg += "\n⚠️ Нет планов с привязанными FB кампаниями\n"

    # ═══ ИТОГО ═══
    msg += f"\n━━━ 📊 ИТОГО ━━━\n"
    msg += f"💵 Расход: <b>${total_spend:.2f}</b>\n"
    msg += f"📝 Лидов: <b>{total_leads}</b>\n"
    if total_leads > 0:
        msg += f"💰 CPL: <b>${total_cpl:.2f}</b>\n"

        if matched_plan:
            max_cpl_20 = matched_plan.get("max_cpl_20", 0) or matched_plan.get("max_cpl", 0) or 0
            max_cpl_0 = matched_plan.get("max_cpl_0", 0) or matched_plan.get("max_cpl", 0) or 0
            profit = matched_plan.get("net_profit", 0)
            buyout = matched_plan.get("buyout_pct", 50) / 100

            if max_cpl_20 > 0:
                if total_cpl <= max_cpl_20:
                    msg += f"✅ CPL ниже плана!\n"
                elif total_cpl <= max_cpl_0:
                    msg += f"⚠️ CPL выше плана, но не убыток\n"
                else:
                    msg += f"🔴 CPL выше безубытка!\n"

            if profit and buyout:
                orders = int(total_leads * buyout)
                est_profit = orders * profit - total_spend * 3.2
                msg += f"\n━━━ 💰 ПРОГНОЗ ━━━\n"
                msg += f"✅ Заказов: ~{orders}\n"
                msg += f"💰 Прибыль: ~{est_profit:.0f} BYN\n"

    msg += f"\n━━━━━━━━━━━━━━━━━━━━\n"

    # ═══ КАМПАНИИ ═══
    msg += f"\n━━━ 📋 КАМПАНИИ ━━━\n"

    for ci in campaigns_info:
        if ci["spend"] == 0 and ci["imp"] == 0:
            continue

        # Вердикт кампании
        emoji = "⏳"
        if ci["leads"] > 0 and matched_plan:
            max20 = matched_plan.get("max_cpl_20", 0) or 0
            max0 = matched_plan.get("max_cpl_0", 0) or 0
            if max20 > 0 and ci["cpl"] <= max20:
                emoji = "🟢"
            elif max0 > 0 and ci["cpl"] <= max0:
                emoji = "🟡"
            elif max0 > 0 and ci["cpl"] > max0:
                emoji = "🔴"
            else:
                emoji = "🟢" if ci["cpl"] <= 3.0 else "🟡"
        elif ci["leads"] > 0:
            emoji = "🟢" if ci["cpl"] <= 3.0 else "🟡"

        msg += f"\n{emoji} 📘 <b>{ci['name']}</b>\n"
        msg += f"   💵 ${ci['spend']:.2f} | 👁 {ci['imp']} | 🖱 {ci['clicks']}\n"
        msg += f"   📊 CTR {ci['ctr']:.2f}% | CPC ${ci['cpc']:.2f} | Freq {ci['freq']:.1f}\n"
        msg += f"   📝 {ci['leads']} лид"
        if ci["leads"] > 0:
            msg += f" | CPL ${ci['cpl']:.2f}"
        msg += "\n"

    # ═══ ВНИМАНИЕ ═══
    warnings = []
    for ci in campaigns_info:
        if ci["spend"] == 0:
            continue
        if matched_plan:
            max0 = matched_plan.get("max_cpl_0", 0) or 0
            max20 = matched_plan.get("max_cpl_20", 0) or 0

            if ci["leads"] > 0 and max0 > 0 and ci["cpl"] > max0:
                warnings.append(f"🔴 «{ci['name']}» — CPL ${ci['cpl']:.2f} > безуб ${max0:.2f}. УБЫТОК!")
            elif ci["leads"] > 0 and max20 > 0 and ci["cpl"] <= max20 * 0.7 and ci["leads"] >= 2:
                warnings.append(f"🟢 «{ci['name']}» — CPL ${ci['cpl']:.2f} — огонь! Масштабируй!")
            elif ci["spend"] >= 5 and ci["leads"] == 0:
                warnings.append(f"🛑 «{ci['name']}» — ${ci['spend']:.2f} без лидов!")

        if ci["imp"] > 1000 and ci["ctr"] < 0.8:
            warnings.append(f"⚠️ «{ci['name']}» — CTR {ci['ctr']:.2f}% дно! Меняй крео")
        if ci["freq"] > 3.0:
            warnings.append(f"⚠️ «{ci['name']}» — Частота {ci['freq']:.1f}! Аудитория выгорает")

    if warnings:
        msg += f"\n━━━ ⚠️ ВНИМАНИЕ ━━━\n"
        for w in warnings:
            msg += f"{w}\n"

    msg += f"━━━━━━━━━━━━━━━━━━━━"

    # Отправляем дашборд
    if len(msg) > 4000:
        for p in smart_split(msg, 4000):
            try:
                await bot.send_message(uid, p, parse_mode="HTML")
            except Exception:
                await bot.send_message(uid, p)
    else:
        try:
            await bot.send_message(uid, msg, parse_mode="HTML")
        except Exception:
            await bot.send_message(uid, msg)

    # ═══ AI АНАЛИЗ ═══
    ai_data = f"Facebook Ads | Расход: ${total_spend:.2f}, лидов: {total_leads}\n\n"
    for ci in campaigns_info:
        if ci["spend"] == 0:
            continue
        ai_data += (
            f"Кампания: {ci['name']}\n"
            f"  ${ci['spend']:.2f} | {ci['imp']} показов | {ci['clicks']} кликов | "
            f"CTR {ci['ctr']:.2f}% | CPC ${ci['cpc']:.2f} | Freq {ci['freq']:.1f} | "
            f"лиды {ci['leads']}"
        )
        if ci["leads"] > 0:
            ai_data += f" | CPL ${ci['cpl']:.2f}"
        ai_data += "\n\n"

    if matched_plan:
        ai_data += (
            f"ЮНИТ-ПЛАН: CPL план ${matched_plan.get('max_cpl_20', 0):.2f}, "
            f"безуб ${matched_plan.get('max_cpl_0', 0):.2f}\n"
        )

    if warnings:
        ai_data += "\nАЛЕРТЫ:\n"
        for w in warnings:
            ai_data += f"  {w}\n"

    prompt = (
        "Пользователю УЖЕ показан дашборд Facebook с цифрами.\n"
        "НЕ повторяй цифры!\n\n"
        "ФОРМАТ:\n"
        "━━━ 🧠 МНЕНИЕ ━━━\n[2-3 предл]\n\n"
        "━━━ 💡 ИНСАЙТЫ ━━━\n[паттерны CTR/CPC/Freq, крео, аудитория]\n\n"
        "━━━ 🎯 СТРАТЕГИЯ ━━━\n[масштабирование, Look-alike, крео]\n\n"
        "Учитывай особенности FB: частота, выгорание аудитории, "
        "Look-alike, CBO vs ABO.\n"
        "Коротко, как друг-таргетолог. Только русский."
    )

    try:
        ai_resp = await ai_ask(prompt, ai_data)
        import html as html_module
        safe = html_module.escape(ai_resp)
        if len(safe) > 4000:
            for p in smart_split(safe, 4000):
                try:
                    await bot.send_message(uid, p, parse_mode="HTML")
                except Exception:
                    await bot.send_message(uid, p)
        else:
            try:
                await bot.send_message(uid, safe, parse_mode="HTML")
            except Exception:
                await bot.send_message(uid, ai_resp)
    except Exception as e:
        logging.error(f"Dashboard FB AI error: {e}")


@dp.message(F.text == "📎 Из сохранённых связок")
async def ai_saved_bundles(message: types.Message, state: FSMContext):
    await message.answer("🤖 <b>Анализирую сохранённые связки...</b>", parse_mode="HTML")

    ctx = build_product_context(message.from_user.id)

    if not ctx.strip():
        await message.answer("❌ Нет сохранённых данных.", reply_markup=main_kb())
        return

    prompt = (
        "Проанализируй все мои сохранённые рекламные связки.\n"
        "По каждой: что хорошо, что плохо, что делать.\n"
        "В конце — общие рекомендации."
    )

    response = await ai_ask(prompt, ctx)

    await message.answer(f"🤖 <b>AI АНАЛИЗ</b>\n\n{response}", parse_mode="HTML")

    await state.update_data(ai_context=ctx, ai_product=None)
    await message.answer(
        "💬 Уточни или выйди:",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="🚪 Выход из чата")]
        ], resize_keyboard=True)
    )
    await state.set_state(AIChat.chatting)


@dp.message(F.text == "💡 AI подсказка по отбору")
async def ai_tips(message: types.Message, state: FSMContext):
    await state.clear()
    await message.answer("🤖 <b>Думаю...</b>", parse_mode="HTML")

    ctx = build_product_context(message.from_user.id)
    prompt = (
        "Дай практические советы по отбору товара для товарного бизнеса (COD).\n"
        "Учти мои текущие данные.\n\n"
        "1. Что искать (ниши, тренды)\n"
        "2. Где искать (источники)\n"
        "3. Как проверять (чек-лист)\n"
        "4. Красные флаги\n"
        "5. Конкретный совет для меня"
    )

    response = await ai_ask(prompt, ctx)

    await message.answer(f"💡 <b>AI ПОДСКАЗКИ</b>\n\n{response}", parse_mode="HTML")

    await state.update_data(ai_context=ctx, ai_product=None)
    await message.answer(
        "💬 Уточни или выйди:",
        reply_markup=ReplyKeyboardMarkup(keyboard=[
            [KeyboardButton(text="🚪 Выход из чата")]
        ], resize_keyboard=True)
    )
    await state.set_state(AIChat.chatting)


@dp.message(F.text == "🚪 Выход из чата")
async def ai_exit(message: types.Message, state: FSMContext):
    await state.clear()
    await message.answer("👋 Вышел из AI чата.", reply_markup=main_kb())


@dp.message(AIChat.chatting)
async def ai_chat_message(message: types.Message, state: FSMContext):
    text = message.text.strip()

    if len(text) < 2:
        await message.answer("❌ Минимум 2 символа:")
        return
    if len(text) > 2000:
        await message.answer("❌ Максимум 2000 символов:")
        return

    d = await state.get_data()
    ctx = d.get("ai_context", "")
    product = d.get("ai_product")
    history = d.get("chat_history", [])

    if product:
        text = f"[Товар: {product}] {text}"

    await message.answer("🤖 <i>Думаю...</i>", parse_mode="HTML")

    response = await ai_ask(text, ctx, history=history)

    # Сохраняем историю
    history.append({"role": "user", "text": text})
    history.append({"role": "assistant", "text": response[:500]})
    # Храним максимум 10 сообщений
    if len(history) > 10:
        history = history[-10:]
    await state.update_data(chat_history=history)

    if len(response) > 4000:
        parts = smart_split(response, 4000)
        for part in parts:
            try:
                await message.answer(part)
            except Exception:
                await message.answer(part, parse_mode=None)
    else:
        try:
            await message.answer(response)
        except Exception:
            await message.answer(response, parse_mode=None)


