async def tt_refresh_token():
    """Обновляет access_token через refresh_token"""
    url = "https://business-api.tiktok.com/open_api/v1.3/oauth2/access_token/"
    data = {
        "app_id": TT_APP_ID,
        "secret": TT_APP_SECRET,
        "grant_type": "refresh_token",
        "refresh_token": tt_token_data["refresh_token"],
    }
    try:
        async with aiohttp.ClientSession() as session:
            async with session.post(url, json=data) as resp:
                res = await resp.json()
                if res.get("code") == 0:
                    new_data = res["data"]
                    tt_token_data["access_token"] = new_data["access_token"]
                    tt_token_data["refresh_token"] = new_data.get(
                        "refresh_token", tt_token_data["refresh_token"]
                    )
                    logging.info("✅ TikTok token refreshed!")
                    return True
                else:
                    logging.error(f"TT refresh error: {res}")
                    return False
    except Exception as e:
        logging.error(f"TT refresh exception: {e}")
        return False
async def tt_get_campaigns():
    """Получает список кампаний из TikTok"""
    url = "https://business-api.tiktok.com/open_api/v1.3/campaign/get/"
    headers = {
        "Access-Token": tt_token_data["access_token"],
    }
    params = {
        "advertiser_id": TT_ADVERTISER_ID,
        "page": 1,
        "page_size": 50,
    }
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(url, headers=headers, params=params) as resp:
                res = await resp.json()
                if res.get("code") == 0:
                    campaigns = res.get("data", {}).get("list", [])
                    return {"ok": True, "data": campaigns}
                else:
                    return {"ok": False, "error": res.get("message", "unknown")}
    except Exception as e:
        return {"ok": False, "error": str(e)}

async def tt_get_campaign_insights(campaign_id, preset="today"):
    """Получает статистику конкретной кампании TikTok"""
    from datetime import timezone, timedelta as td
    minsk_tz = timezone(td(hours=3))
    today = datetime.now(minsk_tz).date()
    if preset in ["today", "Сегодня"]:
        start_date = end_date = today.isoformat()
    elif preset in ["yesterday", "Вчера"]:
        start_date = end_date = (today - timedelta(days=1)).isoformat()
    elif preset in ["last_7d", "7 дней"]:
        start_date = (today - timedelta(days=6)).isoformat()
        end_date = today.isoformat()
    elif preset in ["last_30d", "30 дней"]:
        start_date = (today - timedelta(days=29)).isoformat()
        end_date = today.isoformat()
    else:
        start_date = end_date = today.isoformat()

    url = "https://business-api.tiktok.com/open_api/v1.3/report/integrated/get/"
    headers = {"Access-Token": tt_token_data["access_token"]}
    base_params = {
        "advertiser_id": TT_ADVERTISER_ID,
        "service_type": "AUCTION",
        "report_type": "BASIC",
        "data_level": "AUCTION_CAMPAIGN",
        "dimensions": json.dumps(["campaign_id"]),
        "start_date": start_date,
        "end_date": end_date,
        "filtering": json.dumps([{
            "field_name": "campaign_ids",
            "filter_type": "IN",
            "filter_value": json.dumps([str(campaign_id)])
        }]),
        "page": 1,
        "page_size": 10,
    }

    result_metrics = {}

    logging.info(f"TT API REQUEST: campaign={campaign_id}, start={start_date}, end={end_date}, preset={preset}")

    try:
        async with aiohttp.ClientSession() as session:
            # Запрос 1: базовые метрики
            params1 = {**base_params, "metrics": json.dumps([
                "spend", "impressions", "clicks", "cpc", "ctr", "cpm"
            ])}
            async with session.get(url, headers=headers, params=params1) as resp:
                res1 = await resp.json()
                if res1.get("code") == 0:
                    data_list = res1.get("data", {}).get("list", [])
                    if data_list:
                        result_metrics = data_list[0].get("metrics", {})

            # Запрос 2: конверсии
            params2 = {**base_params, "metrics": json.dumps([
                "real_time_conversion", "real_time_cost_per_conversion"
            ])}
            async with session.get(url, headers=headers, params=params2) as resp:
                res2 = await resp.json()
                if res2.get("code") == 0:
                    data_list2 = res2.get("data", {}).get("list", [])
                    if data_list2:
                        conv_metrics = data_list2[0].get("metrics", {})
                        result_metrics["conversion"] = conv_metrics.get("real_time_conversion", "0")
                        result_metrics["cost_per_conversion"] = conv_metrics.get("real_time_cost_per_conversion", "0")

        if "conversion" not in result_metrics:
            result_metrics["conversion"] = "0"

        logging.info(f"TT final metrics: {result_metrics}")

        if result_metrics:
            return {"ok": True, "data": result_metrics}
        else:
            return {"ok": False, "data": {}}

    except Exception as e:
        logging.error(f"TT campaign insights error: {e}")
        return {"ok": False, "error": str(e)}

async def tt_get_report(date_range="LAST_7_DAYS"):
    """Получает отчёт TikTok через GET"""
    url = "https://business-api.tiktok.com/open_api/v1.3/report/integrated/get/"
    headers = {
        "Access-Token": tt_token_data["access_token"],
    }
    
    from datetime import timezone, timedelta as td
    minsk_tz = timezone(td(hours=3))
    today = datetime.now(minsk_tz).date()
    if date_range == "TODAY":
        start_date = end_date = today.isoformat()
    elif date_range == "LAST_7_DAYS":
        start_date = (today - timedelta(days=6)).isoformat()
        end_date = today.isoformat()
    else:
        start_date = (today - timedelta(days=6)).isoformat()
        end_date = today.isoformat()

    params = {
        "advertiser_id": TT_ADVERTISER_ID,
        "service_type": "AUCTION",
        "report_type": "BASIC",
        "data_level": "AUCTION_CAMPAIGN",
        "dimensions": json.dumps(["campaign_id"]),
        "metrics": json.dumps(["spend", "impressions", "clicks", "cpc", "ctr", "cpm"]),
        "start_date": start_date,
        "end_date": end_date,
        "page": 1,
        "page_size": 20,
    }
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(url, headers=headers, params=params) as resp:
                response_text = await resp.text()
                logging.info(f"TT API {resp.status}: {response_text[:300]}")
                try:
                    res = json.loads(response_text)
                except Exception:
                    return {"ok": False, "error": response_text[:500]}

                if res.get("code") in [40104, 40105, 40100]:
                    refreshed = await tt_refresh_token()
                    if refreshed:
                        headers["Access-Token"] = tt_token_data["access_token"]
                        async with session.get(url, headers=headers, params=params) as resp2:
                            res = json.loads(await resp2.text())
                            if res.get("code") == 0:
                                return {"ok": True, "data": res.get("data", {}).get("list", [])}
                            return {"ok": False, "error": res.get("message", "unknown")}
                    return {"ok": False, "error": "Не удалось обновить токен"}

                if res.get("code") == 0:
                    return {"ok": True, "data": res.get("data", {}).get("list", [])}
                return {"ok": False, "error": res.get("message", "no message")}
    except Exception as e:
        return {"ok": False, "error": str(e)}

# ══════════════════════════════════════
# УТИЛИТЫ ПАРСИНГА
# ══════════════════════════════════════

def pn(text):
    try:
        return float(text.strip().replace(",", ".").replace("%", "").replace("$", "").replace(" ", ""))
    except:
        return None

def pn_int(text):
    try:
        return int(float(text.strip().replace(",", "").replace(" ", "")))
    except:
        return None

def pyn(text):
    t = text.strip().lower()
    if any(x in t for x in ["да", "yes", "✅"]):
        return True
    if any(x in t for x in ["нет", "no", "❌"]):
        return False
    return None

